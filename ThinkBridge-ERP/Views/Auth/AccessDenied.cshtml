@{
    ViewData["Title"] = "Access Denied";
    ViewData["HideLayout"] = true;
    ViewData["BodyClass"] = "login-page";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/login.css" asp-append-version="true" />
}

<div class="login-container">
    <div class="login-form-container" style="width: 100%; max-width: 500px; margin: auto;">
        <div class="login-form-wrapper" style="text-align: center;">
            <div class="login-logo-mobile">
                <img src="~/images/thinkBridge.png" alt="ThinkBridge" class="logo-icon" />
                <span class="logo-text"><span class="logo-think">Think</span><span
                    class="logo-bridge">Bridge</span></span>
                </div>

                <div style="margin: 2rem 0;">
                    <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"
                         style="margin-bottom: 1rem;">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="8" x2="12" y2="12"></line>
                        <line x1="12" y1="16" x2="12.01" y2="16"></line>
                    </svg>
                </div>

                <div class="login-header">
                    <h2 style="color: #ef4444;">Access Denied</h2>
                    <p>You don't have permission to access this page.</p>
                    <p style="font-size: 0.875rem; color: #6b7280; margin-top: 1rem;">
                        If you believe this is an error, please contact your system administrator.
                    </p>
                </div>

                <div style="margin-top: 2rem;">
                    <a href="javascript:history.back()" class="btn btn-secondary" style="margin-right: 1rem;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="19" y1="12" x2="5" y2="12"></line>
                            <polyline points="12 19 5 12 12 5"></polyline>
                        </svg>
                        Go Back
                    </a>
                    <a href="/Auth/Login" class="btn btn-primary">
                        Return to Login
                    </a>
                </div>
            </div>
        </div>
    </div>