<!-- New Task Modal -->
<div class="modal-overlay" id="new-task-modal">
    <div class="modal modal-lg">
        <div class="modal-header">
            <h2>Create New Task</h2>
            <button class="modal-close" id="task-modal-close">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body">
            <form class="task-form">
                <div class="form-group">
                    <label for="task-name">Task Name</label>
                    <input type="text" id="task-name" class="form-input" placeholder="Enter task name" />
                </div>
                <div class="form-group">
                    <label for="task-description">Description</label>
                    <textarea id="task-description" class="form-textarea" rows="3"
                              placeholder="Enter task description"></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="task-project">Project</label>
                        <select id="task-project" class="form-select">
                            <option value="">Select Project</option>
                            <option value="prj-001">Customer Portal Redesign</option>
                            <option value="prj-002">API Gateway v2.0</option>
                            <option value="prj-003">Mobile App Analytics</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="task-status">Status</label>
                        <select id="task-status" class="form-select">
                            <option value="todo">To Do</option>
                            <option value="in-progress">In Progress</option>
                            <option value="review">Review</option>
                            <option value="done">Done</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="task-priority">Priority</label>
                        <select id="task-priority" class="form-select">
                            <option value="low">Low</option>
                            <option value="medium">Medium</option>
                            <option value="high">High</option>
                            <option value="urgent">Urgent</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="task-due-date">Due Date</label>
                        <input type="date" id="task-due-date" class="form-input" />
                    </div>
                </div>
                <div class="form-group">
                    <label for="task-assignees">Assignees</label>
                    <select id="task-assignees" class="form-select" multiple>
                        <option value="jd">John Doe</option>
                        <option value="sk">Sarah Kim</option>
                        <option value="mk">Michael Kim</option>
                        <option value="lm">Lisa Moore</option>
                        <option value="an">Alex Nguyen</option>
                    </select>
                </div>
            </form>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" id="task-modal-cancel">Cancel</button>
            <button class="btn btn-primary">Create Task</button>
        </div>
    </div>
</div>

<!-- View Task Modal -->
<div class="modal-overlay" id="view-task-modal">
    <div class="modal modal-lg">
        <div class="modal-header modal-header-primary">
            <div>
                <h2>Implement OAuth 2.0 authentication flow</h2>
                <p class="modal-subtitle">TSK-001</p>
            </div>
            <button class="modal-close" data-modal-close>
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body">
            <div class="detail-section">
                <h4 class="detail-section-title">Task Information</h4>
                <div class="detail-grid">
                    <div class="detail-item">
                        <span class="detail-label">Status</span>
                        <span class="badge badge-in-progress">In Progress</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Priority</span>
                        <span class="priority priority-high">High</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Project</span>
                        <span class="detail-value">Customer Portal Redesign</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Due Date</span>
                        <span class="detail-value">Feb 10, 2026</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Stage</span>
                        <span class="stage-tag">Development</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Created</span>
                        <span class="detail-value">Feb 01, 2026</span>
                    </div>
                </div>
            </div>

            <div class="detail-section">
                <h4 class="detail-section-title">Description</h4>
                <p class="detail-description">Implement OAuth 2.0 authentication flow for the customer portal. This
                    includes setting up the authorization server, implementing token-based authentication, and
                    integrating with existing user management system.</p>
                </div>

                <div class="detail-section">
                    <h4 class="detail-section-title">Assignees</h4>
                    <div class="detail-team">
                        <div class="detail-team-member">
                            <span class="member-avatar">SK</span>
                            <span class="member-name">Sarah Kim</span>
                        </div>
                    </div>
                </div>

                <div class="detail-section">
                    <h4 class="detail-section-title">Activity</h4>
                    <div class="detail-timeline">
                        <div class="timeline-item">
                            <div class="timeline-content">
                                <span class="timeline-date">Feb 10, 2026 - 9:15 AM</span>
                                <p class="timeline-text">Sarah Kim added a comment</p>
                            </div>
                        </div>
                        <div class="timeline-item">
                            <div class="timeline-content">
                                <span class="timeline-date">Feb 08, 2026 - 2:30 PM</span>
                                <p class="timeline-text">Status changed to "In Progress"</p>
                            </div>
                        </div>
                        <div class="timeline-item">
                            <div class="timeline-content">
                                <span class="timeline-date">Feb 01, 2026 - 10:00 AM</span>
                                <p class="timeline-text">Task created by John Doe</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-modal-close>Close</button>
                <button class="btn btn-primary" id="edit-task-from-view">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                    </svg>
                    Edit Task
                </button>
            </div>
        </div>
    </div>

