@{
    ViewData["Title"] = "Payments";
    ViewData["UserRole"] = "superadmin";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/superadmin.css" asp-append-version="true" />
}

<div class="page-payments">
    <!-- Page Header -->
    <section class="page-header">
        <div class="header-content">
            <h1 class="page-title">Payments</h1>
            <p class="page-subtitle">Track and manage payment transactions</p>
        </div>
        <button class="btn btn-outline">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            Export Report
        </button>
    </section>

    <!-- Payment Stats -->
    <section class="payment-stats">
        <div class="stat-card">
            <div class="stat-content">
                <span class="stat-label">Total Revenue (Feb)</span>
                <span class="stat-value">$48,500</span>
            </div>
            <div class="stat-trend positive">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
                    <polyline points="17 6 23 6 23 12"></polyline>
                </svg>
                +12%
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-content">
                <span class="stat-label">Pending Payments</span>
                <span class="stat-value warning">$12,450</span>
            </div>
            <span class="stat-count">7 invoices</span>
        </div>
        <div class="stat-card">
            <div class="stat-content">
                <span class="stat-label">Overdue</span>
                <span class="stat-value danger">$2,450</span>
            </div>
            <span class="stat-count">1 invoice</span>
        </div>
        <div class="stat-card">
            <div class="stat-content">
                <span class="stat-label">Collected (Feb)</span>
                <span class="stat-value success">$36,050</span>
            </div>
            <span class="stat-count">32 payments</span>
        </div>
    </section>

    <!-- Filters -->
    <section class="filters-section">
        <div class="filter-tabs">
            <button class="filter-tab active">All</button>
            <button class="filter-tab">Pending</button>
            <button class="filter-tab">Completed</button>
            <button class="filter-tab">Overdue</button>
            <button class="filter-tab">Failed</button>
        </div>
        <div class="filter-actions">
            <input type="month" class="date-filter" value="2026-02" />
        </div>
    </section>

    <!-- Payments Table -->
    <section class="payments-table-section">
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Invoice</th>
                        <th>Company</th>
                        <th>Amount</th>
                        <th>Due Date</th>
                        <th>Status</th>
                        <th>Payment Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="overdue-row">
                        <td><span class="invoice-id">INV-2026-0045</span></td>
                        <td>
                            <div class="company-cell">
                                <div class="company-avatar">HL</div>
                                <span class="company-name">HealthLink Medical</span>
                            </div>
                        </td>
                        <td class="amount">$2,450.00</td>
                        <td>Feb 5, 2026</td>
                        <td><span class="status-badge overdue">Overdue</span></td>
                        <td>-</td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn-small warning">Send Reminder</button>
                                <button class="btn-small">View</button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><span class="invoice-id">INV-2026-0052</span></td>
                        <td>
                            <div class="company-cell">
                                <div class="company-avatar">RS</div>
                                <span class="company-name">RetailSmart Ltd</span>
                            </div>
                        </td>
                        <td class="amount">$1,800.00</td>
                        <td>Feb 20, 2026</td>
                        <td><span class="status-badge pending">Pending</span></td>
                        <td>-</td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn-small">View</button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><span class="invoice-id">INV-2026-0056</span></td>
                        <td>
                            <div class="company-cell">
                                <div class="company-avatar">EG</div>
                                <span class="company-name">EduGlobal Academy</span>
                            </div>
                        </td>
                        <td class="amount">$950.00</td>
                        <td>Feb 28, 2026</td>
                        <td><span class="status-badge pending">Pending</span></td>
                        <td>-</td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn-small">View</button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><span class="invoice-id">INV-2026-0041</span></td>
                        <td>
                            <div class="company-cell">
                                <div class="company-avatar">TC</div>
                                <span class="company-name">TechCorp Solutions</span>
                            </div>
                        </td>
                        <td class="amount">$3,500.00</td>
                        <td>Feb 1, 2026</td>
                        <td><span class="status-badge completed">Completed</span></td>
                        <td>Feb 1, 2026</td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn-small">View</button>
                                <button class="btn-small">Receipt</button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><span class="invoice-id">INV-2026-0042</span></td>
                        <td>
                            <div class="company-cell">
                                <div class="company-avatar">GF</div>
                                <span class="company-name">GlobalFinance Inc</span>
                            </div>
                        </td>
                        <td class="amount">$2,000.00</td>
                        <td>Feb 3, 2026</td>
                        <td><span class="status-badge completed">Completed</span></td>
                        <td>Feb 2, 2026</td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn-small">View</button>
                                <button class="btn-small">Receipt</button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><span class="invoice-id">INV-2026-0038</span></td>
                        <td>
                            <div class="company-cell">
                                <div class="company-avatar">MH</div>
                                <span class="company-name">MegaHoldings Corp</span>
                            </div>
                        </td>
                        <td class="amount">$3,500.00</td>
                        <td>Jan 28, 2026</td>
                        <td><span class="status-badge completed">Completed</span></td>
                        <td>Jan 27, 2026</td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn-small">View</button>
                                <button class="btn-small">Receipt</button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><span class="invoice-id">INV-2026-0035</span></td>
                        <td>
                            <div class="company-cell">
                                <div class="company-avatar">BT</div>
                                <span class="company-name">BuildTech Industries</span>
                            </div>
                        </td>
                        <td class="amount">$500.00</td>
                        <td>Jan 25, 2026</td>
                        <td><span class="status-badge failed">Failed</span></td>
                        <td>-</td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn-small warning">Retry</button>
                                <button class="btn-small">View</button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="pagination">
            <span class="pagination-info">Showing 1-7 of 42 payments</span>
            <div class="pagination-controls">
                <button class="btn-page" disabled>&laquo;</button>
                <button class="btn-page active">1</button>
                <button class="btn-page">2</button>
                <button class="btn-page">3</button>
                <button class="btn-page">...</button>
                <button class="btn-page">6</button>
                <button class="btn-page">&raquo;</button>
            </div>
        </div>
    </section>
</div>