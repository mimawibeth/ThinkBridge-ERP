@{
    ViewData["Title"] = "Subscriptions";
    ViewData["UserRole"] = "superadmin";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/superadmin.css" asp-append-version="true" />
}

<div class="page-subscriptions">
    <!-- Page Header -->
    <section class="page-header">
        <div class="header-content">
            <h1 class="page-title">Subscriptions</h1>
            <p class="page-subtitle">Monitor and manage company subscription plans</p>
        </div>
    </section>

    <!-- Subscription Summary Cards -->
    <section class="subscription-summary">
        <div class="summary-card enterprise">
            <div class="summary-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon
                        points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2">
                    </polygon>
                </svg>
            </div>
            <div class="summary-content">
                <span class="summary-label">Enterprise</span>
                <span class="summary-value">18</span>
                <span class="summary-revenue">$63,000/mo</span>
            </div>
        </div>
        <div class="summary-card professional">
            <div class="summary-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
            </div>
            <div class="summary-content">
                <span class="summary-label">Professional</span>
                <span class="summary-value">14</span>
                <span class="summary-revenue">$28,000/mo</span>
            </div>
        </div>
        <div class="summary-card starter">
            <div class="summary-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
            </div>
            <div class="summary-content">
                <span class="summary-label">Starter</span>
                <span class="summary-value">8</span>
                <span class="summary-revenue">$4,000/mo</span>
            </div>
        </div>
        <div class="summary-card trial">
            <div class="summary-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                    <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
            </div>
            <div class="summary-content">
                <span class="summary-label">Trial</span>
                <span class="summary-value">5</span>
                <span class="summary-revenue">Free</span>
            </div>
        </div>
    </section>

    <!-- Subscriptions Table -->
    <section class="subscriptions-table-section">
        <div class="section-header">
            <h2 class="section-title">All Subscriptions</h2>
            <div class="filter-group">
                <select class="filter-select">
                    <option value="">All Plans</option>
                    <option value="enterprise">Enterprise</option>
                    <option value="professional">Professional</option>
                    <option value="starter">Starter</option>
                    <option value="trial">Trial</option>
                </select>
            </div>
        </div>
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Company</th>
                        <th>Current Plan</th>
                        <th>Price</th>
                        <th>Billing Cycle</th>
                        <th>Next Billing</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>
                            <div class="company-cell">
                                <div class="company-avatar">TC</div>
                                <span class="company-name">TechCorp Solutions</span>
                            </div>
                        </td>
                        <td><span class="plan-badge enterprise">Enterprise</span></td>
                        <td>$3,500/mo</td>
                        <td>Monthly</td>
                        <td>Mar 1, 2026</td>
                        <td><span class="status-badge active">Active</span></td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn-small">Modify</button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <div class="company-cell">
                                <div class="company-avatar">GF</div>
                                <span class="company-name">GlobalFinance Inc</span>
                            </div>
                        </td>
                        <td><span class="plan-badge professional">Professional</span></td>
                        <td>$2,000/mo</td>
                        <td>Monthly</td>
                        <td>Feb 22, 2026</td>
                        <td><span class="status-badge active">Active</span></td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn-small">Modify</button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <div class="company-cell">
                                <div class="company-avatar">HL</div>
                                <span class="company-name">HealthLink Medical</span>
                            </div>
                        </td>
                        <td><span class="plan-badge enterprise">Enterprise</span></td>
                        <td>$3,500/mo</td>
                        <td>Monthly</td>
                        <td>Feb 15, 2026</td>
                        <td><span class="status-badge overdue">Overdue</span></td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn-small warning">Send Reminder</button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <div class="company-cell">
                                <div class="company-avatar">RS</div>
                                <span class="company-name">RetailSmart Ltd</span>
                            </div>
                        </td>
                        <td><span class="plan-badge starter">Starter</span></td>
                        <td>$500/mo</td>
                        <td>Monthly</td>
                        <td>Feb 20, 2026</td>
                        <td><span class="status-badge active">Active</span></td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn-small">Modify</button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <div class="company-cell">
                                <div class="company-avatar">EG</div>
                                <span class="company-name">EduGlobal Academy</span>
                            </div>
                        </td>
                        <td><span class="plan-badge professional">Professional</span></td>
                        <td>$2,000/mo</td>
                        <td>Annual</td>
                        <td>Aug 12, 2026</td>
                        <td><span class="status-badge active">Active</span></td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn-small">Modify</button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <div class="company-cell">
                                <div class="company-avatar">IT</div>
                                <span class="company-name">InnovateTech Co</span>
                            </div>
                        </td>
                        <td><span class="plan-badge trial">Trial</span></td>
                        <td>$0</td>
                        <td>-</td>
                        <td>Feb 23, 2026</td>
                        <td><span class="status-badge trial">14 days left</span></td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn-small success">Convert</button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>

    <!-- Expiring Soon Alert -->
    <section class="alert-section">
        <div class="alert warning">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z">
                </path>
                <line x1="12" y1="9" x2="12" y2="13"></line>
                <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
            <div class="alert-content">
                <strong>3 trial subscriptions expiring soon</strong>
                <p>Contact these companies to discuss conversion to paid plans.</p>
            </div>
            <button class="btn btn-outline">View Details</button>
        </div>
    </section>
</div>