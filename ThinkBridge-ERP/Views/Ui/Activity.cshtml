@{
    ViewData["Title"] = "Activity";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/activity.css" asp-append-version="true" />
}

<div class="page-activity">
    <!-- Page Header -->
    <div class="page-header">
        <div class="header-filters">
            <div class="search-box">
                <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" class="search-input" placeholder="Search activities..." />
            </div>
            <div class="filter-dropdown">
                <button class="filter-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
                    </svg>
                    All Activities
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <!-- Activity Timeline -->
    <div class="activity-timeline">
        <!-- Date Header -->
        <div class="timeline-date">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            <span>Feb 05, 2026</span>
        </div>

        <!-- Activity Item 1 -->
        <div class="activity-item">
            <div class="activity-icon completed">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
            </div>
            <div class="activity-content">
                <div class="activity-header">
                    <p class="activity-text">
                        <strong>Sarah Kim</strong> completed task <a href="#" class="activity-link">Implement OAuth 2.0 flow</a>
                    </p>
                    <span class="activity-avatar">SK</span>
                </div>
                <div class="activity-meta">
                    <span class="activity-time">5 minutes ago</span>
                    <span class="activity-type">Task</span>
                </div>
                <p class="activity-description">Task completed ahead of schedule. All tests passing.</p>
            </div>
        </div>

        <!-- Activity Item 2 -->
        <div class="activity-item">
            <div class="activity-icon upload">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="17 8 12 3 7 8"></polyline>
                    <line x1="12" y1="3" x2="12" y2="15"></line>
                </svg>
            </div>
            <div class="activity-content">
                <div class="activity-header">
                    <p class="activity-text">
                        <strong>Michael Lee</strong> uploaded document <a href="#" class="activity-link">API Documentation v2.1</a>
                    </p>
                    <span class="activity-avatar">ML</span>
                </div>
                <div class="activity-meta">
                    <span class="activity-time">32 minutes ago</span>
                    <span class="activity-type">Document</span>
                </div>
                <p class="activity-description">Updated endpoints and added code examples.</p>
            </div>
        </div>

        <!-- Activity Item 3 -->
        <div class="activity-item">
            <div class="activity-icon lifecycle">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
            </div>
            <div class="activity-content">
                <div class="activity-header">
                    <p class="activity-text">
                        <strong>John Doe</strong> moved product to <a href="#" class="activity-link">Testing phase</a>
                    </p>
                    <span class="activity-avatar">JD</span>
                </div>
                <div class="activity-meta">
                    <span class="activity-time">1 hour ago</span>
                    <span class="activity-type">Product Lifecycle</span>
                </div>
                <p class="activity-description">API Gateway Service is now ready for QA testing.</p>
                <div class="activity-comments">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                    </svg>
                    <span>2 comments</span>
                </div>
            </div>
        </div>

        <!-- Activity Item 4 -->
        <div class="activity-item">
            <div class="activity-icon project">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                </svg>
            </div>
            <div class="activity-content">
                <div class="activity-header">
                    <p class="activity-text">
                        <strong>Anna Wilson</strong> created project <a href="#" class="activity-link">Mobile App Analytics</a>
                    </p>
                    <span class="activity-avatar">AW</span>
                </div>
                <div class="activity-meta">
                    <span class="activity-time">2 hours ago</span>
                    <span class="activity-type">Project</span>
                </div>
            </div>
        </div>

        <!-- Activity Item 5 -->
        <div class="activity-item">
            <div class="activity-icon comment">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                </svg>
            </div>
            <div class="activity-content">
                <div class="activity-header">
                    <p class="activity-text">
                        <strong>Robert Chen</strong> commented on <a href="#" class="activity-link">Customer Portal Redesign</a>
                    </p>
                    <span class="activity-avatar">RC</span>
                </div>
                <div class="activity-meta">
                    <span class="activity-time">3 hours ago</span>
                    <span class="activity-type">Project</span>
                </div>
                <p class="activity-description">Need to discuss the authentication flow changes in tomorrow's standup.</p>
            </div>
        </div>

        <!-- Activity Item 6 -->
        <div class="activity-item">
            <div class="activity-icon task">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 11l3 3L22 4"></path>
                    <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                </svg>
            </div>
            <div class="activity-content">
                <div class="activity-header">
                    <p class="activity-text">
                        <strong>Lisa Moore</strong> created task <a href="#" class="activity-link">Design mobile navigation components</a>
                    </p>
                    <span class="activity-avatar">LM</span>
                </div>
                <div class="activity-meta">
                    <span class="activity-time">4 hours ago</span>
                    <span class="activity-type">Task</span>
                </div>
            </div>
        </div>

        <!-- Activity Item 7 -->
        <div class="activity-item">
            <div class="activity-icon team">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="8.5" cy="7" r="4"></circle>
                    <line x1="20" y1="8" x2="20" y2="14"></line>
                    <line x1="23" y1="11" x2="17" y2="11"></line>
                </svg>
            </div>
            <div class="activity-content">
                <div class="activity-header">
                    <p class="activity-text">
                        <strong>John Doe</strong> added member to <a href="#" class="activity-link">E-commerce Platform Migration</a>
                    </p>
                    <span class="activity-avatar">JD</span>
                </div>
                <div class="activity-meta">
                    <span class="activity-time">5 hours ago</span>
                    <span class="activity-type">Team</span>
                </div>
            </div>
        </div>

        <!-- Date Header - Previous Day -->
        <div class="timeline-date">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            <span>Feb 04, 2026</span>
        </div>

        <!-- Activity Item 8 -->
        <div class="activity-item">
            <div class="activity-icon completed">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
            </div>
            <div class="activity-content">
                <div class="activity-header">
                    <p class="activity-text">
                        <strong>Alex Nguyen</strong> completed task <a href="#" class="activity-link">Set up staging environment</a>
                    </p>
                    <span class="activity-avatar">AN</span>
                </div>
                <div class="activity-meta">
                    <span class="activity-time">Yesterday at 6:45 PM</span>
                    <span class="activity-type">Task</span>
                </div>
            </div>
        </div>

        <!-- Activity Item 9 -->
        <div class="activity-item">
            <div class="activity-icon lifecycle">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
            </div>
            <div class="activity-content">
                <div class="activity-header">
                    <p class="activity-text">
                        <strong>Michael Kim</strong> moved product to <a href="#" class="activity-link">Development phase</a>
                    </p>
                    <span class="activity-avatar">MK</span>
                </div>
                <div class="activity-meta">
                    <span class="activity-time">Yesterday at 3:20 PM</span>
                    <span class="activity-type">Product Lifecycle</span>
                </div>
            </div>
        </div>

        <!-- Activity Item 10 -->
        <div class="activity-item">
            <div class="activity-icon upload">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="17 8 12 3 7 8"></polyline>
                    <line x1="12" y1="3" x2="12" y2="15"></line>
                </svg>
            </div>
            <div class="activity-content">
                <div class="activity-header">
                    <p class="activity-text">
                        <strong>Robert Wilson</strong> uploaded document <a href="#" class="activity-link">Analytics Dashboard User Guide</a>
                    </p>
                    <span class="activity-avatar">RW</span>
                </div>
                <div class="activity-meta">
                    <span class="activity-time">Yesterday at 11:00 AM</span>
                    <span class="activity-type">Document</span>
                </div>
            </div>
        </div>

        <!-- Load More -->
        <div class="load-more">
            <button class="btn btn-secondary">Load More Activity</button>
        </div>
    </div>
</div>
