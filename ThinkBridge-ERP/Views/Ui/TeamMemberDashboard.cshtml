@{
    ViewData["Title"] = "My Dashboard";
    ViewData["UserRole"] = "teammember";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/teammember.css" asp-append-version="true" />
}

<div class="page-dashboard tm-dashboard">
    <!-- Welcome Section -->
    <section class="welcome-section">
        <h1 class="welcome-title">Welcome back!</h1>
        <p class="welcome-subtitle">Here's what you have on your plate today.</p>
    </section>

    <!-- KPI Cards Section -->
    <section class="kpi-section">
        <div class="kpi-card">
            <div class="kpi-content">
                <span class="kpi-label">My Tasks</span>
                <span class="kpi-value">12</span>
                <span class="kpi-change warning">4 due this week</span>
            </div>
            <div class="kpi-icon blue">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 11l3 3L22 4"></path>
                    <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                </svg>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-content">
                <span class="kpi-label">Completed</span>
                <span class="kpi-value">28</span>
                <span class="kpi-change positive">This month</span>
            </div>
            <div class="kpi-icon green">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-content">
                <span class="kpi-label">Active Projects</span>
                <span class="kpi-value">3</span>
                <span class="kpi-change neutral">Assigned to you</span>
            </div>
            <div class="kpi-icon purple">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                </svg>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-content">
                <span class="kpi-label">On-Time Rate</span>
                <span class="kpi-value">92%</span>
                <span class="kpi-change positive">+3% vs last month</span>
            </div>
            <div class="kpi-icon orange">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
            </div>
        </div>
    </section>

    <!-- Main Content Grid -->
    <div class="dashboard-grid">
        <!-- Today's Tasks -->
        <section class="dashboard-section todays-tasks">
            <div class="section-header">
                <h2 class="section-title">Today's Tasks</h2>
                <a href="@Url.Action("MyTasks", "Ui", new { role = "teammember" })" class="view-all-link">
                    View all
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </a>
            </div>
            <div class="tasks-list">
                <div class="task-item priority-high">
                    <div class="task-checkbox">
                        <input type="checkbox" id="task1" />
                        <label for="task1"></label>
                    </div>
                    <div class="task-content">
                        <span class="task-name">Complete user authentication flow</span>
                        <div class="task-meta">
                            <span class="task-project">Customer Portal Redesign</span>
                            <span class="priority-tag high">High Priority</span>
                        </div>
                    </div>
                    <div class="task-actions">
                        <button class="btn-icon" title="Update Status">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                        </button>
                    </div>
                </div>
                <div class="task-item priority-medium">
                    <div class="task-checkbox">
                        <input type="checkbox" id="task2" />
                        <label for="task2"></label>
                    </div>
                    <div class="task-content">
                        <span class="task-name">Review pull request #234</span>
                        <div class="task-meta">
                            <span class="task-project">API Gateway v2.0</span>
                            <span class="priority-tag medium">Medium</span>
                        </div>
                    </div>
                    <div class="task-actions">
                        <button class="btn-icon" title="Update Status">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                        </button>
                    </div>
                </div>
                <div class="task-item priority-low completed">
                    <div class="task-checkbox">
                        <input type="checkbox" id="task3" checked />
                        <label for="task3"></label>
                    </div>
                    <div class="task-content">
                        <span class="task-name">Update project documentation</span>
                        <div class="task-meta">
                            <span class="task-project">Customer Portal Redesign</span>
                            <span class="priority-tag low">Low</span>
                        </div>
                    </div>
                    <div class="task-status">
                        <span class="status-badge completed">Completed</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- My Projects -->
        <section class="dashboard-section my-projects">
            <div class="section-header">
                <h2 class="section-title">My Projects</h2>
            </div>
            <div class="projects-compact-list">
                <div class="project-compact-card">
                    <div class="project-info">
                        <h3 class="project-name">Customer Portal Redesign</h3>
                        <span class="project-role">Frontend Developer</span>
                    </div>
                    <div class="project-stats">
                        <div class="stat">
                            <span class="stat-value">5</span>
                            <span class="stat-label">Tasks</span>
                        </div>
                        <div class="stat">
                            <span class="stat-value">65%</span>
                            <span class="stat-label">Progress</span>
                        </div>
                    </div>
                    <div class="project-progress-mini">
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: 65%"></div>
                        </div>
                    </div>
                </div>
                <div class="project-compact-card">
                    <div class="project-info">
                        <h3 class="project-name">API Gateway v2.0</h3>
                        <span class="project-role">Backend Developer</span>
                    </div>
                    <div class="project-stats">
                        <div class="stat">
                            <span class="stat-value">4</span>
                            <span class="stat-label">Tasks</span>
                        </div>
                        <div class="stat">
                            <span class="stat-value">90%</span>
                            <span class="stat-label">Progress</span>
                        </div>
                    </div>
                    <div class="project-progress-mini">
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: 90%"></div>
                        </div>
                    </div>
                </div>
                <div class="project-compact-card">
                    <div class="project-info">
                        <h3 class="project-name">Mobile App Analytics</h3>
                        <span class="project-role">Full Stack Developer</span>
                    </div>
                    <div class="project-stats">
                        <div class="stat">
                            <span class="stat-value">3</span>
                            <span class="stat-label">Tasks</span>
                        </div>
                        <div class="stat">
                            <span class="stat-value">45%</span>
                            <span class="stat-label">Progress</span>
                        </div>
                    </div>
                    <div class="project-progress-mini">
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: 45%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Recent Documents -->
        <section class="dashboard-section recent-documents">
            <div class="section-header">
                <h2 class="section-title">Recent Documents</h2>
                <a href="@Url.Action("Documents", "Ui", new { role = "teammember" })" class="view-all-link">
                    View all
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </a>
            </div>
            <div class="documents-list">
                <div class="document-item">
                    <div class="document-icon figma">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2">
                            <path d="M5 5.5A3.5 3.5 0 0 1 8.5 2H12v7H8.5A3.5 3.5 0 0 1 5 5.5z"></path>
                            <path d="M12 2h3.5a3.5 3.5 0 1 1 0 7H12V2z"></path>
                            <path d="M12 12.5a3.5 3.5 0 1 1 7 0 3.5 3.5 0 1 1-7 0z"></path>
                            <path d="M5 19.5A3.5 3.5 0 0 1 8.5 16H12v3.5a3.5 3.5 0 1 1-7 0z"></path>
                            <path d="M5 12.5A3.5 3.5 0 0 1 8.5 9H12v7H8.5A3.5 3.5 0 0 1 5 12.5z"></path>
                        </svg>
                    </div>
                    <div class="document-info">
                        <span class="document-name">Dashboard_Design_v3.fig</span>
                        <span class="document-meta">Uploaded 2 hours ago • 4.2 MB</span>
                    </div>
                </div>
                <div class="document-item">
                    <div class="document-icon pdf">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                        </svg>
                    </div>
                    <div class="document-info">
                        <span class="document-name">API_Documentation.pdf</span>
                        <span class="document-meta">Uploaded yesterday • 1.8 MB</span>
                    </div>
                </div>
                <div class="document-item">
                    <div class="document-icon code">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2">
                            <polyline points="16 18 22 12 16 6"></polyline>
                            <polyline points="8 6 2 12 8 18"></polyline>
                        </svg>
                    </div>
                    <div class="document-info">
                        <span class="document-name">auth-module.ts</span>
                        <span class="document-meta">Modified 3 hours ago • 24 KB</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Team Collaboration -->
        <section class="dashboard-section team-collaboration">
            <div class="section-header">
                <h2 class="section-title">Team Activity</h2>
            </div>
            <div class="activity-list">
                <div class="activity-item">
                    <div class="activity-avatar">
                        <span>SK</span>
                    </div>
                    <div class="activity-content">
                        <span class="activity-text"><strong>Sarah Kim</strong> commented on your task "Authentication
                            flow"</span>
                            <span class="activity-time">15 min ago</span>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="activity-avatar">
                            <span>PM</span>
                        </div>
                        <div class="activity-content">
                            <span class="activity-text"><strong>Project Manager</strong> assigned you a new task</span>
                            <span class="activity-time">1 hour ago</span>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="activity-avatar">
                            <span>MK</span>
                        </div>
                        <div class="activity-content">
                            <span class="activity-text"><strong>Mike Kennedy</strong> approved your pull request</span>
                            <span class="activity-time">2 hours ago</span>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="activity-avatar">
                            <span>LM</span>
                        </div>
                        <div class="activity-content">
                            <span class="activity-text"><strong>Lisa Martinez</strong> shared
                                "Dashboard_Design_v3.fig"</span>
                                <span class="activity-time">3 hours ago</span>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>