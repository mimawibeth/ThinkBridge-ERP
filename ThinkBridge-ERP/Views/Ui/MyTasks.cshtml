@{
    ViewData["Title"] = "My Tasks";
    ViewData["UserRole"] = "teammember";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/teammember.css" asp-append-version="true" />
}

<div class="page-mytasks">
    <!-- Page Header -->
    <section class="page-header">
        <div class="header-content">
            <h1 class="page-title">My Tasks</h1>
            <p class="page-subtitle">Track and manage your assigned tasks</p>
        </div>
    </section>

    <!-- Task Stats -->
    <section class="task-stats">
        <div class="stat-pill">
            <span class="stat-count">12</span>
            <span class="stat-label">Total</span>
        </div>
        <div class="stat-pill in-progress">
            <span class="stat-count">5</span>
            <span class="stat-label">In Progress</span>
        </div>
        <div class="stat-pill completed">
            <span class="stat-count">4</span>
            <span class="stat-label">Completed</span>
        </div>
        <div class="stat-pill overdue">
            <span class="stat-count">2</span>
            <span class="stat-label">Overdue</span>
        </div>
    </section>

    <!-- Filters -->
    <section class="filters-section">
        <div class="filter-tabs">
            <button class="filter-tab active">All Tasks</button>
            <button class="filter-tab">To Do</button>
            <button class="filter-tab">In Progress</button>
            <button class="filter-tab">Completed</button>
        </div>
        <div class="filter-group">
            <select class="filter-select">
                <option value="">All Projects</option>
                <option value="prj-001">Customer Portal</option>
                <option value="prj-002">API Gateway</option>
                <option value="prj-003">Mobile Analytics</option>
            </select>
            <select class="filter-select">
                <option value="">All Priority</option>
                <option value="high">High</option>
                <option value="medium">Medium</option>
                <option value="low">Low</option>
            </select>
        </div>
    </section>

    <!-- Tasks List -->
    <section class="tasks-section">
        <!-- Overdue Tasks -->
        <div class="task-group">
            <h3 class="group-title overdue">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="8" x2="12" y2="12"></line>
                    <line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
                Overdue (2)
            </h3>
            <div class="task-cards">
                <div class="task-card overdue">
                    <div class="task-header">
                        <span class="task-id">TASK-045</span>
                        <span class="priority-badge high">High</span>
                    </div>
                    <h4 class="task-title">Fix database migration errors</h4>
                    <p class="task-description">Resolve the migration script errors causing data inconsistency in the
                        staging environment.</p>
                        <div class="task-meta">
                            <span class="task-project">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2">
                                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z">
                                    </path>
                                </svg>
                                Data Migration Tool
                            </span>
                            <span class="task-due overdue">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                </svg>
                                Due Feb 5, 2026
                            </span>
                        </div>
                        <div class="task-actions">
                            <select class="status-select">
                                <option value="in-progress" selected>In Progress</option>
                                <option value="review">In Review</option>
                                <option value="completed">Completed</option>
                            </select>
                            <button class="btn-small">View Details</button>
                        </div>
                    </div>
                    <div class="task-card overdue">
                        <div class="task-header">
                            <span class="task-id">TASK-042</span>
                            <span class="priority-badge medium">Medium</span>
                        </div>
                        <h4 class="task-title">Update error handling module</h4>
                        <p class="task-description">Implement centralized error handling for better debugging and user
                            experience.</p>
                            <div class="task-meta">
                                <span class="task-project">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                         stroke-width="2">
                                        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z">
                                        </path>
                                    </svg>
                                    API Gateway v2.0
                                </span>
                                <span class="task-due overdue">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                         stroke-width="2">
                                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                        <line x1="16" y1="2" x2="16" y2="6"></line>
                                        <line x1="8" y1="2" x2="8" y2="6"></line>
                                        <line x1="3" y1="10" x2="21" y2="10"></line>
                                    </svg>
                                    Due Feb 7, 2026
                                </span>
                            </div>
                            <div class="task-actions">
                                <select class="status-select">
                                    <option value="todo">To Do</option>
                                    <option value="in-progress" selected>In Progress</option>
                                    <option value="review">In Review</option>
                                    <option value="completed">Completed</option>
                                </select>
                                <button class="btn-small">View Details</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Due This Week -->
                <div class="task-group">
                    <h3 class="group-title due-soon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <polyline points="12 6 12 12 16 14"></polyline>
                        </svg>
                        Due This Week (3)
                    </h3>
                    <div class="task-cards">
                        <div class="task-card">
                            <div class="task-header">
                                <span class="task-id">TASK-051</span>
                                <span class="priority-badge high">High</span>
                            </div>
                            <h4 class="task-title">Complete user authentication flow</h4>
                            <p class="task-description">Implement OAuth2.0 authentication with JWT tokens for secure user
                                sessions.</p>
                                <div class="task-meta">
                                    <span class="task-project">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                             stroke-width="2">
                                            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z">
                                            </path>
                                        </svg>
                                        Customer Portal Redesign
                                    </span>
                                    <span class="task-due">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                             stroke-width="2">
                                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                            <line x1="16" y1="2" x2="16" y2="6"></line>
                                            <line x1="8" y1="2" x2="8" y2="6"></line>
                                            <line x1="3" y1="10" x2="21" y2="10"></line>
                                        </svg>
                                        Due Feb 12, 2026
                                    </span>
                                </div>
                                <div class="task-actions">
                                    <select class="status-select">
                                        <option value="in-progress" selected>In Progress</option>
                                        <option value="review">In Review</option>
                                        <option value="completed">Completed</option>
                                    </select>
                                    <button class="btn-small">View Details</button>
                                </div>
                            </div>
                            <div class="task-card">
                                <div class="task-header">
                                    <span class="task-id">TASK-052</span>
                                    <span class="priority-badge medium">Medium</span>
                                </div>
                                <h4 class="task-title">Review pull request #234</h4>
                                <p class="task-description">Code review for the new API endpoints implementation.</p>
                                <div class="task-meta">
                                    <span class="task-project">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                             stroke-width="2">
                                            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z">
                                            </path>
                                        </svg>
                                        API Gateway v2.0
                                    </span>
                                    <span class="task-due">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                             stroke-width="2">
                                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                            <line x1="16" y1="2" x2="16" y2="6"></line>
                                            <line x1="8" y1="2" x2="8" y2="6"></line>
                                            <line x1="3" y1="10" x2="21" y2="10"></line>
                                        </svg>
                                        Due Feb 13, 2026
                                    </span>
                                </div>
                                <div class="task-actions">
                                    <select class="status-select">
                                        <option value="todo" selected>To Do</option>
                                        <option value="in-progress">In Progress</option>
                                        <option value="review">In Review</option>
                                        <option value="completed">Completed</option>
                                    </select>
                                    <button class="btn-small">View Details</button>
                                </div>
                            </div>
                            <div class="task-card">
                                <div class="task-header">
                                    <span class="task-id">TASK-053</span>
                                    <span class="priority-badge low">Low</span>
                                </div>
                                <h4 class="task-title">Update project documentation</h4>
                                <p class="task-description">Document the new authentication module and update API references.</p>
                                <div class="task-meta">
                                    <span class="task-project">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                             stroke-width="2">
                                            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z">
                                            </path>
                                        </svg>
                                        Customer Portal Redesign
                                    </span>
                                    <span class="task-due">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                             stroke-width="2">
                                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                            <line x1="16" y1="2" x2="16" y2="6"></line>
                                            <line x1="8" y1="2" x2="8" y2="6"></line>
                                            <line x1="3" y1="10" x2="21" y2="10"></line>
                                        </svg>
                                        Due Feb 14, 2026
                                    </span>
                                </div>
                                <div class="task-actions">
                                    <select class="status-select">
                                        <option value="todo" selected>To Do</option>
                                        <option value="in-progress">In Progress</option>
                                        <option value="review">In Review</option>
                                        <option value="completed">Completed</option>
                                    </select>
                                    <button class="btn-small">View Details</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Completed Tasks -->
                    <div class="task-group">
                        <h3 class="group-title completed">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                <polyline points="22 4 12 14.01 9 11.01"></polyline>
                            </svg>
                            Completed Recently (4)
                        </h3>
                        <div class="task-cards completed-tasks">
                            <div class="task-card completed">
                                <div class="task-header">
                                    <span class="task-id">TASK-048</span>
                                    <span class="status-badge completed">Completed</span>
                                </div>
                                <h4 class="task-title">Implement login UI components</h4>
                                <div class="task-meta">
                                    <span class="task-project">Customer Portal Redesign</span>
                                    <span class="completed-date">Completed Feb 8, 2026</span>
                                </div>
                            </div>
                            <div class="task-card completed">
                                <div class="task-header">
                                    <span class="task-id">TASK-046</span>
                                    <span class="status-badge completed">Completed</span>
                                </div>
                                <h4 class="task-title">Set up CI/CD pipeline</h4>
                                <div class="task-meta">
                                    <span class="task-project">API Gateway v2.0</span>
                                    <span class="completed-date">Completed Feb 6, 2026</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>