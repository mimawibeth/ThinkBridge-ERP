@{
    ViewData["Title"] = "Dashboard";
    ViewData["UserRole"] = "superadmin";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/superadmin.css" asp-append-version="true" />
}

<div class="page-dashboard superadmin-dashboard">
    <!-- Welcome Section -->
    <section class="welcome-section">
        <h1 class="welcome-title">Welcome, Maribeth!</h1>
        <p class="welcome-subtitle">Platform overview and company management</p>
    </section>

    <!-- KPI Cards Section -->
    <section class="kpi-section">
        <div class="kpi-card">
            <div class="kpi-content">
                <span class="kpi-label">Total Companies</span>
                <span class="kpi-value">45</span>
                <span class="kpi-change positive">+5 this month</span>
            </div>
            <div class="kpi-icon blue">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 21h18"></path>
                    <path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"></path>
                </svg>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-content">
                <span class="kpi-label">Active Subscriptions</span>
                <span class="kpi-value">38</span>
                <span class="kpi-change positive">84% active</span>
            </div>
            <div class="kpi-icon green">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-content">
                <span class="kpi-label">Pending Payments</span>
                <span class="kpi-value">7</span>
                <span class="kpi-change warning">$12,450 due</span>
            </div>
            <div class="kpi-icon orange">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                    <line x1="1" y1="10" x2="23" y2="10"></line>
                </svg>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-content">
                <span class="kpi-label">Monthly Revenue</span>
                <span class="kpi-value">$48.5K</span>
                <span class="kpi-change positive">+12% vs last month</span>
            </div>
            <div class="kpi-icon purple">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="1" x2="12" y2="23"></line>
                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                </svg>
            </div>
        </div>
    </section>

    <!-- Main Content Grid -->
    <div class="dashboard-grid">
        <!-- Recent Companies Section -->
        <section class="dashboard-section recent-companies">
            <div class="section-header">
                <h2 class="section-title">Recent Companies</h2>
                <a href="@Url.Action("Companies", "Ui", new { role = "superadmin" })" class="view-all-link">
                    View all
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </a>
            </div>
            <div class="companies-list">
                <div class="company-card">
                    <div class="company-header">
                        <div class="company-logo">
                            <span>TC</span>
                        </div>
                        <div class="company-info">
                            <h3 class="company-name">TechCorp Solutions</h3>
                            <span class="company-industry">Technology</span>
                        </div>
                        <span class="badge badge-active">Active</span>
                    </div>
                    <div class="company-details">
                        <div class="detail-item">
                            <span class="detail-label">Plan</span>
                            <span class="detail-value">Enterprise</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Users</span>
                            <span class="detail-value">156</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Since</span>
                            <span class="detail-value">Jan 2024</span>
                        </div>
                    </div>
                </div>
                <div class="company-card">
                    <div class="company-header">
                        <div class="company-logo">
                            <span>GF</span>
                        </div>
                        <div class="company-info">
                            <h3 class="company-name">GlobalFinance Inc</h3>
                            <span class="company-industry">Finance</span>
                        </div>
                        <span class="badge badge-active">Active</span>
                    </div>
                    <div class="company-details">
                        <div class="detail-item">
                            <span class="detail-label">Plan</span>
                            <span class="detail-value">Professional</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Users</span>
                            <span class="detail-value">82</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Since</span>
                            <span class="detail-value">Mar 2024</span>
                        </div>
                    </div>
                </div>
                <div class="company-card">
                    <div class="company-header">
                        <div class="company-logo">
                            <span>HL</span>
                        </div>
                        <div class="company-info">
                            <h3 class="company-name">HealthLink Medical</h3>
                            <span class="company-industry">Healthcare</span>
                        </div>
                        <span class="badge badge-pending">Pending Payment</span>
                    </div>
                    <div class="company-details">
                        <div class="detail-item">
                            <span class="detail-label">Plan</span>
                            <span class="detail-value">Enterprise</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Users</span>
                            <span class="detail-value">203</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Since</span>
                            <span class="detail-value">Nov 2023</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Payment Status Section -->
        <section class="dashboard-section payment-status">
            <div class="section-header">
                <h2 class="section-title">Payment Status</h2>
                <a href="@Url.Action("Payments", "Ui", new { role = "superadmin" })" class="view-all-link">
                    View all
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </a>
            </div>
            <div class="payments-list">
                <div class="payment-item">
                    <div class="payment-company">
                        <span class="company-avatar">HL</span>
                        <div class="payment-info">
                            <span class="company-name">HealthLink Medical</span>
                            <span class="payment-date">Due: Feb 15, 2026</span>
                        </div>
                    </div>
                    <div class="payment-amount overdue">$2,450</div>
                </div>
                <div class="payment-item">
                    <div class="payment-company">
                        <span class="company-avatar">RS</span>
                        <div class="payment-info">
                            <span class="company-name">RetailSmart Ltd</span>
                            <span class="payment-date">Due: Feb 20, 2026</span>
                        </div>
                    </div>
                    <div class="payment-amount pending">$1,800</div>
                </div>
                <div class="payment-item">
                    <div class="payment-company">
                        <span class="company-avatar">EG</span>
                        <div class="payment-info">
                            <span class="company-name">EduGlobal Academy</span>
                            <span class="payment-date">Due: Feb 28, 2026</span>
                        </div>
                    </div>
                    <div class="payment-amount pending">$950</div>
                </div>
                <div class="payment-item">
                    <div class="payment-company">
                        <span class="company-avatar">TC</span>
                        <div class="payment-info">
                            <span class="company-name">TechCorp Solutions</span>
                            <span class="payment-date">Paid: Feb 1, 2026</span>
                        </div>
                    </div>
                    <div class="payment-amount paid">$3,500</div>
                </div>
            </div>
        </section>

        <!-- Subscription Overview -->
        <section class="dashboard-section subscription-overview">
            <div class="section-header">
                <h2 class="section-title">Subscription Overview</h2>
            </div>
            <div class="subscription-stats">
                <div class="stat-item">
                    <div class="stat-bar enterprise">
                        <div class="bar-fill" style="width: 45%"></div>
                    </div>
                    <div class="stat-info">
                        <span class="stat-label">Enterprise</span>
                        <span class="stat-value">18 companies</span>
                    </div>
                </div>
                <div class="stat-item">
                    <div class="stat-bar professional">
                        <div class="bar-fill" style="width: 35%"></div>
                    </div>
                    <div class="stat-info">
                        <span class="stat-label">Professional</span>
                        <span class="stat-value">14 companies</span>
                    </div>
                </div>
                <div class="stat-item">
                    <div class="stat-bar starter">
                        <div class="bar-fill" style="width: 20%"></div>
                    </div>
                    <div class="stat-info">
                        <span class="stat-label">Starter</span>
                        <span class="stat-value">8 companies</span>
                    </div>
                </div>
                <div class="stat-item">
                    <div class="stat-bar trial">
                        <div class="bar-fill" style="width: 12%"></div>
                    </div>
                    <div class="stat-info">
                        <span class="stat-label">Trial</span>
                        <span class="stat-value">5 companies</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Platform Activity -->
        <section class="dashboard-section platform-activity">
            <div class="section-header">
                <h2 class="section-title">Platform Activity</h2>
            </div>
            <div class="activity-list">
                <div class="activity-item">
                    <div class="activity-icon new-company">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2">
                            <path d="M3 21h18"></path>
                            <path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"></path>
                        </svg>
                    </div>
                    <div class="activity-content">
                        <span class="activity-text"><strong>InnovateTech Co</strong> registered as new company</span>
                        <span class="activity-time">2 hours ago</span>
                    </div>
                </div>
                <div class="activity-item">
                    <div class="activity-icon payment">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2">
                            <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                            <line x1="1" y1="10" x2="23" y2="10"></line>
                        </svg>
                    </div>
                    <div class="activity-content">
                        <span class="activity-text"><strong>TechCorp Solutions</strong> completed payment</span>
                        <span class="activity-time">5 hours ago</span>
                    </div>
                </div>
                <div class="activity-item">
                    <div class="activity-icon upgrade">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2">
                            <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
                            <polyline points="17 6 23 6 23 12"></polyline>
                        </svg>
                    </div>
                    <div class="activity-content">
                        <span class="activity-text"><strong>GlobalFinance Inc</strong> upgraded to Professional</span>
                        <span class="activity-time">Yesterday</span>
                    </div>
                </div>
                <div class="activity-item">
                    <div class="activity-icon deactivate">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line>
                        </svg>
                    </div>
                    <div class="activity-content">
                        <span class="activity-text"><strong>OldCorp Ltd</strong> account deactivated</span>
                        <span class="activity-time">2 days ago</span>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>