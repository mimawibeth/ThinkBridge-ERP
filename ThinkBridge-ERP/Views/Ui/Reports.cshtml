@{
    ViewData["Title"] = "Reports";
    ViewData["UserRole"] = "projectmanager";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/projectmanager.css" asp-append-version="true" />
}

<div class="page-reports">
    <!-- Page Header -->
    <section class="page-header">
        <div class="header-content">
            <h1 class="page-title">Reports</h1>
            <p class="page-subtitle">Project performance and team analytics</p>
        </div>
        <div class="header-actions">
            <select class="filter-select">
                <option value="week">This Week</option>
                <option value="month" selected>This Month</option>
                <option value="quarter">This Quarter</option>
                <option value="year">This Year</option>
            </select>
            <button class="btn btn-outline">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                Export
            </button>
        </div>
    </section>

    <!-- Report Cards -->
    <section class="report-cards">
        <div class="report-card">
            <div class="report-header">
                <h3>Tasks Completed</h3>
                <span class="trend positive">+18%</span>
            </div>
            <div class="report-value">127</div>
            <div class="report-chart mini-chart">
                <div class="chart-bar" style="height: 40%"></div>
                <div class="chart-bar" style="height: 55%"></div>
                <div class="chart-bar" style="height: 45%"></div>
                <div class="chart-bar" style="height: 70%"></div>
                <div class="chart-bar" style="height: 65%"></div>
                <div class="chart-bar" style="height: 80%"></div>
                <div class="chart-bar current" style="height: 90%"></div>
            </div>
        </div>
        <div class="report-card">
            <div class="report-header">
                <h3>On-Time Delivery</h3>
                <span class="trend positive">+5%</span>
            </div>
            <div class="report-value">84%</div>
            <div class="circular-progress" style="--progress: 84">
                <svg viewBox="0 0 36 36">
                    <path class="bg"
                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                    <path class="progress" stroke-dasharray="84, 100"
                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                </svg>
            </div>
        </div>
        <div class="report-card">
            <div class="report-header">
                <h3>Team Utilization</h3>
                <span class="trend neutral">0%</span>
            </div>
            <div class="report-value">76%</div>
            <div class="circular-progress" style="--progress: 76">
                <svg viewBox="0 0 36 36">
                    <path class="bg"
                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                    <path class="progress blue" stroke-dasharray="76, 100"
                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                </svg>
            </div>
        </div>
        <div class="report-card">
            <div class="report-header">
                <h3>Blockers Resolved</h3>
                <span class="trend positive">+25%</span>
            </div>
            <div class="report-value">15</div>
            <div class="report-subtext">out of 18 total</div>
        </div>
    </section>

    <!-- Charts Grid -->
    <div class="charts-grid">
        <!-- Project Progress Chart -->
        <section class="chart-section">
            <div class="section-header">
                <h2 class="section-title">Project Progress</h2>
            </div>
            <div class="chart-container">
                <div class="project-bars">
                    <div class="project-bar-item">
                        <span class="project-label">Customer Portal</span>
                        <div class="bar-wrapper">
                            <div class="bar completed" style="width: 65%"></div>
                            <span class="bar-value">65%</span>
                        </div>
                    </div>
                    <div class="project-bar-item">
                        <span class="project-label">API Gateway v2.0</span>
                        <div class="bar-wrapper">
                            <div class="bar completed" style="width: 90%"></div>
                            <span class="bar-value">90%</span>
                        </div>
                    </div>
                    <div class="project-bar-item">
                        <span class="project-label">Mobile App Analytics</span>
                        <div class="bar-wrapper">
                            <div class="bar in-progress" style="width: 45%"></div>
                            <span class="bar-value">45%</span>
                        </div>
                    </div>
                    <div class="project-bar-item at-risk">
                        <span class="project-label">Data Migration Tool</span>
                        <div class="bar-wrapper">
                            <div class="bar at-risk" style="width: 35%"></div>
                            <span class="bar-value">35%</span>
                        </div>
                    </div>
                    <div class="project-bar-item">
                        <span class="project-label">Inventory System</span>
                        <div class="bar-wrapper">
                            <div class="bar completed" style="width: 80%"></div>
                            <span class="bar-value">80%</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Task Distribution -->
        <section class="chart-section">
            <div class="section-header">
                <h2 class="section-title">Task Distribution</h2>
            </div>
            <div class="chart-container">
                <div class="task-distribution">
                    <div class="distribution-item">
                        <div class="distribution-color completed"></div>
                        <span class="distribution-label">Completed</span>
                        <span class="distribution-value">127</span>
                        <span class="distribution-percent">54%</span>
                    </div>
                    <div class="distribution-item">
                        <div class="distribution-color in-progress"></div>
                        <span class="distribution-label">In Progress</span>
                        <span class="distribution-value">47</span>
                        <span class="distribution-percent">20%</span>
                    </div>
                    <div class="distribution-item">
                        <div class="distribution-color review"></div>
                        <span class="distribution-label">In Review</span>
                        <span class="distribution-value">32</span>
                        <span class="distribution-percent">14%</span>
                    </div>
                    <div class="distribution-item">
                        <div class="distribution-color not-started"></div>
                        <span class="distribution-label">Not Started</span>
                        <span class="distribution-value">28</span>
                        <span class="distribution-percent">12%</span>
                    </div>
                </div>
                <div class="stacked-bar">
                    <div class="bar-segment completed" style="width: 54%"></div>
                    <div class="bar-segment in-progress" style="width: 20%"></div>
                    <div class="bar-segment review" style="width: 14%"></div>
                    <div class="bar-segment not-started" style="width: 12%"></div>
                </div>
            </div>
        </section>

        <!-- Team Performance -->
        <section class="chart-section wide">
            <div class="section-header">
                <h2 class="section-title">Team Performance</h2>
            </div>
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Team Member</th>
                            <th>Tasks Assigned</th>
                            <th>Completed</th>
                            <th>Completion Rate</th>
                            <th>On-Time %</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>
                                <div class="member-cell">
                                    <span class="member-avatar">SK</span>
                                    <span class="member-name">Sarah Kim</span>
                                </div>
                            </td>
                            <td>24</td>
                            <td>22</td>
                            <td>
                                <div class="mini-progress">
                                    <div class="progress-fill" style="width: 92%"></div>
                                </div>
                                <span>92%</span>
                            </td>
                            <td>95%</td>
                            <td><span class="status-badge excellent">Excellent</span></td>
                        </tr>
                        <tr>
                            <td>
                                <div class="member-cell">
                                    <span class="member-avatar">MK</span>
                                    <span class="member-name">Mike Kennedy</span>
                                </div>
                            </td>
                            <td>28</td>
                            <td>23</td>
                            <td>
                                <div class="mini-progress">
                                    <div class="progress-fill" style="width: 82%"></div>
                                </div>
                                <span>82%</span>
                            </td>
                            <td>78%</td>
                            <td><span class="status-badge good">Good</span></td>
                        </tr>
                        <tr>
                            <td>
                                <div class="member-cell">
                                    <span class="member-avatar">LM</span>
                                    <span class="member-name">Lisa Martinez</span>
                                </div>
                            </td>
                            <td>18</td>
                            <td>17</td>
                            <td>
                                <div class="mini-progress">
                                    <div class="progress-fill" style="width: 94%"></div>
                                </div>
                                <span>94%</span>
                            </td>
                            <td>100%</td>
                            <td><span class="status-badge excellent">Excellent</span></td>
                        </tr>
                        <tr>
                            <td>
                                <div class="member-cell">
                                    <span class="member-avatar">RB</span>
                                    <span class="member-name">Robert Brown</span>
                                </div>
                            </td>
                            <td>21</td>
                            <td>16</td>
                            <td>
                                <div class="mini-progress">
                                    <div class="progress-fill warning" style="width: 76%"></div>
                                </div>
                                <span>76%</span>
                            </td>
                            <td>70%</td>
                            <td><span class="status-badge needs-attention">Needs Attention</span></td>
                        </tr>
                        <tr>
                            <td>
                                <div class="member-cell">
                                    <span class="member-avatar">AN</span>
                                    <span class="member-name">Alex Nguyen</span>
                                </div>
                            </td>
                            <td>20</td>
                            <td>18</td>
                            <td>
                                <div class="mini-progress">
                                    <div class="progress-fill" style="width: 90%"></div>
                                </div>
                                <span>90%</span>
                            </td>
                            <td>88%</td>
                            <td><span class="status-badge good">Good</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>