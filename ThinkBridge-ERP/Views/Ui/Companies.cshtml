@{
    ViewData["Title"] = "Companies";
    ViewData["UserRole"] = "superadmin";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/superadmin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/forms.css" asp-append-version="true" />
}

<div class="page-companies">
    <!-- Page Header -->
    <section class="page-header">
        <div class="header-content">
            <h1 class="page-title">Companies</h1>
            <p class="page-subtitle">Manage client companies and their accounts</p>
        </div>
        <button class="btn btn-primary" onclick="openAddCompanyModal()">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Add Company
        </button>
    </section>

    <!-- Filters Section -->
    <section class="filters-section">
        <div class="search-box">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input type="text" placeholder="Search companies..." class="search-input" />
        </div>
        <div class="filter-group">
            <select class="filter-select">
                <option value="">All Status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
                <option value="pending">Pending</option>
            </select>
            <select class="filter-select">
                <option value="">All Plans</option>
                <option value="enterprise">Enterprise</option>
                <option value="professional">Professional</option>
                <option value="starter">Starter</option>
                <option value="trial">Trial</option>
            </select>
        </div>
    </section>

    <!-- Companies Table -->
    <section class="companies-table-section">
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Company</th>
                        <th>Industry</th>
                        <th>Plan</th>
                        <th>Users</th>
                        <th>Status</th>
                        <th>Joined</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>
                            <div class="company-cell">
                                <div class="company-avatar">TC</div>
                                <div class="company-details">
                                    <span class="company-name">TechCorp Solutions</span>
                                    <span class="company-email">admin@techcorp.com</span>
                                </div>
                            </div>
                        </td>
                        <td>Technology</td>
                        <td><span class="plan-badge enterprise">Enterprise</span></td>
                        <td>156</td>
                        <td><span class="status-badge active">Active</span></td>
