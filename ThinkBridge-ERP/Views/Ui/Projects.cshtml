<!-- New Project Modal -->
<div class="modal-overlay" id="new-project-modal">
    <div class="modal modal-lg">
        <div class="modal-header">
            <h2>Create New Project</h2>
            <button class="modal-close" id="modal-close">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body">
            <form class="project-form">
                <div class="form-group">
                    <label for="project-name">Project Name</label>
                    <input type="text" id="project-name" class="form-input" placeholder="Enter project name" />
                </div>
                <div class="form-group">
                    <label for="project-description">Description</label>
                    <textarea id="project-description" class="form-textarea" rows="3" placeholder="Enter project description"></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="start-date">Start Date</label>
                        <input type="date" id="start-date" class="form-input" />
                    </div>
                    <div class="form-group">
                        <label for="due-date">Due Date</label>
                        <input type="date" id="due-date" class="form-input" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="project-status">Status</label>
                        <select id="project-status" class="form-select">
                            <option value="planning">Planning</option>
                            <option value="in-progress">In Progress</option>
                            <option value="review">Review</option>
                            <option value="completed">Completed</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="project-category">Category</label>
                        <select id="project-category" class="form-select">
                            <option value="development">Development</option>
                            <option value="infrastructure">Infrastructure</option>
                            <option value="analytics">Analytics</option>
                            <option value="security">Security</option>
                            <option value="documentation">Documentation</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label for="team-members">Assign Team Members</label>
                    <select id="team-members" class="form-select" multiple>
                        <option value="jd">John Doe</option>
                        <option value="sk">Sarah Kim</option>
                        <option value="mk">Michael Kim</option>
                        <option value="lm">Lisa Moore</option>
                        <option value="an">Alex Nguyen</option>
                    </select>
                </div>
            </form>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" id="modal-cancel">Cancel</button>
            <button class="btn btn-primary">Create Project</button>
        </div>
    </div>
</div>

<!-- View Project Modal -->
<div class="modal-overlay" id="view-project-modal">
    <div class="modal modal-lg">
        <div class="modal-header modal-header-primary">
            <div>
                <h2>Customer Portal Redesign</h2>
                <p class="modal-subtitle">PRJ-001</p>
            </div>
            <button class="modal-close" data-modal-close>
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body">
            <div class="detail-section">
                <h4 class="detail-section-title">Project Information</h4>
                <div class="detail-grid">
                    <div class="detail-item">
                        <span class="detail-label">Status</span>
                        <span class="badge badge-in-progress">In Progress</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Category</span>
                        <span class="badge badge-category">Development</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Start Date</span>
                        <span class="detail-value">Jan 15, 2026</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Due Date</span>
                        <span class="detail-value">Feb 28, 2026</span>
                    </div>
                </div>
            </div>

            <div class="detail-section">
                <h4 class="detail-section-title">Description</h4>
                <p class="detail-description">Complete overhaul of the customer-facing portal with modern UI/UX. This includes redesigning the dashboard, implementing new navigation patterns, and improving overall user experience based on customer feedback.</p>
            </div>

            <div class="detail-section">
                <h4 class="detail-section-title">Progress</h4>
                <div class="detail-progress">
                    <div class="detail-progress-header">
                        <span class="detail-progress-label">Overall Completion</span>
                        <span class="detail-progress-value">65%</span>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: 65%"></div>
                    </div>
                </div>
            </div>

            <div class="detail-section">
                <h4 class="detail-section-title">Team Members</h4>
                <div class="detail-team">
                    <div class="detail-team-member">
                        <span class="member-avatar">JD</span>
                        <span class="member-name">John Doe</span>
                    </div>
                    <div class="detail-team-member">
                        <span class="member-avatar">SK</span>
                        <span class="member-name">Sarah Kim</span>
                    </div>
                    <div class="detail-team-member">
                        <span class="member-avatar">LM</span>
                        <span class="member-name">Lisa Moore</span>
                    </div>
                </div>
            </div>

            <div class="detail-section">
                <h4 class="detail-section-title">Recent Activity</h4>
                <div class="detail-timeline">
                    <div class="timeline-item">
                        <div class="timeline-content">
                            <span class="timeline-date">Feb 10, 2026 - 10:30 AM</span>
                            <p class="timeline-text">Sarah Kim completed task "Design homepage layout"</p>
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-content">
                            <span class="timeline-date">Feb 09, 2026 - 3:45 PM</span>
                            <p class="timeline-text">John Doe uploaded document "UI Specifications v2"</p>
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-content">
                            <span class="timeline-date">Feb 08, 2026 - 11:00 AM</span>
                            <p class="timeline-text">Project milestone "Phase 1" completed</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" data-modal-close>Close</button>
            <button class="btn btn-primary" id="edit-project-from-view">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                </svg>
                Edit Project
            </button>
        </div>
    </div>
</div>

<!-- Edit Project Modal -->
<div class="modal-overlay" id="edit-project-modal">
    <div class="modal modal-lg">
        <div class="modal-header">
            <div>
                <h2>Edit Project</h2>
                <p class="modal-subtitle">PRJ-001</p>
            </div>
            <button class="modal-close" data-modal-close>
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body">
            <form class="project-form">
                <div class="form-group">
                    <label for="edit-project-name">Project Name</label>
                    <input type="text" id="edit-project-name" class="form-input" value="Customer Portal Redesign" />
                </div>
                <div class="form-group">
                    <label for="edit-project-description">Description</label>
                    <textarea id="edit-project-description" class="form-textarea" rows="3">Complete overhaul of the customer-facing portal with modern UI/UX</textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="edit-start-date">Start Date</label>
                        <input type="date" id="edit-start-date" class="form-input" value="2026-01-15" />
                    </div>
                    <div class="form-group">
                        <label for="edit-due-date">Due Date</label>
                        <input type="date" id="edit-due-date" class="form-input" value="2026-02-28" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="edit-project-status">Status</label>
                        <select id="edit-project-status" class="form-select">
                            <option value="planning">Planning</option>
                            <option value="in-progress" selected>In Progress</option>
                            <option value="review">Review</option>
                            <option value="completed">Completed</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="edit-project-category">Category</label>
                        <select id="edit-project-category" class="form-select">
                            <option value="development" selected>Development</option>
                            <option value="infrastructure">Infrastructure</option>
                            <option value="analytics">Analytics</option>
                            <option value="security">Security</option>
                            <option value="documentation">Documentation</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label for="edit-team-members">Team Members</label>
                    <select id="edit-team-members" class="form-select" multiple>
                        <option value="jd" selected>John Doe</option>
                        <option value="sk" selected>Sarah Kim</option>
                        <option value="mk">Michael Kim</option>
                        <option value="lm" selected>Lisa Moore</option>
                        <option value="an">Alex Nguyen</option>
                    </select>
                </div>
            </form>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" data-modal-close>Cancel</button>
            <button class="btn btn-primary">Save Changes</button>
        </div>
    </div>
</div>

@section PageScripts {
    <script src="~/js/pages/projects.js" asp-append-version="true"></script>
}
