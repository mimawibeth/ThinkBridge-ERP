<!-- Super Admin Sidebar Navigation -->
<aside class="sidebar" id="sidebar">
    <!-- Logo Section -->
    <div class="sidebar-header">
        <a href="@Url.Action("SuperAdminDashboard", "Ui")" class="sidebar-logo">
            <div class="logo-icon">
                <img src="/images/thinkBridge.png" alt="ThinkBridge Logo" />
            </div>
            <span class="logo-text">
                <span class="logo-think">Think</span><span class="logo-bridge">Bridge</span>
            </span>
        </a>
        <button class="sidebar-collapse-btn" id="sidebar-collapse-btn" aria-label="Collapse sidebar">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
        </button>
    </div>

    <!-- Navigation Links -->
    <nav class="sidebar-nav">
        <ul class="nav-list">
            <li class="nav-item">
                <a href="@Url.Action("SuperAdminDashboard", "Ui")" class="nav-link" data-page="superadmindashboard">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2">
                        <rect x="3" y="3" width="7" height="7"></rect>
                        <rect x="14" y="3" width="7" height="7"></rect>
                        <rect x="14" y="14" width="7" height="7"></rect>
                        <rect x="3" y="14" width="7" height="7"></rect>
                    </svg>
                    <span class="nav-text">Dashboard</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Companies", "Ui", new { role = "superadmin" })" class="nav-link"
                       data-page="companies">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2">
                        <path d="M3 21h18"></path>
                        <path d="M9 8h1"></path>
                        <path d="M9 12h1"></path>
                        <path d="M9 16h1"></path>
                        <path d="M14 8h1"></path>
                        <path d="M14 12h1"></path>
                        <path d="M14 16h1"></path>
                        <path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"></path>
                    </svg>
                    <span class="nav-text">Companies</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Subscriptions", "Ui", new { role = "superadmin" })" class="nav-link"
                       data-page="subscriptions">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2">
                        <path d="M21 4H3a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h18a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2z"></path>
                        <path d="M12 8v8"></path>
                        <path d="M8 12h8"></path>
                    </svg>
                    <span class="nav-text">Subscriptions</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Payments", "Ui", new { role = "superadmin" })" class="nav-link"
                       data-page="payments">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2">
                        <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                        <line x1="1" y1="10" x2="23" y2="10"></line>
                    </svg>
                    <span class="nav-text">Payments</span>
                </a>
            </li>
        </ul>
    </nav>

    <!-- User Profile Section -->
    <div class="sidebar-footer">
        <div class="user-profile">
            <div class="user-avatar superadmin">
                <span>JD</span>
            </div>
            <div class="user-info">
                <span class="user-name">John Doe</span>
                <span class="user-role text-muted">Super Administrator</span>
            </div>
        </div>
    </div>
</aside>

