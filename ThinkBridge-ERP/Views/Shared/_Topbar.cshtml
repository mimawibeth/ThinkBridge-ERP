<!-- Topbar Header -->
<header class="topbar @(ViewData["UserRole"]?.ToString() == "superadmin" ? "superadmin-topbar" : "")">
    <div class="topbar-left">
        <h1 class="page-title">@ViewData["Title"]</h1>
    </div>

    <div class="topbar-right">
        <span class="topbar-date" id="topbar-date"></span>
        <!-- Notifications -->
        <div class="topbar-item notification-wrapper">
            <button class="notification-btn" id="notification-btn" aria-label="Notifications"
                    onclick="toggleNotifications(event)">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                </svg>
                <span class="notification-dot" id="notification-dot" style="display:none;"></span>
            </button>
            <div class="notification-dropdown" id="notification-dropdown">
                <div class="dropdown-header">
                    <h3>Notifications</h3>
                    <a href="#" class="mark-all-read" onclick="markAllNotificationsRead(event)">Mark all as read</a>
                </div>
                <div class="notification-list" id="notification-list">
                    <div class="notification-empty"
                         style="text-align:center;padding:24px;color:var(--text-muted);font-size:0.82rem;">Loading...
                    </div>
                </div>
                <div class="dropdown-footer">
                    <a href="@Url.Action("Activity", "Web", new { role = ViewData["UserRole"] })">View all activity</a>
                </div>
            </div>
        </div>

        <!-- User Info Display -->
        <div class="topbar-item topbar-user-info">
            @{
                var userName = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Name)?.Value ??
            "User";
                var userInitials = string.Join("", userName.Split(' ').Where(n => !string.IsNullOrEmpty(n)).Select(n =>
            n[0].ToString().ToUpper()).Take(2));
                if (string.IsNullOrEmpty(userInitials)) userInitials = "U";
                var avatarColor = User.Claims.FirstOrDefault(c => c.Type == "AvatarColor")?.Value ?? "#0B4F6C";
                var userRole = ViewData["UserRole"]?.ToString() ?? "companyadmin";
                var displayRole = userRole switch
                {
                    "superadmin" => "Super Administrator",
                    "companyadmin" => "Administrator",
                    "projectmanager" => "Project Manager",
                    "teammember" => "Team Member",
                    _ => "Administrator"
                };
            }
            <div class="user-avatar-sm" style="background: @avatarColor;" id="topbar-avatar">
                <span>@userInitials</span>
            </div>
            <div class="user-display-info">
                <span class="user-display-name">@userName</span>
                <span class="user-display-role">@displayRole</span>
            </div>
        </div>
    </div>
    <input type="hidden" id="topbar-user-role" value="@userRole" />
</header>