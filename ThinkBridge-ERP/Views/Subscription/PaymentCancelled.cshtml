@{
    ViewData["Title"] = "Payment Cancelled - ThinkBridge ERP";
    ViewData["HideLayout"] = true;
    ViewData["BodyClass"] = "signup-page";
    var subscriptionId = ViewData["SubscriptionId"] as int?;
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/landing.css" asp-append-version="true" />
}

<div class="payment-result-page">
    <div class="payment-result-card">
        <div class="cancel-icon">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="15" y1="9" x2="9" y2="15"></line>
                <line x1="9" y1="9" x2="15" y2="15"></line>
            </svg>
        </div>
        <h2>Payment Cancelled</h2>
        <p class="success-subtitle">Your payment was not completed. Your account has been created but is not yet active.</p>

        <div class="credential-warning">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
            <span>You can try again by signing up with a new company, or contact support for assistance.</span>
        </div>

        <div class="result-actions">
            <a href="/Subscription/SignUp" class="btn btn-primary btn-lg">
                Try Again
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="23 4 23 10 17 10"></polyline>
                    <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
                </svg>
            </a>
            <a href="/" class="btn btn-secondary btn-lg">Back to Home</a>
        </div>
    </div>
</div>
