@{
    ViewData["Title"] = "Login";
    ViewData["HideLayout"] = true;
    ViewData["BodyClass"] = "login-page";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/login.css" asp-append-version="true" />
}

<a href="/" class="back-to-home-btn">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
    </svg>
    Back to Home
</a>

<div class="login-container">
    <!-- Left Side - Branding -->
    <div class="login-branding">
        <div class="branding-content">
            <div class="logo">
                <img src="~/images/thinkBridge.png" alt="ThinkBridge" class="logo-icon" />
                <span class="logo-text"><span class="logo-think">Think</span><span
                    class="logo-bridge">Bridge</span></span>
                </div>
                <h1 class="branding-title">Enterprise Resource Planning Made Simple</h1>
                <p class="branding-description">
                    Streamline your business operations with our comprehensive ERP solution designed for modern teams.
                </p>
                <div class="feature-grid">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2">
                                <rect x="3" y="3" width="7" height="7"></rect>
                                <rect x="14" y="3" width="7" height="7"></rect>
                                <rect x="14" y="14" width="7" height="7"></rect>
                                <rect x="3" y="14" width="7" height="7"></rect>
                            </svg>
                        </div>
                        <h3>Centralized Dashboard</h3>
                        <p>Monitor all projects from one place</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2">
                                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                                <line x1="8" y1="21" x2="16" y2="21"></line>
                                <line x1="12" y1="17" x2="12" y2="21"></line>
                            </svg>
                        </div>
                        <h3>Project Management</h3>
                        <p>Track progress efficiently</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                <circle cx="9" cy="7" r="4"></circle>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                            </svg>
                        </div>
                        <h3>Team Collaboration</h3>
                        <p>Work together seamlessly</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2">
                                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                            </svg>
                        </div>
                        <h3>Knowledge Base</h3>
                        <p>Access documentation easily</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2">
                                <circle cx="12" cy="12" r="10"></circle>
                                <path d="M12 6v6l4 2"></path>
                            </svg>
                        </div>
                        <h3>Enterprise Security</h3>
                        <p>Role-based access control</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2">
                                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                            </svg>
                        </div>
                        <h3>Real-time Updates</h3>
                        <p>Stay informed instantly</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side - Login Form -->
        <div class="login-form-container">
            <div class="login-form-wrapper">
                <div class="login-logo-mobile">
                    <img src="~/images/thinkBridge.png" alt="ThinkBridge" class="logo-icon" />
                    <span class="logo-text"><span class="logo-think">Think</span><span
                        class="logo-bridge">Bridge</span></span>
                    </div>
                    <div class="login-header">
                        <h2>Welcome back</h2>
                        <p>Access your ThinkBridge ERP workspace.</p>
                    </div>

                    <form class="login-form" id="loginForm">
                        @Html.AntiForgeryToken()
                        <div class="form-group">
                            <label for="email">Email Address</label>
                            <input type="email" id="email" class="form-input" placeholder="Enter your email address" required />
                        </div>

                        <div class="form-group">
                            <label for="password">Password</label>
                            <div class="input-wrapper">
                                <input type="password" id="password" class="form-input" placeholder="Enter your password"
                                       required />
                                <button type="button" class="password-toggle" id="toggle-password">
                                    <svg class="eye-icon" width="18" height="18" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                        <circle cx="12" cy="12" r="3"></circle>
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <div class="form-group error-message" id="errorMessage" style="display: none;">
                            <span class="error-text">Invalid password. Please try again.</span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-login" id="loginBtn">
                            Sign In
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                        </button>
                    </form>

                    <div class="login-footer">
                        <p>Don't have an account? <a href="/Subscription/SignUp">Sign Up</a></p>
                    </div>
                </div>
                <div class="login-terms">
                    <p>By signing in, you agree to our <a href="#" id="terms-link">Terms</a> and <a href="#"
                                                                                                        id="privacy-link">Privacy Policy</a></p>
                    </div>
                </div>
            </div>

            <!-- Terms of Service Modal -->
            <div class="modal-overlay" id="terms-modal">
                <div class="modal modal-lg">
                    <div class="modal-header">
                        <h2>Terms of Service</h2>
                        <button class="modal-close" data-modal-close>
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="18" y1="6" x2="6" y2="18"></line>
                                <line x1="6" y1="6" x2="18" y2="18"></line>
                            </svg>
                        </button>
                    </div>
                    <div class="modal-body legal-content">
                        <p class="legal-updated">Last Updated: February 10, 2026</p>

                        <h4>1. Acceptance of Terms</h4>
                        <p>By accessing and using ThinkBridge ERP ("the System"), you agree to be bound by these Terms of Service.
                            If you do not agree, you may not access the System.</p>

                            <h4>2. User Accounts & Access</h4>
                            <ul>
                                <li>Access credentials are provided by your Company Administrator</li>
                                <li>You are responsible for maintaining the confidentiality of your login credentials</li>
                                <li>You must not share your account or allow unauthorized access</li>
                                <li>Report any suspected security breaches immediately to your administrator</li>
                            </ul>

                            <h4>3. Acceptable Use</h4>
                            <p>You agree to use ThinkBridge ERP only for legitimate business purposes. You shall not:</p>
                            <ul>
                                <li>Attempt to gain unauthorized access to system resources</li>
                                <li>Upload malicious code or interfere with system operations</li>
                                <li>Use the System for any unlawful purpose</li>
                                <li>Export or extract data except as authorized by your organization</li>
                            </ul>

                            <h4>4. Intellectual Property</h4>
                            <p>ThinkBridge ERP and its original content, features, and functionality are owned by ThinkBridge
                                Technologies and are protected by international copyright, trademark, and other intellectual property
                                laws.</p>

                                <h4>5. Data Ownership</h4>
                                <p>Your organization retains ownership of all data entered into the System. ThinkBridge acts as a data
                                    processor under applicable data protection regulations.</p>

                                    <h4>6. Service Availability</h4>
                                    <p>We strive to maintain 99.9% uptime but do not guarantee uninterrupted access. Scheduled maintenance will
                                        be announced in advance when possible.</p>

                                        <h4>7. Limitation of Liability</h4>
                                        <p>ThinkBridge shall not be liable for any indirect, incidental, special, consequential, or punitive damages
                                            resulting from your use of the System, to the fullest extent permitted by Philippine and applicable
                                            international law.</p>

                                            <h4>8. Governing Law</h4>
                                            <p>These Terms shall be governed by and construed in accordance with the laws of the Republic of the
                                                Philippines, without regard to conflict of law principles.</p>

                                                <h4>9. Changes to Terms</h4>
                                                <p>We reserve the right to modify these terms at any time. Users will be notified of significant changes.
                                                    Continued use after changes constitutes acceptance.</p>

                                                    <h4>10. Contact</h4>
                                                    <p>For questions about these Terms, contact your Company Administrator or email legal@thinkbridge.com</p>
                                                </div>
                                                <div class="modal-footer">
                                                    <button class="btn btn-primary" data-modal-close>I Understand</button>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Privacy Policy Modal -->
                                        <div class="modal-overlay" id="privacy-modal">
                                            <div class="modal modal-lg">
                                                <div class="modal-header">
                                                    <h2>Privacy Policy</h2>
                                                    <button class="modal-close" data-modal-close>
                                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                            <line x1="18" y1="6" x2="6" y2="18"></line>
                                                            <line x1="6" y1="6" x2="18" y2="18"></line>
                                                        </svg>
                                                    </button>
                                                </div>
                                                <div class="modal-body legal-content">
                                                    <p class="legal-updated">Last Updated: February 10, 2026</p>
                                                    <p class="legal-compliance">This policy complies with the <strong>Data Privacy Act of 2012 (RA
                                                        10173)</strong> of the Philippines and the <strong>General Data Protection Regulation
                                                        (GDPR)</strong> of the European Union.</p>

                                                        <h4>1. Data Controller</h4>
                                                        <p>Your organization acts as the Data Controller. ThinkBridge Technologies acts as the Data Processor,
                                                            processing personal data on behalf of your organization.</p>

                                                            <h4>2. Personal Data We Collect</h4>
                                                            <ul>
                                                                <li><strong>Identity Data:</strong> Name, employee ID, job title, department</li>
                                                                <li><strong>Contact Data:</strong> Email address, phone number</li>
                                                                <li><strong>Technical Data:</strong> IP address, browser type, login timestamps, device information</li>
                                                                <li><strong>Usage Data:</strong> System activity logs, feature usage, session duration</li>
                                                            </ul>

                                                            <h4>3. Legal Basis for Processing</h4>
                                                            <p>Under RA 10173 and GDPR, we process your data based on:</p>
                                                            <ul>
                                                                <li><strong>Consent:</strong> Your explicit agreement to these terms</li>
                                                                <li><strong>Contractual Necessity:</strong> To provide ERP services to your organization</li>
                                                                <li><strong>Legitimate Interests:</strong> System security, fraud prevention, service improvement</li>
                                                                <li><strong>Legal Obligation:</strong> Compliance with applicable laws and regulations</li>
                                                            </ul>

                                                            <h4>4. How We Use Your Data</h4>
                                                            <ul>
                                                                <li>Authenticate and authorize system access</li>
                                                                <li>Provide and maintain ERP functionality</li>
                                                                <li>Generate audit logs for security and compliance</li>
                                                                <li>Send system notifications and updates</li>
                                                                <li>Improve system performance and user experience</li>
                                                            </ul>

                                                            <h4>5. Data Retention</h4>
                                                            <p>Personal data is retained for the duration of your employment with the subscribing organization, plus 5
                                                                years for audit and legal compliance purposes, unless a longer retention period is required by law.</p>

                                                                <h4>6. Your Data Subject Rights</h4>
                                                                <p>Under RA 10173 and GDPR, you have the right to:</p>
                                                                <ul>
                                                                    <li><strong>Access:</strong> Request a copy of your personal data</li>
                                                                    <li><strong>Rectification:</strong> Correct inaccurate or incomplete data</li>
                                                                    <li><strong>Erasure:</strong> Request deletion of your data (subject to legal retention requirements)
                                                                    </li>
                                                                    <li><strong>Portability:</strong> Receive your data in a structured, machine-readable format</li>
                                                                    <li><strong>Object:</strong> Object to processing based on legitimate interests</li>
                                                                    <li><strong>Withdraw Consent:</strong> Withdraw consent at any time (contact your Company Administrator)
                                                                    </li>
                                                                </ul>

                                                                <h4>7. Data Security</h4>
                                                                <p>We implement appropriate technical and organizational measures including:</p>
                                                                <ul>
                                                                    <li>End-to-end encryption for data in transit (TLS 1.3)</li>
                                                                    <li>AES-256 encryption for data at rest</li>
                                                                    <li>Role-based access control (RBAC)</li>
                                                                    <li>Regular security audits and penetration testing</li>
                                                                    <li>Multi-factor authentication options</li>
                                                                </ul>

                                                                <h4>8. Data Transfers</h4>
                                                                <p>Data may be processed in servers located within the Philippines and other jurisdictions with adequate
                                                                    data protection. Cross-border transfers comply with NPC Circular 2016-02 and GDPR Chapter V
                                                                    requirements.</p>

                                                                    <h4>9. Third-Party Disclosure</h4>
                                                                    <p>We do not sell personal data. Data may be shared with:</p>
                                                                    <ul>
                                                                        <li>Cloud infrastructure providers (under Data Processing Agreements)</li>
                                                                        <li>Law enforcement when required by valid legal process</li>
                                                                        <li>Auditors for compliance verification</li>
                                                                    </ul>

                                                                    <h4>10. Breach Notification</h4>
                                                                    <p>In the event of a personal data breach, we will notify the National Privacy Commission (NPC) and affected
                                                                        data subjects within 72 hours, as required by RA 10173 and GDPR.</p>

                                                                        <h4>11. Data Protection Officer</h4>
                                                                        <p>For privacy concerns or to exercise your rights, contact:<br>
                                                                            <strong>Data Protection Officer</strong><br>
                                                                            Email: dpo@thinkbridge.com<br>
                                                                            You may also file a complaint with the National Privacy Commission (NPC) at complaints@privacy.gov.ph
                                                                        </p>

                                                                        <h4>12. Policy Updates</h4>
                                                                        <p>This policy may be updated periodically. Material changes will be communicated via system notification or
                                                                            email.</p>
                                                                        </div>
                                                                        <div class="modal-footer">
                                                                            <button class="btn btn-primary" data-modal-close>I Understand</button>
                                                                        </div>
                                                                    </div>
                                                                </div>

                                                                <script>
                                                                    // Password toggle
                                                                    document.getElementById('toggle-password').addEventListener('click', function () {
                                                                        const passwordInput = document.getElementById('password');
                                                                        const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                                                                        passwordInput.setAttribute('type', type);
                                                                    });

                                                                    // Terms and Privacy modals
                                                                    document.getElementById('terms-link').addEventListener('click', function (e) {
                                                                        e.preventDefault();
                                                                        document.getElementById('terms-modal').classList.add('active');
                                                                    });

                                                                    document.getElementById('privacy-link').addEventListener('click', function (e) {
                                                                        e.preventDefault();
                                                                        document.getElementById('privacy-modal').classList.add('active');
                                                                    });

                                                                    // Close modals
                                                                    document.querySelectorAll('[data-modal-close]').forEach(btn => {
                                                                        btn.addEventListener('click', function () {
                                                                            this.closest('.modal-overlay').classList.remove('active');
                                                                        });
                                                                    });

                                                                    document.querySelectorAll('.modal-overlay').forEach(overlay => {
                                                                        overlay.addEventListener('click', function (e) {
                                                                            if (e.target === this) {
                                                                                this.classList.remove('active');
                                                                            }
                                                                        });
                                                                    });

                                                                    // Form submission with API call
                                                                    document.getElementById('loginForm').addEventListener('submit', async function (e) {
                                                                        e.preventDefault();

                                                                        const email = document.getElementById('email').value.toLowerCase().trim();
                                                                        const password = document.getElementById('password').value;
                                                                        const errorMessage = document.getElementById('errorMessage');
                                                                        const loginBtn = document.getElementById('loginBtn');

                                                                        // Hide previous error
                                                                        errorMessage.style.display = 'none';

                                                                        // Validate email
                                                                        if (!email) {
                                                                            errorMessage.querySelector('.error-text').textContent = 'Please enter your email address.';
                                                                            errorMessage.style.display = 'block';
                                                                            return;
                                                                        }

                                                                        // Validate password
                                                                        if (!password) {
                                                                            errorMessage.querySelector('.error-text').textContent = 'Please enter your password.';
                                                                            errorMessage.style.display = 'block';
                                                                            return;
                                                                        }

                                                                        // Disable button and show loading state
                                                                        loginBtn.disabled = true;
                                                                        loginBtn.innerHTML = '<span class="spinner"></span> Signing in...';

                                                                        try {
                                                                            const response = await fetch('/Auth/Login', {
                                                                                method: 'POST',
                                                                                headers: {
                                                                                    'Content-Type': 'application/json'
                                                                                },
                                                                                credentials: 'same-origin',
                                                                                body: JSON.stringify({
                                                                                    email: email,
                                                                                    password: password,
                                                                                    rememberMe: false
                                                                                })
                                                                            });

                                                                            if (!response.ok) {
                                                                                throw new Error(`HTTP error! status: ${response.status}`);
                                                                            }

                                                                            const result = await response.json();

                                                                            if (result.success) {
                                                                                // Store user info in sessionStorage
                                                                                sessionStorage.setItem('userRole', result.user.role.toLowerCase());
                                                                                sessionStorage.setItem('userName', result.user.name);
                                                                                sessionStorage.setItem('userEmail', result.user.email);

                                                                                // Redirect to appropriate dashboard
                                                                                window.location.href = result.redirectUrl;
                                                                            } else {
                                                                                errorMessage.querySelector('.error-text').textContent = result.message || 'Login failed. Please try again.';
                                                                                errorMessage.style.display = 'block';
                                                                                loginBtn.disabled = false;
                                                                                loginBtn.innerHTML = 'Sign In <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>';
                                                                            }
                                                                        } catch (error) {
                                                                            console.error('Login error:', error);
                                                                            errorMessage.querySelector('.error-text').textContent = 'An error occurred. Please try again.';
                                                                            errorMessage.style.display = 'block';
                                                                            loginBtn.disabled = false;
                                                                            loginBtn.innerHTML = 'Sign In <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>';
                                                                        }
                                                                    });
                                                                </script>