@{
    ViewData["Title"] = "Subscriptions";
    ViewData["UserRole"] = "superadmin";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/subscriptions.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/superadmin.css" asp-append-version="true" />
}

<div class="page-subscriptions">
    <!-- Quick Stats -->
    <section class="stats-section">
        <div class="stat-card">
            <div class="stat-icon blue">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
            </div>
            <div class="stat-content">
                <span class="stat-value" id="stat-total">0</span>
                <span class="stat-label">Total Subscribers</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon green">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
            </div>
            <div class="stat-content">
                <span class="stat-value" id="stat-active">0</span>
                <span class="stat-label">Active Subscriptions</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon orange">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
            </div>
            <div class="stat-content">
                <span class="stat-value" id="stat-trial">0</span>
                <span class="stat-label">Trial Users</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon purple">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="1" x2="12" y2="23"></line>
                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                </svg>
            </div>
            <div class="stat-content">
                <span class="stat-value" id="stat-mrr">₱0</span>
                <span class="stat-label">Monthly Revenue</span>
            </div>
        </div>
    </section>

    <!-- Subscription Plans Section -->
    <section class="plans-management-section">
        <div class="section-header">
            <h2 class="section-title">Subscription Plans</h2>
            <button class="btn btn-primary" id="add-plan-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                Add Plan
            </button>
        </div>
        <div class="table-section">
            <div class="table-container">
                <table class="data-table" id="plans-table">
                    <thead>
                        <tr>
                            <th>Plan Name</th>
                            <th>Price</th>
                            <th>Billing Cycle</th>
                            <th>Max Users</th>
                            <th>Max Projects</th>
                            <th>Active Subs</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="plans-tbody">
                        <tr>
                            <td colspan="8" class="loading-cell">Loading plans...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- Company Subscriptions Section -->
    <section class="subscriptions-section">
        <div class="filters-section">
            <div class="search-box">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" placeholder="Search subscriptions..." class="search-input"
                       id="subscription-search" />
            </div>
            <div class="filter-group">
                <select class="filter-select" id="status-filter">
                    <option value="">All Status</option>
                    <option value="active">Active</option>
                    <option value="trial">Trial</option>
                    <option value="expired">Expired</option>
                    <option value="cancelled">Cancelled</option>
                </select>
                <select class="filter-select" id="plan-filter">
                    <option value="">All Plans</option>
                </select>
            </div>
        </div>

        <div class="table-section">
            <div class="table-container">
                <table class="data-table" id="subscriptions-table">
                    <thead>
                        <tr>
                            <th>Company</th>
                            <th>Plan</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Remaining</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="subscriptions-tbody">
                        <tr>
                            <td colspan="8" class="loading-cell">Loading subscriptions...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="table-footer" id="subscription-pagination">
            </div>
        </div>
    </section>
</div>

<!-- Add/Edit Plan Modal -->
<div class="modal-overlay" id="plan-modal">
    <div class="modal">
        <div class="modal-header">
            <h3 class="modal-title" id="plan-modal-title">Add Subscription Plan</h3>
            <button class="modal-close" onclick="closePlanModal()">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="plan-edit-id" value="" />
            <div class="form-group">
                <label class="form-label">Plan Name</label>
                <input type="text" class="form-input" id="plan-name" placeholder="e.g. Professional" maxlength="80" />
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Price (₱)</label>
                    <input type="number" class="form-input" id="plan-price" placeholder="0.00" min="0" step="0.01" />
                </div>
                <div class="form-group">
                    <label class="form-label">Billing Cycle</label>
                    <select class="form-select" id="plan-billing-cycle">
                        <option value="Monthly">Monthly</option>
                        <option value="Annual">Annual</option>
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Max Users</label>
                    <input type="number" class="form-input" id="plan-max-users" placeholder="Unlimited (0)" min="0" />
                    <span class="form-hint">Leave 0 for unlimited</span>
                </div>
                <div class="form-group">
                    <label class="form-label">Max Projects</label>
                    <input type="number" class="form-input" id="plan-max-projects" placeholder="Unlimited (0)"
                           min="0" />
                    <span class="form-hint">Leave 0 for unlimited</span>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label checkbox-label">
                    <input type="checkbox" id="plan-is-active" checked />
                    Plan is Active
                </label>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closePlanModal()">Cancel</button>
            <button class="btn btn-primary" id="save-plan-btn">Save Plan</button>
        </div>
    </div>
</div>

<!-- Edit Subscription Modal -->
<div class="modal-overlay" id="subscription-edit-modal">
    <div class="modal">
        <div class="modal-header">
            <h3 class="modal-title">Edit Subscription</h3>
            <button class="modal-close" onclick="closeEditSubModal()">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="edit-sub-id" value="" />
            <div class="edit-sub-company-info" id="edit-sub-company-info"></div>
            <div class="form-group">
                <label class="form-label">Plan</label>
                <select class="form-select" id="edit-sub-plan">
                    <option value="">Select plan...</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Status</label>
                <select class="form-select" id="edit-sub-status">
                    <option value="Active">Active</option>
                    <option value="Trial">Trial</option>
                    <option value="Expired">Expired</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Start Date</label>
                    <input type="date" class="form-input" id="edit-sub-start-date" />
                </div>
                <div class="form-group">
                    <label class="form-label">End Date</label>
                    <input type="date" class="form-input" id="edit-sub-end-date" />
                </div>
            </div>
            <div class="modal-danger-zone">
                <button class="btn btn-outline danger" id="cancel-subscription-btn">Cancel Subscription</button>
                <span class="form-hint">This will suspend the company and deactivate all users.</span>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeEditSubModal()">Cancel</button>
            <button class="btn btn-primary" id="update-subscription-btn">Save Changes</button>
        </div>
    </div>
</div>

<!-- View Subscription Detail Modal -->
<div class="modal-overlay" id="subscription-detail-modal">
    <div class="modal modal-lg">
        <div class="modal-header">
            <h3 class="modal-title">Subscription Details</h3>
            <button class="modal-close" onclick="closeDetailModal()">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body" id="detail-modal-body">
            <div class="loading-cell">Loading...</div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeDetailModal()">Close</button>
        </div>
    </div>
</div>

<!-- Confirm Action Modal -->
<div class="modal-overlay" id="confirm-modal">
    <div class="modal" style="max-width: 420px;">
        <div class="modal-header">
            <h3 class="modal-title" id="confirm-modal-title">Confirm</h3>
            <button class="modal-close" id="confirm-modal-close">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body" style="padding: 24px;">
            <div style="display: flex; align-items: flex-start; gap: 16px;">
                <div
                    style="flex-shrink: 0; width: 42px; height: 42px; border-radius: 50%; background: rgba(220, 38, 38, 0.1); display: flex; align-items: center; justify-content: center;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="8" x2="12" y2="12"></line>
                        <line x1="12" y1="16" x2="12.01" y2="16"></line>
                    </svg>
                </div>
                <p id="confirm-modal-message"
                       style="margin: 0; padding-top: 8px; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.5;">
                </p>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" id="confirm-modal-cancel">Cancel</button>
            <button class="btn btn-primary" id="confirm-modal-action"
                    style="background: var(--danger, #DC2626); border-color: var(--danger, #DC2626);">Confirm</button>
        </div>
    </div>
</div>

@section PageScripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            let currentPage = 1;
            let currentStatus = '';
            let currentPlan = '';
            let currentSearch = '';
            let plansCache = [];
            let confirmCallback = null;

            // Init
            loadStats();
            loadPlans();
            loadSubscriptions();

            // Bind events
            const searchInput = document.getElementById('subscription-search');
            const statusFilter = document.getElementById('status-filter');
            const planFilter = document.getElementById('plan-filter');

            if (searchInput) {
                let timeout;
                searchInput.addEventListener('input', function () {
                    clearTimeout(timeout);
                    timeout = setTimeout(() => {
                        currentSearch = this.value;
                        currentPage = 1;
                        loadSubscriptions();
                    }, 300);
                });
            }

            if (statusFilter) {
                statusFilter.addEventListener('change', function () {
                    currentStatus = this.value;
                    currentPage = 1;
                    loadSubscriptions();
                });
            }

            if (planFilter) {
                planFilter.addEventListener('change', function () {
                    currentPlan = this.value;
                    currentPage = 1;
                    loadSubscriptions();
                });
            }

            document.getElementById('add-plan-btn').addEventListener('click', () => openPlanModal());
            document.getElementById('save-plan-btn').addEventListener('click', savePlan);
            document.getElementById('update-subscription-btn').addEventListener('click', updateSubscription);
            document.getElementById('cancel-subscription-btn').addEventListener('click', cancelSubscription);

            // Close modals on overlay click
            document.querySelectorAll('.modal-overlay').forEach(overlay => {
                overlay.addEventListener('click', function (e) {
                    if (e.target === overlay) overlay.classList.remove('active');
                });
            });

            // ========== CONFIRM MODAL ==========
            function showConfirmModal(message, title, actionLabel, onConfirm) {
                const overlay = document.getElementById('confirm-modal');
                document.getElementById('confirm-modal-title').textContent = title || 'Confirm';
                document.getElementById('confirm-modal-message').innerHTML = message;
                document.getElementById('confirm-modal-action').textContent = actionLabel || 'Confirm';
                confirmCallback = onConfirm;
                overlay.classList.add('active');
            }

            function closeConfirmModal() {
                document.getElementById('confirm-modal').classList.remove('active');
                confirmCallback = null;
            }

            document.getElementById('confirm-modal-cancel').addEventListener('click', closeConfirmModal);
            document.getElementById('confirm-modal-close').addEventListener('click', closeConfirmModal);
            document.getElementById('confirm-modal').addEventListener('click', function (e) {
                if (e.target === this) closeConfirmModal();
            });
            document.getElementById('confirm-modal-action').addEventListener('click', function () {
                if (confirmCallback) confirmCallback();
                closeConfirmModal();
            });

            // ========== STATS ==========
            async function loadStats() {
                try {
                    const res = await fetch('/api/superadmin/subscriptions/stats', { credentials: 'same-origin' });
                    const result = await res.json();
                    if (result.success) {
                        const d = result.data;
                        document.getElementById('stat-total').textContent = d.totalSubscriptions;
                        document.getElementById('stat-active').textContent = d.activeSubscriptions;
                        document.getElementById('stat-trial').textContent = d.trialSubscriptions;
                        document.getElementById('stat-mrr').textContent = '₱' + formatNumber(d.monthlyRecurringRevenue);
                    }
                } catch (e) { console.error('Error loading stats:', e); }
            }

            // ========== PLANS ==========
            async function loadPlans() {
                try {
                    const res = await fetch('/api/superadmin/subscription-plans', { credentials: 'same-origin' });
                    const result = await res.json();
                    if (result.success) {
                        plansCache = result.data;
                        renderPlansTable(result.data);
                        populatePlanDropdowns(result.data);
                    }
                } catch (e) { console.error('Error loading plans:', e); }
            }

            function renderPlansTable(plans) {
                const tbody = document.getElementById('plans-tbody');
                if (!plans || plans.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="8" class="loading-cell">No plans found. Click "Add Plan" to create one.</td></tr>';
                    return;
                }

                const visiblePlans = plans.filter(p => p.planName.toLowerCase() !== 'trial');
                if (visiblePlans.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="8" class="loading-cell">No plans found. Click "Add Plan" to create one.</td></tr>';
                    return;
                }

                tbody.innerHTML = visiblePlans.map(p => `
                        <tr>
                            <td><strong>${esc(p.planName)}</strong></td>
                            <td>₱${formatNumber(p.price)}</td>
                            <td>${esc(p.billingCycle)}</td>
                            <td>${p.maxUsers ? p.maxUsers : '<span class="text-muted">Unlimited</span>'}</td>
                            <td>${p.maxProjects ? p.maxProjects : '<span class="text-muted">Unlimited</span>'}</td>
                            <td>${p.activeSubscriptions}</td>
                            <td>${p.isActive ? 'Active' : 'Inactive'}</td>
                            <td>
                                <div class="action-buttons">
                                    <button class="btn-icon" title="Edit Plan" onclick="openPlanModal(${p.planID})">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    `).join('');
            }

            function populatePlanDropdowns(plans) {
                const activePlans = plans.filter(p => p.isActive);

                // Plan filter dropdown
                const planFilterEl = document.getElementById('plan-filter');
                const currentVal = planFilterEl.value;
                planFilterEl.innerHTML = '<option value="">All Plans</option>' +
                    plans.map(p => `<option value="${esc(p.planName.toLowerCase())}">${esc(p.planName)}</option>`).join('');
                planFilterEl.value = currentVal;

                // Edit subscription plan dropdown
                const editSubPlan = document.getElementById('edit-sub-plan');
                editSubPlan.innerHTML = '<option value="">Select plan...</option>' +
                    activePlans.map(p => `<option value="${p.planID}">${esc(p.planName)} (₱${formatNumber(p.price)}/${p.billingCycle})</option>`).join('');
            }

            // Plan modal
            window.openPlanModal = function (planId) {
                const modal = document.getElementById('plan-modal');
                const title = document.getElementById('plan-modal-title');

                if (planId) {
                    const plan = plansCache.find(p => p.planID === planId);
                    if (!plan) return;

                    title.textContent = 'Edit Subscription Plan';
                    document.getElementById('plan-edit-id').value = planId;
                    document.getElementById('plan-name').value = plan.planName;
                    document.getElementById('plan-price').value = plan.price;
                    document.getElementById('plan-billing-cycle').value = plan.billingCycle;
                    document.getElementById('plan-max-users').value = plan.maxUsers || 0;
                    document.getElementById('plan-max-projects').value = plan.maxProjects || 0;
                    document.getElementById('plan-is-active').checked = plan.isActive;
                } else {
                    title.textContent = 'Add Subscription Plan';
                    document.getElementById('plan-edit-id').value = '';
                    document.getElementById('plan-name').value = '';
                    document.getElementById('plan-price').value = '';
                    document.getElementById('plan-billing-cycle').value = 'Monthly';
                    document.getElementById('plan-max-users').value = '';
                    document.getElementById('plan-max-projects').value = '';
                    document.getElementById('plan-is-active').checked = true;
                }

                modal.classList.add('active');
            };

            window.closePlanModal = function () {
                document.getElementById('plan-modal').classList.remove('active');
            };

            async function savePlan() {
                const editId = document.getElementById('plan-edit-id').value;
                const body = {
                    planName: document.getElementById('plan-name').value.trim(),
                    price: parseFloat(document.getElementById('plan-price').value) || 0,
                    billingCycle: document.getElementById('plan-billing-cycle').value,
                    maxUsers: parseInt(document.getElementById('plan-max-users').value) || 0,
                    maxProjects: parseInt(document.getElementById('plan-max-projects').value) || 0,
                    isActive: document.getElementById('plan-is-active').checked
                };

                if (!body.planName) { alert('Plan name is required.'); return; }

                try {
                    const url = editId
                        ? `/api/superadmin/subscription-plans/${editId}`
                        : '/api/superadmin/subscription-plans';
                    const method = editId ? 'PUT' : 'POST';

                    const res = await fetch(url, {
                        method,
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'same-origin',
                        body: JSON.stringify(body)
                    });
                    const result = await res.json();
                    if (result.success) {
                        closePlanModal();
                        showToast(editId ? 'Plan updated successfully.' : 'Plan created successfully.', 'success');
                        loadPlans();
                        loadStats();
                    } else {
                        showToast(result.message || 'Failed to save plan.', 'error');
                    }
                } catch (e) { alert('An error occurred while saving the plan.'); }
            }

            // ========== SUBSCRIPTIONS ==========
            async function loadSubscriptions() {
                const params = new URLSearchParams({ page: currentPage, pageSize: 10 });
                if (currentSearch) params.append('search', currentSearch);
                if (currentStatus) params.append('status', currentStatus);
                if (currentPlan) params.append('plan', currentPlan);

                try {
                    const res = await fetch(`/api/superadmin/subscriptions?${params}`, { credentials: 'same-origin' });
                    const result = await res.json();
                    if (result.success) {
                        renderSubscriptionsTable(result.data);
                        renderPagination(result.pagination);
                    }
                } catch (e) { console.error('Error loading subscriptions:', e); }
            }

            function renderSubscriptionsTable(subscriptions) {
                const tbody = document.getElementById('subscriptions-tbody');
                if (!subscriptions || subscriptions.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="8" class="loading-cell">No subscriptions found</td></tr>';
                    return;
                }

                tbody.innerHTML = subscriptions.map(sub => {
                    const planClass = (sub.planName || 'trial').toLowerCase();
                    const statusClass = sub.status.toLowerCase();

                    let remaining = '';
                    if (sub.status === 'Active' || sub.status === 'Trial') {
                        if (sub.daysRemaining >= 0) {
                            remaining = `<span class="${sub.daysRemaining <= 7 ? 'text-danger' : ''}">${sub.daysRemaining}d</span>`;
                        } else {
                            remaining = '<span class="text-muted">Ongoing</span>';
                        }
                    } else {
                        remaining = '<span class="text-muted">—</span>';
                    }

                    return `
                            <tr class="clickable-row" onclick="viewSubscription(${sub.subscriptionID})">
                                <td><strong>${esc(sub.companyName)}</strong></td>
                                <td><span class="plan-text ${planClass}">${esc(sub.planName)}</span></td>
                                <td>₱${formatNumber(sub.planPrice)}/${sub.billingCycle === 'Annual' ? 'yr' : 'mo'}</td>
                                <td><span class="status-indicator ${statusClass}">${esc(sub.status)}</span></td>
                                <td>${formatDate(sub.startDate)}</td>
                                <td>${sub.endDate ? formatDate(sub.endDate) : '<span class="text-muted">—</span>'}</td>
                                <td>${remaining}</td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="btn-icon" title="Edit Subscription" onclick="event.stopPropagation(); openEditSubModal(${sub.subscriptionID})">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                            </svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        `;
                }).join('');
            }

            function renderPagination(pagination) {
                const footer = document.getElementById('subscription-pagination');
                if (!pagination || pagination.totalPages <= 1) {
                    footer.innerHTML = pagination
                        ? `<span class="table-info">Showing ${pagination.totalCount} subscription${pagination.totalCount !== 1 ? 's' : ''}</span>`
                        : '';
                    return;
                }

                let pagesHtml = '';
                for (let i = 1; i <= pagination.totalPages; i++) {
                    pagesHtml += `<button class="page-btn ${i === currentPage ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
                }

                footer.innerHTML = `
                        <span class="table-info">Showing ${(currentPage - 1) * pagination.pageSize + 1}–${Math.min(currentPage * pagination.pageSize, pagination.totalCount)} of ${pagination.totalCount}</span>
                        <div class="pagination">${pagesHtml}</div>
                    `;
            }

            window.goToPage = function (page) {
                currentPage = page;
                loadSubscriptions();
            };

            // ========== EDIT SUBSCRIPTION ==========
            window.openEditSubModal = async function (subId) {
                const modal = document.getElementById('subscription-edit-modal');
                try {
                    const res = await fetch(`/api/superadmin/subscriptions/${subId}`, { credentials: 'same-origin' });
                    const result = await res.json();
                    if (result.success) {
                        const d = result.data;
                        document.getElementById('edit-sub-id').value = subId;

                        // Company info (read-only context)
                        const infoEl = document.getElementById('edit-sub-company-info');
                        infoEl.innerHTML = `
                                <div class="company-cell">
                                    <div class="company-details">
                                        <span class="company-name">${esc(d.company.companyName)}</span>
                                        <span class="company-email">${d.admin ? esc(d.admin.email) : ''}</span>
                                    </div>
                                </div>`;

                        document.getElementById('edit-sub-plan').value = d.subscription.planID;
                        document.getElementById('edit-sub-status').value = d.subscription.status;
                        document.getElementById('edit-sub-start-date').value = d.subscription.startDate;
                        document.getElementById('edit-sub-end-date').value = d.subscription.endDate || '';

                        modal.classList.add('active');
                    }
                } catch (e) { console.error(e); }
            };

            window.closeEditSubModal = function () {
                document.getElementById('subscription-edit-modal').classList.remove('active');
            };

            async function updateSubscription() {
                const subId = document.getElementById('edit-sub-id').value;
                const body = {
                    planID: parseInt(document.getElementById('edit-sub-plan').value) || null,
                    status: document.getElementById('edit-sub-status').value || null,
                    startDate: document.getElementById('edit-sub-start-date').value || null,
                    endDate: document.getElementById('edit-sub-end-date').value || null
                };

                try {
                    const res = await fetch(`/api/superadmin/subscriptions/${subId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'same-origin',
                        body: JSON.stringify(body)
                    });
                    const result = await res.json();
                    if (result.success) {
                        closeEditSubModal();
                        loadSubscriptions();
                        loadStats();
                    } else {
                        alert('Error: ' + result.message);
                    }
                } catch (e) { alert('An error occurred while updating the subscription.'); }
            }

            // ========== CANCEL SUBSCRIPTION (styled confirm) ==========
            async function cancelSubscription() {
                const subId = document.getElementById('edit-sub-id').value;
                showConfirmModal(
                    'Are you sure you want to <strong>cancel</strong> this subscription? This will suspend the company and deactivate all users.',
                    'Cancel Subscription',
                    'Cancel Subscription',
                    async function () {
                        try {
                            const res = await fetch(`/api/superadmin/subscriptions/${subId}/cancel`, {
                                method: 'POST',
                                credentials: 'same-origin'
                            });
                            const result = await res.json();
                            if (result.success) {
                                closeEditSubModal();
                                loadSubscriptions();
                                loadStats();
                            } else {
                                alert('Error: ' + result.message);
                            }
                        } catch (e) { alert('An error occurred.'); }
                    }
                );
            }

            // ========== VIEW SUBSCRIPTION DETAIL (billing-focused) ==========
            window.viewSubscription = async function (subId) {
                const modal = document.getElementById('subscription-detail-modal');
                const body = document.getElementById('detail-modal-body');
                body.innerHTML = '<div class="loading-cell">Loading...</div>';
                modal.classList.add('active');

                try {
                    const res = await fetch(`/api/superadmin/subscriptions/${subId}`, { credentials: 'same-origin' });
                    const result = await res.json();
                    if (result.success) {
                        const d = result.data;
                        const planClass = (d.subscription.planName || 'trial').toLowerCase();
                        body.innerHTML = `
                                <div class="detail-section" style="margin-bottom: var(--spacing-md); padding-bottom: var(--spacing-md); border-bottom: 1px solid var(--border);">
                                    <div style="display: flex; align-items: center; gap: 12px;">
                                        <strong style="font-size: 1rem;">${esc(d.company.companyName)}</strong>
                                        <span class="status-indicator ${d.company.status.toLowerCase()}" style="font-size: 0.75rem;">${esc(d.company.status)}</span>
                                    </div>
                                    ${d.admin ? `<span style="font-size: 0.85rem; color: var(--text-secondary);">${esc(d.admin.name)} &middot; ${esc(d.admin.email)}</span>` : ''}
                                </div>
                                <div class="detail-grid">
                                    <div class="detail-section">
                                        <h4>Billing Details</h4>
                                        <div class="detail-row"><span>Plan</span><span class="plan-text ${planClass}">${esc(d.subscription.planName)}</span></div>
                                        <div class="detail-row"><span>Price</span><span>₱${formatNumber(d.subscription.planPrice)}/${d.subscription.billingCycle === 'Annual' ? 'yr' : 'mo'}</span></div>
                                        <div class="detail-row"><span>Status</span><span>${esc(d.subscription.status)}</span></div>
                                    </div>
                                    <div class="detail-section">
                                        <h4>Period</h4>
                                        <div class="detail-row"><span>Start Date</span><span>${formatDate(d.subscription.startDate)}</span></div>
                                        <div class="detail-row"><span>End Date</span><span>${d.subscription.endDate ? formatDate(d.subscription.endDate) : '—'}</span></div>
                                    </div>
                                </div>
                                ${d.invoices.length > 0 ? `
                                    <div class="detail-section">
                                        <h4>Recent Invoices (${d.invoices.length})</h4>
                                        <table class="data-table compact">
                                            <thead><tr><th>Invoice #</th><th>Amount</th><th>Due</th><th>Paid</th><th>Status</th></tr></thead>
                                            <tbody>
                                                ${d.invoices.slice(0, 5).map(i => `
                                                    <tr>
                                                        <td>${esc(i.invoiceNumber)}</td>
                                                        <td>₱${formatNumber(i.amount)}</td>
                                                        <td>${formatDate(i.dueDate)}</td>
                                                        <td>${i.paidDate ? formatDate(i.paidDate) : '—'}</td>
                                                        <td>${esc(i.status)}</td>
                                                    </tr>
                                                `).join('')}
                                            </tbody>
                                        </table>
                                    </div>
                                ` : ''}
                                ${d.payments.length > 0 ? `
                                    <div class="detail-section">
                                        <h4>Recent Payments (${d.payments.length})</h4>
                                        <table class="data-table compact">
                                            <thead><tr><th>Provider</th><th>Method</th><th>Amount</th><th>Status</th><th>Date</th></tr></thead>
                                            <tbody>
                                                ${d.payments.slice(0, 5).map(p => `
                                                    <tr>
                                                        <td>${esc(p.provider)}</td>
                                                        <td>${esc(p.paymentMethod || '—')}</td>
                                                        <td>₱${formatNumber(p.amount)}</td>
                                                        <td>${esc(p.status)}</td>
                                                        <td>${p.paidAt || p.createdAt}</td>
                                                    </tr>
                                                `).join('')}
                                            </tbody>
                                        </table>
                                    </div>
                                ` : ''}
                            `;
                    } else {
                        body.innerHTML = '<div class="loading-cell">Failed to load subscription details.</div>';
                    }
                } catch (e) {
                    body.innerHTML = '<div class="loading-cell">An error occurred.</div>';
                }
            };

            window.closeDetailModal = function () {
                document.getElementById('subscription-detail-modal').classList.remove('active');
            };

            // ========== ESCAPE KEY ==========
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') {
                    if (document.getElementById('confirm-modal').classList.contains('active')) closeConfirmModal();
                    else if (document.getElementById('subscription-detail-modal').classList.contains('active')) closeDetailModal();
                    else if (document.getElementById('subscription-edit-modal').classList.contains('active')) closeEditSubModal();
                    else if (document.getElementById('plan-modal').classList.contains('active')) closePlanModal();
                }
            });

            // ========== HELPERS ==========
            function esc(text) {
                if (!text) return '';
                const d = document.createElement('div');
                d.textContent = text;
                return d.innerHTML;
            }

            function formatNumber(n) {
                if (n == null) return '0';
                return Number(n).toLocaleString();
            }

            function formatDate(dateStr) {
                if (!dateStr) return '—';
                return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
            }
        });
    </script>
}