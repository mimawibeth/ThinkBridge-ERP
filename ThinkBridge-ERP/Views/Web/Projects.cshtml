    function renderPagination(pagination) {
        const container = document.getElementById('pagination-container');
        const info = document.getElementById('pagination-info');
        const controls = document.getElementById('pagination-controls');

        if (!pagination || pagination.totalPages <= 1) {
            container.style.display = 'none';
            return;
        }

        container.style.display = 'flex';
        const start = (pagination.page - 1) * pagination.pageSize + 1;
        const end = Math.min(pagination.page * pagination.pageSize, pagination.totalCount);
        info.textContent = `Showing ${start}-${end} of ${pagination.totalCount} projects`;

        let btns = `<button style="padding:6px 12px;border:1px solid var(--border);border-radius:var(--radius-md);background:var(--surface);cursor:pointer;" ${pagination.page === 1 ? 'disabled' : ''} onclick="window._goToPage(${pagination.page - 1})">&laquo;</button>`;
        for (let i = 1; i <= pagination.totalPages; i++) {
            btns += `<button style="padding:6px 12px;border:1px solid var(--border);border-radius:var(--radius-md);background:${i === pagination.page ? 'var(--primary)' : 'var(--surface)'};color:${i === pagination.page ? 'white' : 'var(--text-primary)'};cursor:pointer;" onclick="window._goToPage(${i})">${i}</button>`;
        }
        btns += `<button style="padding:6px 12px;border:1px solid var(--border);border-radius:var(--radius-md);background:var(--surface);cursor:pointer;" ${pagination.page === pagination.totalPages ? 'disabled' : ''} onclick="window._goToPage(${pagination.page + 1})">&raquo;</button>`;
        controls.innerHTML = btns;
    }

    function renderTeamMemberCheckboxes(containerId, selectedIds) {
        const container = document.getElementById(containerId);
        if (!container) return;

        if (teamMembers.length === 0) {
            container.innerHTML = '<span style="color: var(--text-secondary); font-size: 0.85rem;">No team members available.</span>';
            return;
        }

        container.innerHTML = teamMembers.map(m => `
            <label style="display:flex;align-items:center;gap:6px;padding:4px 10px;border-radius:var(--radius-md);background:var(--surface);border:1px solid var(--border);cursor:pointer;font-size:0.85rem;white-space:nowrap;">
                <input type="checkbox" value="${m.userID}" ${selectedIds.includes(m.userID) ? 'checked' : ''} style="accent-color:var(--primary);" />
                <span class="team-avatar" style="width:22px;height:22px;font-size:0.6rem;background:${m.avatarColor || '#0B4F6C'}">${esc(m.initials)}</span>
                ${esc(m.fullName)} <span style="color:var(--text-secondary);font-size:0.75rem;">(${esc(m.role)})</span>
            </label>
        `).join('');
    }

    function getSelectedMembers(containerId) {
        const container = document.getElementById(containerId);
        if (!container) return [];
        return Array.from(container.querySelectorAll('input[type="checkbox"]:checked')).map(cb => parseInt(cb.value));
    }

    // =================== Helpers ===================
    function openModal(id) { document.getElementById(id)?.classList.add('active'); }
    function closeModal(id) { document.getElementById(id)?.classList.remove('active'); }

    function getStatusClass(status) {
        const map = { 'Planning': 'planning', 'In Progress': 'in-progress', 'Review': 'review', 'Completed': 'completed', 'Delayed': 'delayed', 'Archived': 'archived' };
        return map[status] || 'planning';
    }

    function esc(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function formatDate(dateStr) {
        const d = new Date(dateStr);
        return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    }

    // =================== Global Handlers ===================
    async function restoreProject(projectId) {
        if (!confirm('Restore this project from archive?')) return;
        try {
            const res = await fetch(`/api/projects/${projectId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'same-origin',
                body: JSON.stringify({ status: 'Planning' })
            });
            const result = await res.json();
            if (result.success) {
                showToast('Project restored successfully.', 'success');
                if (IS_ADMIN) loadStats();
                loadProjects();
            } else {
                showToast(result.message || 'Failed to restore project.', 'error');
            }
        } catch (e) { console.error('Error:', e); alert('An error occurred.'); }
    }

    window._viewProject = viewProject;
    window._editProject = CAN_CREATE ? openEditModal : function() {};
    window._archiveProject = CAN_ARCHIVE ? archiveProject : function() {};
    window._restoreProject = CAN_ARCHIVE ? restoreProject : function() {};
    window._goToPage = function(page) { currentPage = page; loadProjects(); };
    window.promptAddCategory = promptAddCategory;
    window.openAddCategoryModal = window.openAddCategoryModal;
})();
</script>
}
