@{
    ViewData["Title"] = "Payments";
    ViewData["UserRole"] = "superadmin";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/payments.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/superadmin.css" asp-append-version="true" />
}

<div class="page-payments">
    <!-- Payment Stats -->
    <section class="payment-stats">
        <div class="stat-card">
            <div class="stat-content">
                <span class="stat-label">Total Revenue (This Month)</span>
                <span class="stat-value" id="stat-revenue">₱0</span>
            </div>
            <div class="stat-trend positive" id="stat-trend">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
                    <polyline points="17 6 23 6 23 12"></polyline>
                </svg>
                <span id="stat-trend-text">--</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-content">
                <span class="stat-label">Pending Payments</span>
                <span class="stat-value warning" id="stat-pending">₱0</span>
            </div>
            <span class="stat-count" id="stat-pending-count">0 invoices</span>
        </div>
        <div class="stat-card">
            <div class="stat-content">
                <span class="stat-label">Overdue</span>
                <span class="stat-value danger" id="stat-overdue">₱0</span>
            </div>
            <span class="stat-count" id="stat-overdue-count">0 invoices</span>
        </div>
        <div class="stat-card">
            <div class="stat-content">
                <span class="stat-label">Collected (This Month)</span>
                <span class="stat-value success" id="stat-collected">₱0</span>
            </div>
            <span class="stat-count" id="stat-collected-count">0 payments</span>
        </div>
    </section>

    <!-- Filters -->
    <section class="filters-section">
        <div class="filter-tabs">
            <button class="filter-tab active" data-status="">All</button>
            <button class="filter-tab" data-status="Pending">Pending</button>
            <button class="filter-tab" data-status="Completed">Completed</button>
            <button class="filter-tab" data-status="Failed">Failed</button>
        </div>
        <div class="filter-actions">
            <input type="text" class="search-input" id="payment-search" placeholder="Search company or invoice..."
                   style="padding:8px 12px; border:1px solid var(--border); border-radius:6px; background:var(--bg-primary); color:var(--text-primary); font-size:0.9rem; min-width:200px;" />
            <input type="month" class="date-filter" id="date-filter" />
        </div>
    </section>

    <!-- Payments Table -->
    <section class="payments-table-section">
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Invoice</th>
                        <th>Company</th>
                        <th>Amount</th>
                        <th>Provider</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody id="payments-tbody">
                    <tr>
                        <td colspan="6" style="text-align:center; padding:40px;">Loading...</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="table-footer" id="payments-pagination">
        </div>
    </section>
</div>

<!-- Payment Detail Modal -->
<div class="modal-overlay" id="payment-detail-modal">
    <div class="modal" style="max-width:500px;">
        <div class="modal-header">
            <h3 class="modal-title">Payment Details</h3>
            <button class="modal-close"
                    onclick="document.getElementById('payment-detail-modal').classList.remove('active')">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body" id="payment-detail-body" style="padding:24px;">
            <p>Loading...</p>
        </div>
    </div>
</div>

@section PageScripts {
    <script>
                                document.addEventListener('DOMContentLoaded', function () {
                                    let currentPage = 1;
                                    let currentStatus = '';
                                    let currentSearch = '';
                                    let filterYear = null;
                                    let filterMonth = null;

                                    // Set default date filter to current month
                                    const dateFilter = document.getElementById('date-filter');
                                    const now = new Date();
                                    dateFilter.value = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;

                                    loadPaymentStats();
                                    loadPayments();

                                    // Filter tab clicks
                                    document.querySelectorAll('.filter-tab').forEach(tab => {
                                        tab.addEventListener('click', function () {
                                            document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
                                            this.classList.add('active');
                                            currentStatus = this.dataset.status || '';
                                            currentPage = 1;
                                            loadPayments();
                                        });
                                    });

                                    // Search input
                                    const searchInput = document.getElementById('payment-search');
                                    if (searchInput) {
                                        let timeout;
                                        searchInput.addEventListener('input', function () {
                                            clearTimeout(timeout);
                                            timeout = setTimeout(() => {
                                                currentSearch = this.value;
                                                currentPage = 1;
                                                loadPayments();
                                            }, 300);
                                        });
                                    }

                                    // Date filter
                                    dateFilter.addEventListener('change', function () {
                                        if (this.value) {
                                            const parts = this.value.split('-');
                                            filterYear = parseInt(parts[0]);
                                            filterMonth = parseInt(parts[1]);
                                        } else {
                                            filterYear = null;
                                            filterMonth = null;
                                        }
                                        currentPage = 1;
                                        loadPayments();
                                        loadPaymentStats();
                                    });

                                    async function loadPaymentStats() {
                                        const params = new URLSearchParams();
                                        if (filterYear) params.append('year', filterYear);
                                        if (filterMonth) params.append('month', filterMonth);

                                        try {
                                            const res = await fetch(`/api/superadmin/payments/stats?${params}`, { credentials: 'same-origin' });
                                            const result = await res.json();
                                            if (result.success) {
                                                const d = result.data;
                                                document.getElementById('stat-revenue').textContent = '₱' + formatNum(d.totalRevenue);
                                                document.getElementById('stat-pending').textContent = '₱' + formatNum(d.pendingAmount);
                                                document.getElementById('stat-overdue').textContent = '₱' + formatNum(d.overdueAmount);
                                                document.getElementById('stat-collected').textContent = '₱' + formatNum(d.collectedAmount);
                                                document.getElementById('stat-pending-count').textContent = d.pendingCount + ' invoices';
                                                document.getElementById('stat-overdue-count').textContent = d.overdueCount + ' invoices';
                                                document.getElementById('stat-collected-count').textContent = d.completedCount + ' payments';
                                            }
                                        } catch (e) { console.error('Error loading payment stats:', e); }
                                    }

                                    async function loadPayments() {
                                        const params = new URLSearchParams({ page: currentPage, pageSize: 10 });
                                        if (currentSearch) params.append('search', currentSearch);
                                        if (currentStatus) params.append('status', currentStatus);
                                        if (filterYear) params.append('year', filterYear);
                                        if (filterMonth) params.append('month', filterMonth);

                                        try {
                                            const res = await fetch(`/api/superadmin/payments?${params}`, { credentials: 'same-origin' });
                                            const result = await res.json();
                                            if (result.success) {
                                                renderPayments(result.data);
                                                renderPagination(result.pagination);
                                            }
                                        } catch (e) { console.error('Error loading payments:', e); }
                                    }

                                    function renderPayments(payments) {
                                        const tbody = document.getElementById('payments-tbody');
                                        if (!payments || payments.length === 0) {
                                            tbody.innerHTML = '<tr><td colspan="6" style="text-align:center; padding:40px; color:var(--text-secondary);">No payments found</td></tr>';
                                            return;
                                        }

                                        tbody.innerHTML = payments.map(p => {
                                            const statusClass = p.status.toLowerCase();
                                            const isOverdue = statusClass === 'pending' && p.paidAt === null;
                                            const initials = getInitials(p.companyName);

                                            return `
                                                <tr class="clickable-row ${isOverdue ? 'overdue-row' : ''}" onclick="viewPayment(${p.paymentID})">
                                                    <td><span class="invoice-id">${esc(p.invoiceNumber || 'N/A')}</span></td>
                                                    <td>
                                                        <span class="company-name">${esc(p.companyName)}</span>
                                                    </td>
                                                    <td class="amount">₱${formatNum(p.amount)}</td>
                                                    <td>${esc(p.provider)}${p.paymentMethod ? ' / ' + esc(p.paymentMethod) : ''}</td>
                                                    <td><span class="status-indicator ${statusClass}">${esc(p.status)}</span></td>
                                                    <td>${p.paidAt ? formatDate(p.paidAt) : formatDate(p.createdAt)}</td>
                                                </tr>`;
                                        }).join('');
                                    }

                                    function renderPagination(pagination) {
                                        const footer = document.getElementById('payments-pagination');
                                        if (!footer) return;

                                        if (!pagination || pagination.totalPages <= 1) {
                                            footer.innerHTML = pagination
                                                ? `<span class="table-info">Showing ${pagination.totalCount} payment${pagination.totalCount !== 1 ? 's' : ''}</span>`
                                                : '';
                                            return;
                                        }

                                        let pagesHtml = '';
                                        for (let i = 1; i <= pagination.totalPages; i++) {
                                            pagesHtml += `<button class="page-btn ${i === pagination.page ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
                                        }

                                        const start = (pagination.page - 1) * pagination.pageSize + 1;
                                        const end = Math.min(pagination.page * pagination.pageSize, pagination.totalCount);
                                        footer.innerHTML = `
                                            <span class="table-info">Showing ${start}\u2013${end} of ${pagination.totalCount} payments</span>
                                            <div class="pagination">${pagesHtml}</div>
                                        `;
                                    }

                                    window.goToPage = function (page) {
                                        currentPage = page;
                                        loadPayments();
                                    };

                                    window.viewPayment = async function (paymentId) {
                                        const modal = document.getElementById('payment-detail-modal');
                                        const body = document.getElementById('payment-detail-body');
                                        body.innerHTML = '<p>Loading...</p>';
                                        modal.classList.add('active');

                                        try {
                                            const res = await fetch(`/api/superadmin/payments/${paymentId}`, { credentials: 'same-origin' });
                                            const result = await res.json();
                                            if (result.success) {
                                                const p = result.data.payment;
                                                body.innerHTML = `
                                                    <div style="display:grid; gap:12px;">
                                                        <div><strong>Company:</strong> ${esc(result.data.companyName)}</div>
                                                        <div><strong>Plan:</strong> ${esc(result.data.planName)}</div>
                                                        <div><strong>Invoice:</strong> ${esc(result.data.invoiceNumber || 'N/A')}</div>
                                                        <hr style="border:none; border-top:1px solid var(--border);">
                                                        <div><strong>Amount:</strong> ${p.currency} ${formatNum(p.amount)}</div>
                                                        <div><strong>Provider:</strong> ${esc(p.provider)}</div>
                                                        <div><strong>Payment Method:</strong> ${esc(p.paymentMethod || 'N/A')}</div>
                                                        <div><strong>Status:</strong> ${esc(p.status)}</div>
                                                        <div><strong>Transaction ID:</strong> ${esc(p.externalTransactionID || 'N/A')}</div>
                                                        <div><strong>Created:</strong> ${p.createdAt}</div>
                                                        <div><strong>Paid At:</strong> ${p.paidAt || 'N/A'}</div>
                                                    </div>`;
                                            } else {
                                                body.innerHTML = '<p>Error loading payment details.</p>';
                                            }
                                        } catch (e) {
                                            body.innerHTML = '<p>Error loading payment details.</p>';
                                        }
                                    };

                                    // Close modal on overlay click
                                    document.querySelectorAll('.modal-overlay').forEach(overlay => {
                                        overlay.addEventListener('click', function (e) {
                                            if (e.target === overlay) overlay.classList.remove('active');
                                        });
                                    });

                                    function getInitials(name) {
                                        if (!name) return '??';
                                        return name.split(' ').map(w => w[0]).join('').substring(0, 2).toUpperCase();
                                    }

                                    function esc(text) {
                                        if (!text) return '';
                                        const d = document.createElement('div');
                                        d.textContent = text;
                                        return d.innerHTML;
                                    }

                                    function formatNum(n) {
                                        if (n == null) return '0';
                                        return Number(n).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                                    }

                                    function formatDate(dateStr) {
                                        if (!dateStr) return '-';
                                        return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                                    }
                                });
    </script>
}