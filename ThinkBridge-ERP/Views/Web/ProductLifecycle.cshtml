@{
    ViewData["Title"] = "Product Lifecycle";
    var userRole = ViewData["UserRole"]?.ToString() ?? "teammember";
    var canManage = userRole == "projectmanager";
    var canDrag = userRole == "projectmanager" || userRole == "teammember";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/product-lifecycle.css" asp-append-version="true" />
}

<div class="page-product-lifecycle">
    <!-- Page Header -->
    <div class="page-header">
        <div class="header-filters">
            <div class="search-box">
                <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" class="search-input" id="product-search" placeholder="Search products..." />
            </div>
            <div class="filter-dropdown">
                <select class="form-select" id="project-filter"
                        style="min-width: 150px; padding: 8px 12px; border: 1px solid var(--border); border-radius: var(--radius-md); background: var(--surface); color: var(--text-primary); font-size: 0.85rem;">
                    <option value="">All Projects</option>
                </select>
            </div>
            <div class="view-toggle">
                <button class="view-btn active" data-view="kanban" onclick="switchView('kanban')" title="Kanban Board">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="5" height="18" rx="1"></rect>
                        <rect x="10" y="3" width="5" height="12" rx="1"></rect>
                        <rect x="17" y="3" width="5" height="15" rx="1"></rect>
                    </svg>
                    Board
                </button>
                <button class="view-btn" data-view="pipeline" onclick="switchView('pipeline')" title="Pipeline View">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
                    </svg>
                    Pipeline
                </button>
            </div>
        </div>
        @if (canManage)
        {
            <button class="btn btn-primary" onclick="openCreateProductModal()">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                New Product
            </button>
        }
    </div>

    <!-- Pipeline Summary Bar -->
    <div class="pipeline-summary" id="pipeline-summary">
        <div class="pipeline-loading">Loading pipeline...</div>
    </div>

    <!-- Kanban Board View -->
    <div class="kanban-board" id="kanban-board">
        <div class="kanban-loading">
            <div class="tasks-spinner"></div>
            <span>Loading board...</span>
        </div>
    </div>

    <!-- Pipeline View (hidden by default) -->
    <div class="pipeline-view" id="pipeline-view" style="display:none;">
        <div class="products-grid" id="products-grid">
            <div style="padding:40px;color:var(--text-muted);text-align:center;grid-column:1/-1;">Loading products...
            </div>
        </div>
        <div class="pagination-bar" id="pagination-bar" style="display:none;">
            <span class="pagination-info" id="pagination-info"></span>
            <div class="pagination-controls">
                <button class="btn btn-sm btn-secondary" id="prev-page" onclick="changePage(-1)">Previous</button>
                <span class="pagination-page" id="page-display"></span>
                <button class="btn btn-sm btn-secondary" id="next-page" onclick="changePage(1)">Next</button>
            </div>
        </div>
    </div>
</div>

<!-- Create/Edit Product Modal -->
<div class="modal-overlay" id="product-modal" style="display:none;">
    <div class="modal-container" style="max-width: 560px;">
        <div class="modal-header">
            <h2 class="modal-title" id="product-modal-title">New Product</h2>
            <button class="modal-close" onclick="closeProductModal()">&times;</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="edit-product-id" />
            <div class="form-group">
                <label>Product Name <span class="required">*</span></label>
                <input type="text" id="product-name" class="form-input" placeholder="Enter product name" required />
            </div>
            <div class="form-row">
                <div class="form-group" style="flex:1">
                    <label>Product Code</label>
                    <input type="text" id="product-code" class="form-input" placeholder="Auto-generated" />
                </div>
                <div class="form-group" style="flex:1">
                    <label>Linked Project</label>
                    <select id="product-project" class="form-select">
                        <option value="">None (Company-wide)</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label>Description</label>
                <textarea id="product-description" class="form-input" rows="3"
                          placeholder="Describe the product..."></textarea>
            </div>
            <div class="form-group" id="initial-stage-group" style="display:none;">
                <label>Initial Stage</label>
                <select id="product-initial-stage" class="form-select">
                    <option value="">Concept (default)</option>
                </select>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeProductModal()">Cancel</button>
            <button class="btn btn-primary" id="save-product-btn" onclick="saveProduct()">Create Product</button>
        </div>
    </div>
</div>

<!-- View Product / Advance Stage Modal -->
<div class="modal-overlay" id="view-product-modal" style="display:none;">
    <div class="modal-container" style="max-width: 700px;">
        <div class="modal-header">
            <h2 class="modal-title" id="view-product-title">Product Details</h2>
            <button class="modal-close" onclick="closeViewProductModal()">&times;</button>
        </div>
        <div class="modal-body" id="view-product-body"></div>
        <div class="modal-footer" id="view-product-footer"></div>
    </div>
</div>

<!-- Archive Confirmation Modal -->
<div class="modal-overlay" id="archive-product-modal" style="display:none;">
    <div class="modal-container" style="max-width: 420px;">
        <div class="modal-header">
            <h2 class="modal-title" style="color:var(--warning-color, #B45309);">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     style="vertical-align:middle;margin-right:6px;">
                    <polyline points="21 8 21 21 3 21 3 8"></polyline>
                    <rect x="1" y="3" width="22" height="5"></rect>
                    <line x1="10" y1="12" x2="14" y2="12"></line>
                </svg>
                Archive Product
            </h2>
            <button class="modal-close" onclick="closeArchiveModal()">&times;</button>
        </div>
        <div class="modal-body">
            <p style="margin-bottom:8px;">Are you sure you want to archive <strong id="archive-product-name"></strong>?
            </p>
            <p style="font-size:0.82rem;color:var(--text-muted);">The product will be moved to the archive and hidden from active views. You can restore it later.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeArchiveModal()">Cancel</button>
                <button class="btn btn-warning" onclick="confirmArchiveProduct()">Archive Product</button>
            </div>
        </div>
    </div>

    <script>
        const userRole = '@userRole';
        const canManage = @(canManage ? "true" : "false");
        const canDrag = @(canDrag ? "true" : "false");

        let currentPage = 1;
        let totalPages = 1;
        let lifecycleStages = [];
        let allProjects = [];
        let archiveProductId = null;
        let currentView = 'kanban';
        let draggedCard = null;

        // Stage color configuration
        const stageColors = {
            'Concept': { bg: '#DBEAFE', color: '#1E40AF', border: '#93C5FD' },
            'Design': { bg: '#EDE9FE', color: '#6D28D9', border: '#C4B5FD' },
            'Development': { bg: '#FEF3C7', color: '#B45309', border: '#FCD34D' },
            'Testing': { bg: '#FEF9C3', color: '#92400E', border: '#FDE68A' },
            'Production': { bg: '#D1FAE5', color: '#065F46', border: '#6EE7B7' }
        };

        document.addEventListener('DOMContentLoaded', () => {
            loadStages();
            loadProjects();

            let searchTimer;
            document.getElementById('product-search').addEventListener('input', () => {
                clearTimeout(searchTimer);
                searchTimer = setTimeout(() => { currentPage = 1; refreshCurrentView(); }, 400);
            });
            document.getElementById('project-filter').addEventListener('change', () => {
                currentPage = 1;
                refreshCurrentView();
            });
        });

        function switchView(view) {
            currentView = view;
            document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
            document.querySelector(`.view-btn[data-view="${view}"]`).classList.add('active');

            if (view === 'kanban') {
                document.getElementById('kanban-board').style.display = '';
                document.getElementById('pipeline-view').style.display = 'none';
                document.getElementById('pipeline-summary').style.display = 'none';
                loadKanbanBoard();
            } else {
                document.getElementById('kanban-board').style.display = 'none';
                document.getElementById('pipeline-view').style.display = '';
                document.getElementById('pipeline-summary').style.display = '';
                loadProducts();
            }
        }

        function refreshCurrentView() {
            if (currentView === 'kanban') {
                document.getElementById('pipeline-summary').style.display = 'none';
                loadKanbanBoard();
            } else {
                document.getElementById('pipeline-summary').style.display = '';
                loadPipelineSummary();
                loadProducts();
            }
        }

        async function loadStages() {
            try {
                const res = await fetch('/api/products/stages');
                const json = await res.json();
                if (json.success) {
                    lifecycleStages = json.data;
                }
            } catch (e) { console.error('Failed to load stages', e); }
            // After stages load, load the board (kanban is default, so hide pipeline summary)
            document.getElementById('pipeline-summary').style.display = 'none';
            loadKanbanBoard();
        }

        async function loadProjects() {
            try {
                const res = await fetch('/api/projects?pageSize=100');
                const json = await res.json();
                if (json.success) {
                    allProjects = json.data;
                    const projFilter = document.getElementById('project-filter');
                    const projSelect = document.getElementById('product-project');
                    allProjects.forEach(p => {
                        const optHtml = `<option value="${p.projectID}">${escapeHtml(p.projectName)}</option>`;
                        projFilter.innerHTML += optHtml;
                        if (projSelect) projSelect.innerHTML += optHtml;
                    });
                }
            } catch (e) { console.error('Failed to load projects', e); }
        }

        // ========== Pipeline Summary ==========
        async function loadPipelineSummary() {
            const projectId = document.getElementById('project-filter')?.value;
            let url = '/api/products/pipeline';
            if (projectId) url += `?projectId=${projectId}`;

            try {
                const res = await fetch(url);
                const json = await res.json();
                if (json.success) renderPipelineSummary(json.data);
            } catch (e) { console.error('Failed to load pipeline', e); }
        }

        function renderPipelineSummary(stages) {
            const container = document.getElementById('pipeline-summary');
            if (!stages || stages.length === 0) {
                container.innerHTML = '<div class="pipeline-loading">No stages defined.</div>';
                return;
            }

            const totalProducts = stages.reduce((sum, s) => sum + s.productCount, 0);

            container.innerHTML = `
                        <div class="pipeline-stats">
                            <div class="pipeline-stat-total">
                                <span class="stat-number">${totalProducts}</span>
                                <span class="stat-label">Total Products</span>
                            </div>
                            <div class="pipeline-stage-chips">
                                ${stages.map((s, i) => {
                const colors = stageColors[s.stageName] || stageColors['Concept'];
                return `
                                        <div class="stage-chip ${s.productCount > 0 ? 'has-products' : ''}" style="--chip-bg:${colors.bg};--chip-color:${colors.color};--chip-border:${colors.border};">
                                            <div class="chip-top">
                                                <span class="chip-name">${escapeHtml(s.stageName)}</span>
                                                <span class="chip-count">${s.productCount}</span>
                                            </div>
                                        </div>
                                        ${i < stages.length - 1 ? '<div class="chip-connector"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg></div>' : ''}`;
            }).join('')}
                            </div>
                        </div>`;
        }

        // ========== Kanban Board ==========
        async function loadKanbanBoard() {
            const projectId = document.getElementById('project-filter')?.value;
            const search = document.getElementById('product-search')?.value;
            let url = '/api/products/pipeline';
            if (projectId) url += `?projectId=${projectId}`;

            try {
                const res = await fetch(url);
                const json = await res.json();
                if (json.success) renderKanbanBoard(json.data, search);
            } catch (e) {
                console.error('Failed to load kanban', e);
                document.getElementById('kanban-board').innerHTML = '<div class="kanban-loading">Error loading board.</div>';
            }
        }

        function renderKanbanBoard(stages, searchTerm) {
            const board = document.getElementById('kanban-board');
            if (!stages || stages.length === 0) {
                board.innerHTML = '<div class="kanban-loading">No lifecycle stages configured.</div>';
                return;
            }

            board.innerHTML = stages.map(stage => {
                const colors = stageColors[stage.stageName] || stageColors['Concept'];
                let products = stage.products || [];

                // Client-side search filter
                if (searchTerm) {
                    const term = searchTerm.toLowerCase();
                    products = products.filter(p =>
                        p.productName.toLowerCase().includes(term) ||
                        (p.productCode && p.productCode.toLowerCase().includes(term)) ||
                        (p.projectName && p.projectName.toLowerCase().includes(term))
                    );
                }

                const cardsHtml = products.length > 0
                    ? products.map(p => renderKanbanCard(p, stage, colors)).join('')
                    : `<div class="kanban-empty">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:0.3;">
                                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                        <line x1="12" y1="8" x2="12" y2="16"></line>
                                        <line x1="8" y1="12" x2="16" y2="12"></line>
                                    </svg>
                                    <span>No products</span>
                               </div>`;

                return `
                            <div class="kanban-column" data-stage-id="${stage.stageID}" data-stage-name="${escapeHtml(stage.stageName)}">
                                <div class="column-header" style="border-bottom-color: ${colors.border};">
                                    <div class="column-header-left">
                                        <span class="column-title">${escapeHtml(stage.stageName)}</span>
                                    </div>
                                    <span class="column-count" style="background:${colors.bg};color:${colors.color};">${products.length}</span>
                                </div>
                                <div class="column-content" data-stage-id="${stage.stageID}" data-stage-name="${escapeHtml(stage.stageName)}"
                                     ondragover="handleDragOver(event)" ondrop="handleDrop(event, ${stage.stageID})" ondragleave="handleDragLeave(event)">
                                    ${cardsHtml}
                                </div>
                            </div>`;
            }).join('');
        }

        function renderKanbanCard(product, stage, colors) {
            const draggable = canDrag ? 'draggable="true"' : '';
            const stageOrder = stage.stageOrder || 0;

            const progressSteps = lifecycleStages.map(s => {
                let cls = 'k-progress-step';
                if (s.stageOrder < stageOrder) cls += ' done';
                else if (s.stageOrder === stageOrder) cls += ' active';
                return `<div class="${cls}"></div>`;
            }).join('');

            let actionsHtml = '';
            if (canManage) {
                actionsHtml = `
                            <div class="k-card-actions" onclick="event.stopPropagation()">
                                <button class="k-action-btn" onclick="openEditProductModal(${product.productID})" title="Edit">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                </button>
                                <button class="k-action-btn danger" onclick="openArchiveModal(${product.productID}, '${escapeHtml(product.productName).replace(/'/g, "\\'")}')" title="Archive">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="21 8 21 21 3 21 3 8"></polyline><rect x="1" y="3" width="22" height="5"></rect><line x1="10" y1="12" x2="14" y2="12"></line></svg>
                                </button>
                            </div>`;
            }

            return `
                        <div class="kanban-card" ${draggable} data-product-id="${product.productID}"
                             onclick="viewProduct(${product.productID})"
                             ondragstart="handleDragStart(event, ${product.productID})" ondragend="handleDragEnd(event)">
                            <div class="k-card-top">
                                <span class="k-card-code">${escapeHtml(product.productCode || '')}</span>
                                ${actionsHtml}
                            </div>
                            <div class="k-card-title">${escapeHtml(product.productName)}</div>
                            ${product.projectName ? `<div class="k-card-project"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg> ${escapeHtml(product.projectName)}</div>` : ''}
                            <div class="k-card-progress">
                                ${progressSteps}
                            </div>
                        </div>`;
        }

        // ========== Drag & Drop ==========
        function handleDragStart(event, productId) {
            draggedCard = productId;
            event.dataTransfer.effectAllowed = 'move';
            event.dataTransfer.setData('text/plain', productId);
            event.target.classList.add('dragging');
        }

        function handleDragEnd(event) {
            event.target.classList.remove('dragging');
            document.querySelectorAll('.column-content').forEach(c => c.classList.remove('drag-over'));
            draggedCard = null;
        }

        function handleDragOver(event) {
            event.preventDefault();
            event.dataTransfer.dropEffect = 'move';
            event.currentTarget.classList.add('drag-over');
        }

        function handleDragLeave(event) {
            event.currentTarget.classList.remove('drag-over');
        }

        async function handleDrop(event, targetStageId) {
            event.preventDefault();
            event.currentTarget.classList.remove('drag-over');

            const productId = parseInt(event.dataTransfer.getData('text/plain'));
            if (!productId || !canDrag) return;

            // Find the current card's stage
            const card = document.querySelector(`.kanban-card[data-product-id="${productId}"]`);
            const currentColumn = card?.closest('.column-content');
            const currentStageId = currentColumn ? parseInt(currentColumn.dataset.stageId) : null;

            if (currentStageId === targetStageId) return; // No change

            try {
                const res = await fetch(`/api/products/${productId}/advance`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ stageId: targetStageId, remarks: 'Moved via Kanban board' })
                });
                const json = await res.json();
                if (json.success) {
                    showToast('Product stage updated successfully', 'success');
                    refreshCurrentView();
                } else {
                    showToast(json.message || 'Failed to update stage', 'error');
                }
            } catch (e) {
                showToast('Failed to update product stage', 'error');
            }
        }

        // ========== Pipeline / Grid View ==========
        async function loadProducts() {
            const search = document.getElementById('product-search').value;
            const projectId = document.getElementById('project-filter').value;

            let url = `/api/products?page=${currentPage}&pageSize=20`;
            if (search) url += `&search=${encodeURIComponent(search)}`;
            if (projectId) url += `&projectId=${projectId}`;

            try {
                const res = await fetch(url);
                const json = await res.json();
                if (json.success) {
                    renderProducts(json.data);
                    totalPages = json.pagination.totalPages || 1;
                    renderPagination(json.pagination);
                }
            } catch (e) {
                console.error('Failed to load products', e);
                document.getElementById('products-grid').innerHTML = '<div style="padding:40px;color:var(--text-muted);text-align:center;grid-column:1/-1;">Error loading products.</div>';
            }
        }

        function renderProducts(products) {
            const grid = document.getElementById('products-grid');
            if (!products || products.length === 0) {
                grid.innerHTML = `<div style="padding:60px 20px;color:var(--text-secondary);text-align:center;grid-column:1/-1;">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:0.3;margin-bottom:16px;">
                                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                            </svg>
                            <p>No products found</p>
                        </div>`;
                return;
            }

            grid.innerHTML = products.map(p => {
                const colors = stageColors[p.currentStage] || stageColors['Concept'];
                const stageOrder = p.currentStageOrder || 0;

                const progressSteps = lifecycleStages.map(s => {
                    let cls = 'stage-progress-step';
                    if (s.stageOrder < stageOrder) cls += ' completed';
                    else if (s.stageOrder === stageOrder) cls += ' current';
                    return `<div class="${cls}"></div>`;
                }).join('');

                let actionsHtml = '';
                if (canManage) {
                    actionsHtml = `
                                <div class="action-btns" onclick="event.stopPropagation()">
                                    <button class="card-action-btn" onclick="openEditProductModal(${p.productID})" title="Edit">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                    </button>
                                    <button class="card-action-btn delete" onclick="openArchiveModal(${p.productID}, '${escapeHtml(p.productName).replace(/'/g, "\\'")}')" title="Archive">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="21 8 21 21 3 21 3 8"></polyline><rect x="1" y="3" width="22" height="5"></rect><line x1="10" y1="12" x2="14" y2="12"></line></svg>
                                    </button>
                                </div>`;
                }

                return `
                            <div class="product-card" onclick="viewProduct(${p.productID})">
                                <div class="product-card-header">
                                    <div class="product-card-icon" style="background:${colors.bg};color:${colors.color};">
                                    </div>
                                    <div style="flex:1;min-width:0;">
                                        <div class="product-card-title">${escapeHtml(p.productName)}</div>
                                        <div class="product-card-code">${escapeHtml(p.productCode || '')}</div>
                                    </div>
                                    <span class="stage-badge" style="background:${colors.bg};color:${colors.color};">${escapeHtml(p.currentStage)}</span>
                                </div>
                                ${p.description ? `<div class="product-card-desc">${escapeHtml(p.description)}</div>` : ''}
                                <div class="product-stage-progress">
                                    <div class="stage-progress-bar">${progressSteps}</div>
                                </div>
                                <div class="product-card-footer">
                                    <div class="product-card-project">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
                                        ${p.projectName ? escapeHtml(p.projectName) : 'Company-wide'}
                                    </div>
                                    ${actionsHtml}
                                </div>
                            </div>`;
            }).join('');
        }

        function renderPagination(p) {
            const bar = document.getElementById('pagination-bar');
            if (p.totalCount === 0) { bar.style.display = 'none'; return; }
            bar.style.display = 'flex';
            document.getElementById('pagination-info').textContent = `Showing ${(p.page - 1) * p.pageSize + 1}-${Math.min(p.page * p.pageSize, p.totalCount)} of ${p.totalCount}`;
            document.getElementById('page-display').textContent = `Page ${p.page} of ${p.totalPages}`;
            document.getElementById('prev-page').disabled = p.page <= 1;
            document.getElementById('next-page').disabled = p.page >= p.totalPages;
        }

        function changePage(delta) {
            currentPage = Math.max(1, Math.min(totalPages, currentPage + delta));
            loadProducts();
        }

        // ========== Modals ==========
        function openCreateProductModal() {
            document.getElementById('product-modal-title').textContent = 'New Product';
            document.getElementById('save-product-btn').textContent = 'Create Product';
            document.getElementById('edit-product-id').value = '';
            document.getElementById('product-name').value = '';
            document.getElementById('product-code').value = '';
            document.getElementById('product-project').value = '';
            document.getElementById('product-description').value = '';
            document.getElementById('product-modal').style.display = 'flex';
        }

        async function openEditProductModal(productId) {
            try {
                const res = await fetch(`/api/products/${productId}`);
                const json = await res.json();
                if (!json.success) { showToast(json.message, 'error'); return; }
                const p = json.data;

                document.getElementById('product-modal-title').textContent = 'Edit Product';
                document.getElementById('save-product-btn').textContent = 'Save Changes';
                document.getElementById('edit-product-id').value = p.productID;
                document.getElementById('product-name').value = p.productName;
                document.getElementById('product-code').value = p.productCode || '';
                document.getElementById('product-project').value = p.projectID || '';
                document.getElementById('product-description').value = p.description || '';
                document.getElementById('product-modal').style.display = 'flex';
            } catch (e) { showToast('Failed to load product.', 'error'); }
        }

        function closeProductModal() { document.getElementById('product-modal').style.display = 'none'; }

        async function saveProduct() {
            const productId = document.getElementById('edit-product-id').value;
            const isEditing = !!productId;
            const name = document.getElementById('product-name').value.trim();
            if (!name) { showToast('Product name is required.', 'error'); return; }

            const payload = {
                productName: name,
                productCode: document.getElementById('product-code').value.trim() || null,
                projectID: parseInt(document.getElementById('product-project').value) || null,
                description: document.getElementById('product-description').value
            };

            const btn = document.getElementById('save-product-btn');
            btn.disabled = true;
            btn.innerHTML = '<span class="btn-spinner"></span> Saving...';

            try {
                const url = isEditing ? `/api/products/${productId}` : '/api/products';
                const method = isEditing ? 'PUT' : 'POST';
                const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
                const json = await res.json();
                if (json.success) {
                    closeProductModal();
                    showToast(isEditing ? 'Product updated successfully' : 'Product created successfully', 'success');
                    refreshCurrentView();
                } else {
                    showToast(json.message || 'An error occurred.', 'error');
                }
            } catch (e) { showToast('An error occurred.', 'error'); }
            finally {
                btn.disabled = false;
                btn.innerHTML = isEditing ? 'Save Changes' : 'Create Product';
            }
        }

        async function viewProduct(productId) {
            try {
                const res = await fetch(`/api/products/${productId}`);
                const json = await res.json();
                if (!json.success) { showToast(json.message, 'error'); return; }
                const p = json.data;
                const colors = stageColors[p.currentStage] || stageColors['Concept'];

                let html = `
                            <div class="view-product-header">
                                <div class="view-product-icon" style="background:${colors.bg};color:${colors.color};">
                                </div>
                                <div>
                                    <div style="font-size:0.78rem;color:var(--text-muted);font-family:var(--font-mono);">${escapeHtml(p.productCode || 'N/A')}</div>
                                    <span class="stage-badge" style="background:${colors.bg};color:${colors.color};margin-top:4px;display:inline-block;">${escapeHtml(p.currentStage)}</span>
                                </div>
                            </div>

                            <div class="view-product-details">
                                <div class="detail-grid">
                                    <div class="detail-item">
                                        <div class="detail-label">Project</div>
                                        <div class="detail-value">${p.projectName ? escapeHtml(p.projectName) : '<span style="color:var(--text-muted);">Company-wide</span>'}</div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label">Created</div>
                                        <div class="detail-value">${new Date(p.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</div>
                                    </div>
                                </div>
                                ${p.description ? `<div class="detail-item" style="margin-top:12px;"><div class="detail-label">Description</div><div class="detail-value">${escapeHtml(p.description)}</div></div>` : ''}
                            </div>

                            <div class="view-stage-progress">
                                <div class="detail-label" style="margin-bottom:10px;">Stage Progress</div>
                                <div class="stage-timeline">
                                    ${lifecycleStages.map(s => {
                    const sc = stageColors[s.stageName] || stageColors['Concept'];
                    let status = 'pending';
                    if (s.stageOrder < p.currentStageOrder) status = 'done';
                    else if (s.stageOrder === p.currentStageOrder) status = 'current';
                    return `<div class="timeline-step ${status}">
                                            <div class="timeline-dot" style="${status === 'current' ? `background:${sc.color};box-shadow:0 0 0 4px ${sc.bg};` : ''}"></div>
                                            <span class="timeline-label">${escapeHtml(s.stageName)}</span>
                                        </div>`;
                }).join('')}
                                </div>
                            </div>`;

                // History
                if (p.history && p.history.length > 0) {
                    html += `
                                <div class="view-history-section">
                                    <div class="detail-label" style="margin-bottom:10px;">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:4px;">
                                            <circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>
                                        </svg>
                                        Lifecycle History
                                    </div>
                                    <div class="history-timeline">
                                        ${p.history.map(h => {
                        const hc = stageColors[h.stageName] || stageColors['Concept'];
                        return `<div class="history-entry">
                                                <div class="history-dot" style="background:${hc.color};"></div>
                                                <div class="history-body">
                                                    <div class="history-stage-name">${escapeHtml(h.stageName)}</div>
                                                    <div class="history-meta">${escapeHtml(h.changedByName)} &middot; ${new Date(h.changedAt).toLocaleString()}</div>
                                                    ${h.remarks ? `<div class="history-remark">${escapeHtml(h.remarks)}</div>` : ''}
                                                </div>
                                            </div>`;
                    }).join('')}
                                    </div>
                                </div>`;
                }

                // Advance stage section (PM and TM can advance)
                if (canDrag) {
                    const currentIdx = lifecycleStages.findIndex(s => s.stageName === p.currentStage);
                    const nextStages = lifecycleStages.filter((s, i) => i > currentIdx);

                    if (nextStages.length > 0) {
                        html += `
                                    <div class="advance-section">
                                        <div class="detail-label" style="margin-bottom:10px;">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:4px;">
                                                <line x1="12" y1="19" x2="12" y2="5"></line><polyline points="5 12 12 5 19 12"></polyline>
                                            </svg>
                                            Advance Stage
                                        </div>
                                        <div class="advance-controls">
                                            <select id="advance-stage-select" class="form-select" style="flex:0 0 auto;width:auto;min-width:160px;">
                                                ${nextStages.map(s => `<option value="${s.stageID}">${escapeHtml(s.stageName)}</option>`).join('')}
                                            </select>
                                            <input type="text" id="advance-remarks" class="form-input" style="flex:1;min-width:180px;" placeholder="Remarks (optional)" />
                                            <button class="btn btn-success" onclick="advanceStage(${p.productID})">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="19" x2="12" y2="5"></line><polyline points="5 12 12 5 19 12"></polyline></svg>
                                                Advance
                                            </button>
                                        </div>
                                    </div>`;
                    }
                }

                document.getElementById('view-product-title').textContent = p.productName;
                document.getElementById('view-product-body').innerHTML = html;

                let footerBtns = `<button class="btn btn-secondary" onclick="closeViewProductModal()">Close</button>`;
                if (canManage) {
                    footerBtns = `
                                <button class="btn btn-secondary" onclick="closeViewProductModal()">Close</button>
                                <button class="btn btn-primary" onclick="closeViewProductModal(); openEditProductModal(${p.productID});">Edit Product</button>`;
                }
                document.getElementById('view-product-footer').innerHTML = footerBtns;
                document.getElementById('view-product-modal').style.display = 'flex';
            } catch (e) { showToast('Failed to load product details.', 'error'); }
        }

        async function advanceStage(productId) {
            const stageId = parseInt(document.getElementById('advance-stage-select').value);
            const remarks = document.getElementById('advance-remarks').value;

            try {
                const res = await fetch(`/api/products/${productId}/advance`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ stageId, remarks })
                });
                const json = await res.json();
                if (json.success) {
                    closeViewProductModal();
                    showToast('Product advanced to new stage', 'success');
                    refreshCurrentView();
                } else { showToast(json.message, 'error'); }
            } catch (e) { showToast('Failed to advance stage.', 'error'); }
        }

        function closeViewProductModal() { document.getElementById('view-product-modal').style.display = 'none'; }

        function openArchiveModal(productId, productName) {
            archiveProductId = productId;
            document.getElementById('archive-product-name').textContent = productName;
            document.getElementById('archive-product-modal').style.display = 'flex';
        }

        function closeArchiveModal() { document.getElementById('archive-product-modal').style.display = 'none'; archiveProductId = null; }

        async function confirmArchiveProduct() {
            if (!archiveProductId) return;
            try {
                const res = await fetch(`/api/products/${archiveProductId}/archive`, { method: 'POST' });
                const json = await res.json();
                if (json.success) {
                    closeArchiveModal();
                    showToast('Product archived successfully', 'success');
                    refreshCurrentView();
                } else { showToast(json.message, 'error'); }
            } catch (e) { showToast('Failed to archive product.', 'error'); }
        }

        // ========== Helpers ==========
        function showToast(message, type = 'info') {
            if (typeof window.showToast === 'function' && window.showToast !== showToast) {
                window.showToast(message, type);
                return;
            }
            const toast = document.createElement('div');
            toast.className = `plc-toast plc-toast-${type}`;
            toast.textContent = message;
            document.body.appendChild(toast);
            requestAnimationFrame(() => toast.classList.add('visible'));
            setTimeout(() => {
                toast.classList.remove('visible');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }
    </script>