@{
    ViewData["Title"] = "Reports";
    var userRole = ViewData["UserRole"]?.ToString() ?? "projectmanager";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/superadmin-reports.css" asp-append-version="true" />
    <style>
        /* ── Section Spacing ── */
        .report-section { margin-bottom: var(--spacing-xl); }
        .report-section-title {
            font-size: 1rem; font-weight: 700;
            color: var(--text-primary); margin: 0 0 var(--spacing-md) 0;
        }
        .report-section-sub { font-size: 0.78rem; color: var(--text-secondary); margin-top: 2px; }

        /* ── Doughnut + Legend ── */
        .doughnut-legend { display: grid; grid-template-columns: 1fr 1fr; gap: 8px 24px; margin-top: var(--spacing-md); }
        .legend-item { display: flex; align-items: center; justify-content: space-between; font-size: 0.82rem; color: var(--text-secondary); }
        .legend-left { display: flex; align-items: center; gap: 8px; }
        .legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
        .legend-count { font-weight: 700; color: var(--text-primary); font-size: 0.88rem; }

        /* ── Tables ── */
        .pm-table { width: 100%; border-collapse: collapse; }
        .pm-table th {
            text-align: left; font-size: 0.75rem; font-weight: 600;
            text-transform: uppercase; letter-spacing: 0.5px;
            color: var(--text-secondary); padding: 12px 16px;
            border-bottom: 1px solid var(--border);
        }
        .pm-table td { padding: 12px 16px; font-size: 0.88rem; border-bottom: 1px solid var(--border-light); vertical-align: middle; }
        .pm-table tbody tr:last-child td { border-bottom: none; }

        .team-member-cell { display: flex; align-items: center; gap: 10px; }
        .team-avatar-sm {
            width: 34px; height: 34px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-weight: 700; font-size: 0.75rem; flex-shrink: 0;
        }
        .progress-bar-cell { display: flex; align-items: center; gap: 8px; }
        .progress-track { height: 6px; background: var(--background); border-radius: 3px; overflow: hidden; flex: 1; min-width: 60px; }
        .progress-fill { height: 100%; border-radius: 3px; }
        .progress-label-sm { font-size: 0.82rem; font-weight: 600; min-width: 36px; text-align: right; }

        /* ── Status Badge ── */
        .status-badge {
            display: inline-flex; align-items: center; gap: 6px;
            font-weight: 500; font-size: 0.82rem;
        }
        .status-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

        /* ── Filter row ── */
        .filter-row { display: flex; align-items: center; gap: var(--spacing-sm); flex-wrap: wrap; }

        /* ── Responsive ── */
        @@media (max-width: 768px) {
            .doughnut-legend { grid-template-columns: 1fr; }
            .pm-table { font-size: 0.82rem; }
        }
    </style>
}

<div class="page-reports">
    <!-- Header actions -->
    <div class="report-header" style="justify-content:flex-end;">
        <div class="report-header-actions">
            <div class="filter-row">
                <div class="date-filter">
                    <label for="dateFrom">From</label>
                    <input type="date" id="dateFrom" class="filter-select" />
                    <label for="dateTo">To</label>
                    <input type="date" id="dateTo" class="filter-select" />
                </div>
                <button class="btn-generate" onclick="applyFilter()">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
                    </svg>
                    Filter
                </button>
            </div>
            <button class="btn-print" onclick="printReport()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="6 9 6 2 18 2 18 9"></polyline>
                    <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
                    <rect x="6" y="14" width="12" height="8"></rect>
                </svg>
                Print
            </button>
            <button class="btn-print" onclick="downloadPDF()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                PDF
            </button>
        </div>
    </div>

    <!-- Loading -->
    <div class="report-loading" id="report-loading">Loading report data...</div>

    <!-- All-in-one Report Content -->
    <div id="report-content" style="display:none;">

        <!-- ── KPI Summary Cards ── -->
        <div class="report-kpi-grid" id="kpi-grid"></div>

        <!-- ── Charts: Project Status + Task Distribution ── -->
        <div class="report-section">
            <div class="report-chart-grid">
                <div class="report-chart-card">
                    <h3 class="report-section-title">Project Status</h3>
                    <div class="report-section-sub" id="project-count-label">Distribution of projects</div>
                    <div class="report-chart-container" style="height:220px;margin-top:var(--spacing-md);">
                        <canvas id="project-status-chart"></canvas>
                    </div>
                    <div class="doughnut-legend" id="project-legend"></div>
                </div>
                <div class="report-chart-card">
                    <h3 class="report-section-title">Task Summary</h3>
                    <div class="report-section-sub">Breakdown of all tasks by current status</div>
                    <div class="report-chart-container" style="height:220px;margin-top:var(--spacing-md);">
                        <canvas id="task-chart"></canvas>
                    </div>
                    <div class="doughnut-legend" id="task-legend"></div>
                </div>
            </div>
        </div>

        <!-- ── Project Details Table ── -->
        <div class="report-section">
            <div class="report-chart-card">
                <h3 class="report-section-title">Project Details</h3>
                <div class="report-section-sub" style="margin-bottom:var(--spacing-md);">All projects with status and progress</div>
                <table class="pm-table" id="project-table">
                    <thead>
                        <tr>
                            <th>Project</th>
                            <th>Status</th>
                            <th>Progress</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>

        <!-- ── Team Performance ── -->
        <div class="report-section">
            <div class="report-chart-card">
                <h3 class="report-section-title">Team Performance</h3>
                <div class="report-section-sub" style="margin-bottom:var(--spacing-md);">Individual member task stats and completion rates</div>
                <table class="pm-table" id="team-table">
                    <thead>
                        <tr>
                            <th>Member</th>
                            <th>Assigned</th>
                            <th>Completed</th>
                            <th>Completion Rate</th>
                            <th>On-Time</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>

    </div>
</div>

@section PageScripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
    // ── State ──
    let dashboardData = null;
    let projectsData = [];
    let taskData = null;
    let teamData = [];
    let charts = {};

    document.addEventListener('DOMContentLoaded', () => generateReport());

    function applyFilter() { generateReport(); }

    // ── Load All Data ──
    async function generateReport() {
        const loading = document.getElementById('report-loading');
        const content = document.getElementById('report-content');
        loading.style.display = 'flex';
        content.style.display = 'none';

        const dateFrom = document.getElementById('dateFrom').value;
        const dateTo = document.getElementById('dateTo').value;
        let dateParams = '';
        if (dateFrom) dateParams += `&dateFrom=${dateFrom}`;
        if (dateTo) dateParams += `&dateTo=${dateTo}`;

        try {
            const [dashRes, projRes, taskRes, teamRes] = await Promise.all([
                fetch(`/api/reports/dashboard?_=1${dateParams}`, { credentials: 'same-origin' }).then(r => r.json()),
                fetch(`/api/reports/project-progress?_=1${dateParams}`, { credentials: 'same-origin' }).then(r => r.json()),
                fetch(`/api/reports/task-distribution?_=1${dateParams}`, { credentials: 'same-origin' }).then(r => r.json()),
                fetch(`/api/reports/team-performance?_=1${dateParams}`, { credentials: 'same-origin' }).then(r => r.json())
            ]);

            if (dashRes.success) dashboardData = dashRes.data;
            if (projRes.success) projectsData = projRes.data || [];
            if (taskRes.success) taskData = taskRes.data;
            if (teamRes.success) teamData = teamRes.data || [];

            renderAll();
            loading.style.display = 'none';
            content.style.display = 'block';
        } catch (err) {
            console.error('Report error:', err);
            loading.textContent = 'Failed to load report data.';
        }
    }

    function renderAll() {
        renderKPIs();
        renderProjectStatusChart();
        renderTaskChart();
        renderProjectTable();
        renderTeamTable();
    }

    // ═══════════════════════════════════════════════
    // KPI CARDS
    // ═══════════════════════════════════════════════
    function renderKPIs() {
        const db = dashboardData || {};
        const td = taskData || {};
        const totalProjects = projectsData.length;
        const completedProjects = projectsData.filter(p => p.status === 'Completed').length;
        const activeMembers = teamData.filter(m => m.tasksAssigned > 0).length;
        const completionPct = td.total > 0 ? Math.round((td.completed || 0) / td.total * 100) : 0;
        const unresolvedBlockers = (db.totalBlockers || 0) - (db.blockersResolved || 0);

        document.getElementById('kpi-grid').innerHTML = `
            <div class="report-kpi-card">
                <div class="kpi-label">Task Completion</div>
                <div class="kpi-value">${completionPct}%</div>
                <div class="kpi-sub">${td.completed || 0} of ${td.total || 0} tasks completed</div>
            </div>
            <div class="report-kpi-card">
                <div class="kpi-label">Projects</div>
                <div class="kpi-value">${totalProjects}</div>
                <div class="kpi-sub"><span class="text-success">${completedProjects} completed</span> · ${totalProjects - completedProjects} ongoing</div>
            </div>
            <div class="report-kpi-card">
                <div class="kpi-label">Active Members</div>
                <div class="kpi-value">${activeMembers}</div>
                <div class="kpi-sub">${activeMembers} of ${teamData.length} members with tasks</div>
            </div>
            <div class="report-kpi-card">
                <div class="kpi-label">Blockers</div>
                <div class="kpi-value">${db.blockersResolved || 0} / ${db.totalBlockers || 0}</div>
                <div class="kpi-sub"><span class="${unresolvedBlockers > 0 ? 'text-danger' : 'text-success'}">${unresolvedBlockers} unresolved</span></div>
            </div>`;
    }

    // ═══════════════════════════════════════════════
    // PROJECT STATUS DOUGHNUT
    // ═══════════════════════════════════════════════
    function renderProjectStatusChart() {
        const ctx = document.getElementById('project-status-chart');
        if (!ctx) return;
        if (charts.projectStatus) charts.projectStatus.destroy();

        const statusMap = {};
        projectsData.forEach(p => {
            const s = p.status || 'Planning';
            statusMap[s] = (statusMap[s] || 0) + 1;
        });

        const statusDefs = [
            { key: 'Completed', color: '#22c55e' },
            { key: 'In Progress', color: '#0d6e8a' },
            { key: 'Planning', color: '#f59e0b' },
            { key: 'Delayed', color: '#ef4444' }
        ];

        const labels = [], values = [], colors = [];
        statusDefs.forEach(s => { labels.push(s.key); values.push(statusMap[s.key] || 0); colors.push(s.color); });
        Object.keys(statusMap).forEach(k => {
            if (!statusDefs.find(s => s.key === k)) { labels.push(k); values.push(statusMap[k]); colors.push('#94A3B8'); }
        });

        const total = projectsData.length;
        document.getElementById('project-count-label').textContent = `Distribution of ${total} project${total !== 1 ? 's' : ''}`;
        document.getElementById('project-legend').innerHTML = labels.map((l, i) => `
            <div class="legend-item">
                <div class="legend-left"><span class="legend-dot" style="background:${colors[i]}"></span><span>${esc(l)}</span></div>
                <span class="legend-count">${values[i]}</span>
            </div>`).join('');

        charts.projectStatus = new Chart(ctx, {
            type: 'doughnut',
            data: { labels, datasets: [{ data: values, backgroundColor: colors, borderWidth: 0 }] },
            options: { responsive: true, maintainAspectRatio: false, cutout: '65%', plugins: { legend: { display: false } } }
        });
    }

    // ═══════════════════════════════════════════════
    // TASK DISTRIBUTION DOUGHNUT
    // ═══════════════════════════════════════════════
    function renderTaskChart() {
        const ctx = document.getElementById('task-chart');
        if (!ctx) return;
        if (charts.task) charts.task.destroy();

        const td = taskData || {};
        const labels = ['Completed', 'In Progress', 'In Review', 'To Do'];
        const values = [td.completed || 0, td.inProgress || 0, td.inReview || 0, td.notStarted || 0];
        const colors = ['#22c55e', '#0d6e8a', '#7c3aed', '#94A3B8'];

        document.getElementById('task-legend').innerHTML = labels.map((l, i) => `
            <div class="legend-item">
                <div class="legend-left"><span class="legend-dot" style="background:${colors[i]}"></span><span>${esc(l)}</span></div>
                <span class="legend-count">${values[i]}</span>
            </div>`).join('');

        charts.task = new Chart(ctx, {
            type: 'doughnut',
            data: { labels, datasets: [{ data: values, backgroundColor: colors, borderWidth: 0 }] },
            options: { responsive: true, maintainAspectRatio: false, cutout: '65%', plugins: { legend: { display: false } } }
        });
    }

    // ═══════════════════════════════════════════════
    // PROJECT DETAILS TABLE
    // ═══════════════════════════════════════════════
    function renderProjectTable() {
        const tbody = document.querySelector('#project-table tbody');

        if (!projectsData.length) {
            tbody.innerHTML = '<tr><td colspan="3" style="text-align:center;padding:30px;color:var(--text-secondary);">No projects found</td></tr>';
            return;
        }

        const statusColors = { 'Completed': '#22c55e', 'In Progress': '#0d6e8a', 'Planning': '#f59e0b', 'Delayed': '#ef4444' };

        tbody.innerHTML = projectsData.map(p => {
            const prog = Math.round(p.progress || 0);
            const sColor = statusColors[p.status] || '#94A3B8';
            const progColor = prog >= 80 ? '#22c55e' : prog >= 50 ? '#f59e0b' : '#ef4444';
            return `
            <tr>
                <td style="font-weight:500;">${esc(p.projectName)}</td>
                <td>
                    <span class="status-badge">
                        <span class="status-dot" style="background:${sColor}"></span>
                        ${esc(p.status)}
                    </span>
                </td>
                <td>
                    <div class="progress-bar-cell">
                        <div class="progress-track"><div class="progress-fill" style="width:${prog}%;background:${progColor};"></div></div>
                        <span class="progress-label-sm" style="color:${progColor}">${prog}%</span>
                    </div>
                </td>
            </tr>`;
        }).join('');
    }

    // ═══════════════════════════════════════════════
    // TEAM PERFORMANCE TABLE
    // ═══════════════════════════════════════════════
    function renderTeamTable() {
        const tbody = document.querySelector('#team-table tbody');

        if (!teamData.length) {
            tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:30px;color:var(--text-secondary);">No team data available</td></tr>';
            return;
        }

        const sorted = [...teamData].sort((a, b) => b.completionRate - a.completionRate);

        tbody.innerHTML = sorted.map(m => {
            const rate = Math.round(m.completionRate || 0);
            const onTime = Math.round(m.onTimePercent || 0);
            const rateColor = rate >= 80 ? '#22c55e' : rate >= 50 ? '#f59e0b' : '#ef4444';
            const onTimeColor = onTime >= 80 ? '#22c55e' : onTime >= 50 ? '#f59e0b' : '#ef4444';
            return `
            <tr>
                <td>
                    <div class="team-member-cell">
                        <div class="team-avatar-sm" style="background:${m.avatarColor || '#0B4F6C'}">${esc(m.initials)}</div>
                        <span style="font-weight:500;">${esc(m.fullName)}</span>
                    </div>
                </td>
                <td>${m.tasksAssigned || 0}</td>
                <td>${m.tasksCompleted || 0}</td>
                <td>
                    <div class="progress-bar-cell">
                        <div class="progress-track"><div class="progress-fill" style="width:${rate}%;background:${rateColor};"></div></div>
                        <span class="progress-label-sm" style="color:${rateColor}">${rate}%</span>
                    </div>
                </td>
                <td><span style="font-weight:600;color:${onTimeColor}">${onTime}%</span></td>
            </tr>`;
        }).join('');
    }

    // ── Print / PDF ──
    function printReport() { window.print(); }

    async function downloadPDF() {
        const btn = event.currentTarget;
        const originalText = btn.innerHTML;
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> Generating...';
        btn.disabled = true;
        try {
            const dateFrom = document.getElementById('dateFrom').value;
            const dateTo = document.getElementById('dateTo').value;
            let dateParams = '';
            if (dateFrom) dateParams += `&dateFrom=${dateFrom}`;
            if (dateTo) dateParams += `&dateTo=${dateTo}`;
            const res = await fetch(`/api/reports/download-pdf?_=1${dateParams}`, { credentials: 'same-origin' });
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            const blob = await res.blob();
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `PM-Report-${new Date().toISOString().slice(0, 10)}.pdf`;
            document.body.appendChild(a);
            a.click();
            a.remove();
            URL.revokeObjectURL(url);
        } catch (err) {
            console.error('PDF generation error:', err);
            alert('Failed to generate PDF. Please try Print Report instead.');
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    }

    // ── Helpers ──
    function esc(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    window.refreshReport = generateReport;
    window.printReport = printReport;
    window.downloadPDF = downloadPDF;
    window.applyFilter = applyFilter;
    </script>
}