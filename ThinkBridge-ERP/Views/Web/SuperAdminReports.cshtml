@{
    ViewData["Title"] = "Reports";
    ViewData["UserRole"] = "superadmin";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/superadmin-reports.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/superadmin.css" asp-append-version="true" />
}

<div class="page-reports">
    <!-- Header -->
    <div class="report-header">
        <h1>Platform Reports</h1>
        <div class="report-header-actions">
            <div class="date-filter">
                <label for="date-from">From</label>
                <input type="date" id="date-from" />
                <label for="date-to">To</label>
                <input type="date" id="date-to" />
            </div>
            <button class="btn-generate" id="btn-generate" onclick="generateReport()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
                </svg>
                Generate
            </button>
            <button class="btn-print" onclick="printReport()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="6 9 6 2 18 2 18 9"></polyline>
                    <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
                    <rect x="6" y="14" width="12" height="8"></rect>
                </svg>
                Print Report
            </button>
            <button class="btn-print" onclick="downloadPDF()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                Download PDF
            </button>
        </div>
    </div>

    <!-- Report Meta -->
    <div class="report-meta" id="report-meta">
        <span><strong>Report:</strong> Platform Overview</span>
        <span><strong>Period:</strong> <span id="meta-period">Last 12 months</span></span>
        <span><strong>Generated:</strong> <span id="meta-generated">—</span></span>
    </div>

    <!-- Loading -->
    <div class="report-loading" id="report-loading">
        Loading report data...
    </div>

    <!-- Report Content (hidden until data loads) -->
    <div id="report-content" style="display:none;">

        <!-- KPI Summary -->
        <div class="report-kpi-grid" id="kpi-grid"></div>

        <!-- Revenue Chart + Subscription Distribution -->
        <div class="report-chart-grid">
            <div class="report-chart-card">
                <h3>Monthly Revenue Trend</h3>
                <div class="report-chart-container">
                    <canvas id="revenue-chart"></canvas>
                </div>
            </div>
            <div class="report-chart-card">
                <h3>Subscription Distribution</h3>
                <div class="report-chart-container">
                    <canvas id="plan-chart"></canvas>
                </div>
            </div>
        </div>

        <!-- Subscription Breakdown -->
        <section class="report-section">
            <div class="report-section-header">
                <h2>Subscription Breakdown</h2>
            </div>
            <div class="report-section-body" id="subscription-breakdown"></div>
        </section>



        <!-- Top Companies Tables -->
        <div class="report-tables-grid">
            <section class="report-section">
                <div class="report-section-header">
                    <h2>Top Companies by Users</h2>
                </div>
                <div class="report-section-body" style="padding:0;">
                    <table class="report-table" id="top-users-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Company</th>
                                <th>Industry</th>
                                <th>Plan</th>
                                <th>Users</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </section>
            <section class="report-section">
                <div class="report-section-header">
                    <h2>Top Companies by Revenue</h2>
                </div>
                <div class="report-section-body" style="padding:0;">
                    <table class="report-table" id="top-revenue-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Company</th>
                                <th>Plan</th>
                                <th>Revenue</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </section>
        </div>

        <!-- Payment Summary -->
        <section class="report-section">
            <div class="report-section-header">
                <h2>Payment Summary</h2>
            </div>
            <div class="report-section-body" id="payment-summary"></div>
        </section>

    </div>
</div>

@section PageScripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
        // Set default date range (last 12 months)
        const now = new Date();
        const yearAgo = new Date(now.getFullYear() - 1, now.getMonth(), now.getDate());
        document.getElementById('date-from').value = yearAgo.toISOString().split('T')[0];
        document.getElementById('date-to').value = now.toISOString().split('T')[0];

        generateReport();
        });

        let revenueChart = null;
        let planChart = null;

        async function generateReport() {
        const loading = document.getElementById('report-loading');
        const content = document.getElementById('report-content');
        loading.style.display = 'flex';
        content.style.display = 'none';

        const dateFrom = document.getElementById('date-from').value;
        const dateTo = document.getElementById('date-to').value;

        const params = new URLSearchParams();
        if (dateFrom) params.append('dateFrom', dateFrom);
        if (dateTo) params.append('dateTo', dateTo);

        try {
        const response = await fetch(`/api/superadmin/reports?${params}`, { credentials: 'same-origin' });
        const result = await response.json();

        if (result.success) {
        renderReport(result.data);
        loading.style.display = 'none';
        content.style.display = 'block';
        } else {
        loading.textContent = 'Error loading report: ' + (result.message || 'Unknown error');
        }
        } catch (err) {
        console.error('Report error:', err);
        loading.textContent = 'Failed to load report data.';
        }
        }

        function renderReport(data) {
        // Meta
        document.getElementById('meta-period').textContent =
        formatDate(data.periodStart) + ' — ' + formatDate(data.periodEnd);
        document.getElementById('meta-generated').textContent =
        new Date(data.generatedAt).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' });

        // KPIs
        renderKPIs(data);

        // Charts
        renderRevenueChart(data.monthlyRevenue);
        renderPlanChart(data.planDistribution);

        // Sections
        renderSubscriptionBreakdown(data);
        renderTopCompanies(data);
        renderPaymentSummary(data);
        }

        function renderKPIs(data) {
        const grid = document.getElementById('kpi-grid');
        grid.innerHTML = `
        <div class="report-kpi-card">
        <div class="kpi-label">Total Companies</div>
        <div class="kpi-value">${data.totalCompanies}</div>
        <div class="kpi-sub"><span class="text-success">${data.activeCompanies} active</span> · ${data.inactiveCompanies} inactive</div>
        </div>
        <div class="report-kpi-card">
        <div class="kpi-label">Total Users</div>
        <div class="kpi-value">${data.totalUsers}</div>
        <div class="kpi-sub"><span class="text-success">${data.activeUsers} active</span></div>
        </div>
        <div class="report-kpi-card">
        <div class="kpi-label">Subscriptions</div>
        <div class="kpi-value">${data.totalSubscriptions}</div>
        <div class="kpi-sub"><span class="text-success">${data.activeSubscriptions} active</span> · ${data.trialSubscriptions} trial</div>
        </div>
        <div class="report-kpi-card">
        <div class="kpi-label">Monthly Recurring Revenue</div>
        <div class="kpi-value">₱${formatNumber(data.monthlyRecurringRevenue)}</div>
        <div class="kpi-sub">${data.newCompaniesThisPeriod} new companies this period</div>
        </div>
        <div class="report-kpi-card">
        <div class="kpi-label">Total Revenue</div>
        <div class="kpi-value">₱${formatNumber(data.totalRevenue)}</div>
        <div class="kpi-sub">${data.completedPayments} completed payments</div>
        </div>
        <div class="report-kpi-card">
        <div class="kpi-label">Pending Payments</div>
        <div class="kpi-value">${data.pendingPayments}</div>
        <div class="kpi-sub"><span class="text-warning">₱${formatNumber(data.pendingAmount)} pending</span></div>
        </div>

        `;
        }

        function renderRevenueChart(monthlyRevenue) {
        const ctx = document.getElementById('revenue-chart').getContext('2d');
        if (revenueChart) revenueChart.destroy();

        const labels = monthlyRevenue.map(m => m.label);
        const values = monthlyRevenue.map(m => m.revenue);

        revenueChart = new Chart(ctx, {
        type: 'bar',
        data: {
        labels: labels,
        datasets: [{
        label: 'Revenue (₱)',
        data: values,
        backgroundColor: 'rgba(59, 130, 246, 0.7)',
        borderColor: 'rgba(59, 130, 246, 1)',
        borderWidth: 1,
        borderRadius: 4
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
        legend: { display: false },
        tooltip: {
        callbacks: {
        label: ctx => `₱${ctx.parsed.y.toLocaleString()}`
        }
        }
        },
        scales: {
        y: {
        beginAtZero: true,
        ticks: {
        callback: val => '₱' + (val >= 1000 ? (val / 1000).toFixed(0) + 'k' : val),
        font: { size: 11 }
        },
        grid: { color: 'rgba(0,0,0,0.04)' }
        },
        x: {
        ticks: { font: { size: 11 } },
        grid: { display: false }
        }
        }
        }
        });
        }

        function renderPlanChart(planDistribution) {
        const ctx = document.getElementById('plan-chart').getContext('2d');
        if (planChart) planChart.destroy();

        const colors = {
        'Enterprise': '#7C3AED',
        'Professional': '#2563EB',
        'Starter': '#D97706',
        'Trial': '#6D28D9'
        };

        const labels = planDistribution.map(p => p.planName);
        const values = planDistribution.map(p => p.count);
        const bgColors = labels.map(l => colors[l] || '#94A3B8');

        planChart = new Chart(ctx, {
        type: 'doughnut',
        data: {
        labels: labels,
        datasets: [{
        data: values,
        backgroundColor: bgColors,
        borderWidth: 2,
        borderColor: '#fff'
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '55%',
        plugins: {
        legend: {
        position: 'bottom',
        labels: { font: { size: 12 }, padding: 16, usePointStyle: true }
        }
        }
        }
        });
        }

        // Platform usage rendering removed (no project-level analytics for SuperAdmin)

        function renderSubscriptionBreakdown(data) {
        const container = document.getElementById('subscription-breakdown');
        const total = data.totalSubscriptions || 1;

        const items = [
        { label: 'Active', count: data.activeSubscriptions, color: 'green' },
        { label: 'Trial', count: data.trialSubscriptions, color: 'purple' },
        { label: 'Expired', count: data.expiredSubscriptions, color: 'orange' },
        { label: 'Cancelled', count: data.cancelledSubscriptions, color: 'red' }
        ];

        container.innerHTML = items.map(item => `
        <div class="stat-bar-row">
        <span class="stat-bar-label">${item.label}</span>
        <div class="stat-bar-track">
        <div class="stat-bar-fill ${item.color}" style="width: ${(item.count / total * 100).toFixed(1)}%"></div>
        </div>
        <span class="stat-bar-value">${item.count}</span>
        </div>
        `).join('');
        }

        function renderTopCompanies(data) {
        // Top by Users
        const usersTbody = document.querySelector('#top-users-table tbody');
        if (data.topCompaniesByUsers && data.topCompaniesByUsers.length > 0) {
        usersTbody.innerHTML = data.topCompaniesByUsers.map((c, i) => `
        <tr>
        <td>${i + 1}</td>
        <td><strong>${esc(c.companyName)}</strong></td>
        <td>${esc(c.industry)}</td>
        <td><span class="plan-text ${(c.planName || '').toLowerCase()}">${esc(c.planName)}</span></td>
        <td>${c.userCount}</td>
        </tr>
        `).join('');
        } else {
        usersTbody.innerHTML = '<tr><td colspan="5" style="text-align:center; padding:30px; color:var(--text-secondary);">No data</td></tr>';
        }

        // Top by Revenue
        const revTbody = document.querySelector('#top-revenue-table tbody');
        if (data.topCompaniesByRevenue && data.topCompaniesByRevenue.length > 0) {
        revTbody.innerHTML = data.topCompaniesByRevenue.map((c, i) => `
        <tr>
        <td>${i + 1}</td>
        <td><strong>${esc(c.companyName)}</strong></td>
        <td><span class="plan-text ${(c.planName || '').toLowerCase()}">${esc(c.planName)}</span></td>
        <td>₱${formatNumber(c.totalRevenue)}</td>
        </tr>
        `).join('');
        } else {
        revTbody.innerHTML = '<tr><td colspan="4" style="text-align:center; padding:30px; color:var(--text-secondary);">No data</td></tr>';
        }
        }

        function renderPaymentSummary(data) {
        const container = document.getElementById('payment-summary');
        const total = (data.completedPayments + data.pendingPayments + data.failedPayments) || 1;

        container.innerHTML = `
        <div class="report-kpi-grid" style="margin-bottom: var(--spacing-md);">
        <div class="report-kpi-card">
        <div class="kpi-label">Completed</div>
        <div class="kpi-value" style="color: var(--success);">${data.completedPayments}</div>
        <div class="kpi-sub">₱${formatNumber(data.totalRevenue)} collected</div>
        </div>
        <div class="report-kpi-card">
        <div class="kpi-label">Pending</div>
        <div class="kpi-value" style="color: #B45309;">${data.pendingPayments}</div>
        <div class="kpi-sub">₱${formatNumber(data.pendingAmount)} outstanding</div>
        </div>
        <div class="report-kpi-card">
        <div class="kpi-label">Failed</div>
        <div class="kpi-value" style="color: var(--danger);">${data.failedPayments}</div>
        </div>
        </div>
        <div class="stat-bar-row">
        <span class="stat-bar-label">Completed</span>
        <div class="stat-bar-track">
        <div class="stat-bar-fill green" style="width: ${(data.completedPayments / total * 100).toFixed(1)}%"></div>
        </div>
        <span class="stat-bar-value">${(data.completedPayments / total * 100).toFixed(0)}%</span>
        </div>
        <div class="stat-bar-row">
        <span class="stat-bar-label">Pending</span>
        <div class="stat-bar-track">
        <div class="stat-bar-fill orange" style="width: ${(data.pendingPayments / total * 100).toFixed(1)}%"></div>
        </div>
        <span class="stat-bar-value">${(data.pendingPayments / total * 100).toFixed(0)}%</span>
        </div>
        <div class="stat-bar-row">
        <span class="stat-bar-label">Failed</span>
        <div class="stat-bar-track">
        <div class="stat-bar-fill red" style="width: ${(data.failedPayments / total * 100).toFixed(1)}%"></div>
        </div>
        <span class="stat-bar-value">${(data.failedPayments / total * 100).toFixed(0)}%</span>
        </div>
        `;
        }

        // ---- Print / PDF ----
        function printReport() {
        window.print();
        }

        async function downloadPDF() {
        const btn = document.querySelector('.btn-print:last-of-type');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> Generating...';
        btn.disabled = true;

        try {
        const dateFrom = document.getElementById('date-from').value;
        const dateTo = document.getElementById('date-to').value;
        let url = '/api/superadmin/reports/download-pdf';
        const params = [];
        if (dateFrom) params.push(`dateFrom=${dateFrom}`);
        if (dateTo) params.push(`dateTo=${dateTo}`);
        if (params.length) url += '?' + params.join('&');

        const res = await fetch(url, { credentials: 'same-origin' });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const blob = await res.blob();
        const blobUrl = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = blobUrl;
        a.download = `ThinkBridge-Platform-Report-${new Date().toISOString().split('T')[0]}.pdf`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(blobUrl);
        } catch (err) {
        console.error('PDF generation error:', err);
        alert('Failed to generate PDF. Please try Print Report instead.');
        } finally {
        btn.innerHTML = originalText;
        btn.disabled = false;
        }
        }

        // ---- Helpers ----
        function esc(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
        }

        function formatNumber(num) {
        if (num == null) return '0';
        return Number(num).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        function formatDate(dateStr) {
        if (!dateStr) return '—';
        return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        }

        // Make functions globally available
        window.generateReport = generateReport;
        window.printReport = printReport;
        window.downloadPDF = downloadPDF;
    </script>
}