@{
    ViewData["Title"] = "Companies";
    ViewData["UserRole"] = "superadmin";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/companies.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/forms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/superadmin.css" asp-append-version="true" />
}

<div class="page-companies">
    <!-- Filters Section -->
    <section class="filters-section">
        <div class="search-box">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input type="text" placeholder="Search companies..." class="search-input" />
        </div>
        <div class="filter-group">
            <select class="filter-select" id="status-filter">
                <option value="">All Status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
            </select>
            <select class="filter-select" id="plan-filter">
                <option value="">All Plans</option>
            </select>
            <button class="btn btn-primary" id="add-company-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                Add Company
            </button>
        </div>
    </section>

    <!-- Companies Table -->
    <section class="companies-table-section">
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Company</th>
                        <th>Email</th>
                        <th>Industry</th>
                        <th>Status</th>
                        <th>Joined</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="companies-tbody">
                    <tr>
                        <td colspan="6" class="loading-cell">Loading companies...</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="table-footer" id="companies-pagination">
        </div>
    </section>
</div>

<!-- Add Company Modal -->
<div class="modal-overlay" id="add-company-modal">
    <div class="modal modal-lg">
        <div class="modal-header">
            <h2>Add New Company</h2>
            <button class="modal-close" id="company-modal-close">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body">
            <form class="company-form" id="add-company-form">
                <div class="form-group">
                    <label for="company-name">Company Name <span class="required">*</span></label>
                    <input type="text" id="company-name" class="form-control" placeholder="Enter company name"
                           required />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="company-industry">Industry</label>
                        <select id="company-industry" class="form-select">
                            <option value="">Select Industry</option>
                            <option value="Technology">Technology</option>
                            <option value="Finance">Finance</option>
                            <option value="Healthcare">Healthcare</option>
                            <option value="Retail">Retail</option>
                            <option value="Education">Education</option>
                            <option value="Manufacturing">Manufacturing</option>
                            <option value="Consulting">Consulting</option>
                            <option value="Real Estate">Real Estate</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="company-plan">Subscription Plan <span class="required">*</span></label>
                        <select id="company-plan" class="form-select" required>
                            <option value="">Loading plans...</option>
                        </select>
                    </div>
                </div>
                <hr style="margin: 24px 0; border: none; border-top: 1px solid var(--border);" />
                <h4 style="font-size: 0.95rem; font-weight: 600; margin-bottom: 16px; color: var(--text-primary);">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         style="display: inline; vertical-align: middle; margin-right: 6px;">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    Company Admin Account
                </h4>
                <div class="form-row">
                    <div class="form-group">
                        <label for="admin-fname">First Name <span class="required">*</span></label>
                        <input type="text" id="admin-fname" class="form-control" placeholder="Enter first name"
                               required />
                    </div>
                    <div class="form-group">
                        <label for="admin-lname">Last Name <span class="required">*</span></label>
                        <input type="text" id="admin-lname" class="form-control" placeholder="Enter last name"
                               required />
                    </div>
                </div>
                <div class="form-group">
                    <label for="admin-email">Admin Email <span class="required">*</span></label>
                    <input type="email" id="admin-email" class="form-control" placeholder="admin@company.com"
                           required />
                </div>
                <div class="form-group">
                    <label for="admin-phone">Phone Number</label>
                    <input type="tel" id="admin-phone" class="form-control" placeholder="09XXXXXXXXX" maxlength="11" />
                </div>
            </form>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" id="company-modal-cancel">Cancel</button>
            <button class="btn btn-primary" id="company-modal-submit">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                    <polyline points="17 21 17 13 7 13 7 21"></polyline>
                    <polyline points="7 3 7 8 15 8"></polyline>
                </svg>
                Create Company
            </button>
        </div>
    </div>
</div>

<!-- View Company Detail Modal -->
<div class="modal-overlay" id="view-company-modal">
    <div class="modal modal-lg">
        <div class="modal-header">
            <h2>Company Details</h2>
            <button class="modal-close" onclick="closeViewCompanyModal()">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body" id="view-company-body">
            <div class="loading-cell">Loading...</div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeViewCompanyModal()">Close</button>
        </div>
    </div>
</div>

<!-- Edit Company Modal -->
<div class="modal-overlay" id="edit-company-modal">
    <div class="modal">
        <div class="modal-header">
            <h2>Edit Company</h2>
            <button class="modal-close" onclick="closeEditCompanyModal()">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="edit-company-id" value="" />
            <div class="form-group">
                <label class="form-label">Company Name</label>
                <input type="text" class="form-control" id="edit-company-name" placeholder="Company name" />
            </div>
            <div class="form-group">
                <label class="form-label">Industry</label>
                <select id="edit-company-industry" class="form-select">
                    <option value="">Select Industry</option>
                    <option value="Technology">Technology</option>
                    <option value="Finance">Finance</option>
                    <option value="Healthcare">Healthcare</option>
                    <option value="Retail">Retail</option>
                    <option value="Education">Education</option>
                    <option value="Manufacturing">Manufacturing</option>
                    <option value="Consulting">Consulting</option>
                    <option value="Real Estate">Real Estate</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Admin Email</label>
                <input type="email" class="form-control" id="edit-company-email" placeholder="admin@company.com" />
            </div>
            <div class="form-group">
                <label class="form-label">Phone Number</label>
                <input type="tel" class="form-control" id="edit-company-phone" placeholder="09XXXXXXXXX"
                       maxlength="11" />
            </div>
            <div class="form-group">
                <label class="form-label">Status</label>
                <select id="edit-company-status" class="form-select">
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                </select>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeEditCompanyModal()">Cancel</button>
            <button class="btn btn-primary" id="save-edit-company-btn">Save Changes</button>
        </div>
    </div>
</div>

<!-- Confirm Action Modal -->
<div class="modal-overlay" id="confirm-modal">
    <div class="modal" style="max-width: 420px;">
        <div class="modal-header">
            <h2 id="confirm-modal-title">Confirm</h2>
            <button class="modal-close" id="confirm-modal-close">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body" style="padding: 24px;">
            <div style="display: flex; align-items: flex-start; gap: 16px;">
                <div
                    style="flex-shrink: 0; width: 42px; height: 42px; border-radius: 50%; background: rgba(245, 158, 11, 0.12); display: flex; align-items: center; justify-content: center;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="8" x2="12" y2="12"></line>
                        <line x1="12" y1="16" x2="12.01" y2="16"></line>
                    </svg>
                </div>
                <p id="confirm-modal-message"
                       style="margin: 0; padding-top: 8px; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.5;">
                </p>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" id="confirm-modal-cancel">Cancel</button>
            <button class="btn btn-primary" id="confirm-modal-action">Confirm</button>
        </div>
    </div>
</div>

<!-- Password Success Modal -->
<div class="modal-overlay" id="password-modal">
    <div class="modal" style="max-width: 450px;">
        <div class="modal-header" style="background: linear-gradient(135deg, var(--success) 0%, #059669 100%);">
            <h2 style="color: white; display: flex; align-items: center; gap: 10px;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
                Company Created Successfully
            </h2>
            <button class="modal-close" id="password-modal-close">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body" style="text-align: center; padding: 32px;">
            <div style="margin-bottom: 24px;">
                <div
                    style="width: 64px; height: 64px; background: rgba(16, 185, 129, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--success)"
                         stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                </div>
                <h3 style="font-size: 1.1rem; color: var(--text-primary); margin-bottom: 8px;">Admin Account Created
                </h3>
                <p style="font-size: 0.9rem; color: var(--text-secondary);">Please share the temporary password below
                    with the company administrator.</p>
                </div>
                <div
                    style="background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 8px; padding: 16px; margin-bottom: 16px;">
                    <label
                        style="display: block; font-size: 0.8rem; color: var(--text-secondary); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px;">Temporary
                        Password</label>
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <input type="text" id="generated-password" readonly
                                   style="flex: 1; font-family: monospace; font-size: 1.1rem; font-weight: 600; padding: 12px; border: 1px dashed var(--border); border-radius: 6px; background: var(--bg-primary); text-align: center; color: var(--text-primary);" />
                            <button type="button" id="copy-password-btn" class="btn btn-secondary" style="padding: 12px 16px;"
                                    title="Copy to clipboard">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2">
                                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                                </svg>
                            </button>
                        </div>
                    </div>
                    <p
                        style="font-size: 0.85rem; color: var(--warning); display: flex; align-items: center; justify-content: center; gap: 6px;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="8" x2="12" y2="12"></line>
                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                        </svg>
                        The admin will be required to change this password on first login.
                    </p>
                </div>
                <div class="modal-footer" style="justify-content: center;">
                    <button class="btn btn-primary" id="password-modal-done" style="min-width: 120px;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        Done
                    </button>
                </div>
            </div>
        </div>

        @section PageScripts {
            <script>
                                                        document.addEventListener('DOMContentLoaded', function () {
                                                            let currentPage = 1;
                                                            let plansCache = [];
                                                            let confirmCallback = null;

                                                            const addCompanyBtn = document.getElementById('add-company-btn');
                                                            const modal = document.getElementById('add-company-modal');
                                                            const modalClose = document.getElementById('company-modal-close');
                                                            const modalCancel = document.getElementById('company-modal-cancel');
                                                            const modalSubmit = document.getElementById('company-modal-submit');
                                                            const form = document.getElementById('add-company-form');

                                                            const passwordModal = document.getElementById('password-modal');
                                                            const passwordModalClose = document.getElementById('password-modal-close');
                                                            const passwordModalDone = document.getElementById('password-modal-done');
                                                            const generatedPassword = document.getElementById('generated-password');
                                                            const copyPasswordBtn = document.getElementById('copy-password-btn');

                                                            // Init
                                                            loadPlans();
                                                            loadCompanies();

                                                            // ========== PLANS (for filter & create form) ==========
                                                            async function loadPlans() {
                                                                try {
                                                                    const res = await fetch('/api/superadmin/subscription-plans', { credentials: 'same-origin' });
                                                                    const result = await res.json();
                                                                    if (result.success) {
                                                                        plansCache = result.data;
                                                                        populatePlanDropdowns(result.data);
                                                                    }
                                                                } catch (e) { console.error('Error loading plans:', e); }
                                                            }

                                                            function populatePlanDropdowns(plans) {
                                                                const activePlans = plans.filter(p => p.isActive);

                                                                // Plan filter dropdown
                                                                const planFilterEl = document.getElementById('plan-filter');
                                                                const currentVal = planFilterEl.value;
                                                                planFilterEl.innerHTML = '<option value="">All Plans</option>' +
                                                                    plans.map(p => `<option value="${escapeHtml(p.planName.toLowerCase())}">${escapeHtml(p.planName)}</option>`).join('');
                                                                planFilterEl.value = currentVal;

                                                                // Create company plan dropdown
                                                                const companyPlan = document.getElementById('company-plan');
                                                                companyPlan.innerHTML = '<option value="">Select Plan</option>' +
                                                                    activePlans.map(p => `<option value="${escapeHtml(p.planName.toLowerCase())}">${escapeHtml(p.planName)} – ₱${formatNumber(p.price)}/${p.billingCycle === 'Annual' ? 'yr' : 'mo'}</option>`).join('');
                                                            }

                                                            // ========== LOAD COMPANIES ==========
                                                            async function loadCompanies(page) {
                                                                if (page !== undefined) currentPage = page;

                                                                const searchInput = document.querySelector('.search-input');
                                                                const statusFilter = document.getElementById('status-filter');
                                                                const planFilter = document.getElementById('plan-filter');

                                                                const params = new URLSearchParams({ page: currentPage, pageSize: 10 });
                                                                if (searchInput && searchInput.value) params.append('search', searchInput.value);
                                                                if (statusFilter && statusFilter.value) params.append('status', statusFilter.value);
                                                                if (planFilter && planFilter.value) params.append('plan', planFilter.value);

                                                                try {
                                                                    const response = await fetch(`/api/superadmin/companies?${params}`, { credentials: 'same-origin' });
                                                                    const result = await response.json();
                                                                    if (result.success) {
                                                                        renderCompanies(result.data);
                                                                        renderPagination(result.pagination);
                                                                    }
                                                                } catch (error) {
                                                                    console.error('Error loading companies:', error);
                                                                }
                                                            }

                                                            function renderCompanies(companies) {
                                                                const tbody = document.getElementById('companies-tbody');
                                                                if (!tbody) return;

                                                                if (!companies || companies.length === 0) {
                                                                    tbody.innerHTML = '<tr><td colspan="6" class="loading-cell">No companies found</td></tr>';
                                                                    return;
                                                                }

                                                                tbody.innerHTML = companies.map(company => {
                                                                    const statusClass = company.status.toLowerCase() === 'active' ? 'active' : 'inactive';
                                                                    return `
                                                                        <tr class="clickable-row" onclick="viewCompany(${company.companyID})">
                                                                            <td><strong>${escapeHtml(company.companyName)}</strong></td>
                                                                            <td>${escapeHtml(company.adminEmail || 'No admin')}</td>
                                                                            <td>${escapeHtml(company.industry || '–')}</td>
                                                                            <td><span class="status-indicator ${statusClass}">${escapeHtml(company.status)}</span></td>
                                                                            <td>${formatDate(company.createdAt)}</td>
                                                                            <td>
                                                                                <div class="action-buttons">
                                                                                    <button class="btn-icon" title="Edit" onclick="event.stopPropagation(); editCompany(${company.companyID})">
                                                                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                                                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                                                                        </svg>
                                                                                    </button>
                                                                                    ${company.status.toLowerCase() === 'active'
                                                                                        ? `<button class="btn-icon danger" title="Deactivate" onclick="event.stopPropagation(); toggleCompanyStatus(${company.companyID}, 'Inactive')">
                                                                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                                                <circle cx="12" cy="12" r="10"></circle>
                                                                                                <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line>
                                                                                            </svg>
                                                                                        </button>`
                                                                                        : `<button class="btn-icon success" title="Activate" onclick="event.stopPropagation(); toggleCompanyStatus(${company.companyID}, 'Active')">
                                                                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                                                                                <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                                                                            </svg>
                                                                                        </button>`
                                                                                    }
                                                                                </div>
                                                                            </td>
                                                                        </tr>`;
                                                                }).join('');
                                                            }

                                                            function renderPagination(pagination) {
                                                                const footer = document.getElementById('companies-pagination');
                                                                if (!footer) return;

                                                                if (!pagination || pagination.totalPages <= 1) {
                                                                    footer.innerHTML = pagination
                                                                        ? `<span class="table-info">Showing ${pagination.totalCount} compan${pagination.totalCount !== 1 ? 'ies' : 'y'}</span>`
                                                                        : '';
                                                                    return;
                                                                }

                                                                let pagesHtml = '';
                                                                for (let i = 1; i <= pagination.totalPages; i++) {
                                                                    pagesHtml += `<button class="page-btn ${i === pagination.page ? 'active' : ''}" onclick="loadCompanies(${i})">${i}</button>`;
                                                                }

                                                                const start = (pagination.page - 1) * pagination.pageSize + 1;
                                                                const end = Math.min(pagination.page * pagination.pageSize, pagination.totalCount);
                                                                footer.innerHTML = `
                                                                    <span class="table-info">Showing ${start}\u2013${end} of ${pagination.totalCount} companies</span>
                                                                    <div class="pagination">${pagesHtml}</div>
                                                                `;
                                                            }

                                                            // ========== VIEW COMPANY ==========
                                                            window.viewCompany = async function (companyId) {
                                                                const overlay = document.getElementById('view-company-modal');
                                                                const body = document.getElementById('view-company-body');
                                                                body.innerHTML = '<div class="loading-cell">Loading...</div>';
                                                                overlay.classList.add('active');

                                                                try {
                                                                    const res = await fetch(`/api/superadmin/companies/${companyId}`, { credentials: 'same-origin' });
                                                                    const result = await res.json();
                                                                    if (result.success) {
                                                                        const d = result.data;
                                                                        const planClass = (d.subscription?.planName || 'trial').toLowerCase();
                                                                        body.innerHTML = `
                                                                            <div class="detail-grid">
                                                                                <div class="detail-section">
                                                                                    <h4>Company Information</h4>
                                                                                    <div class="detail-row"><span>Name</span><span><strong>${escapeHtml(d.company.companyName)}</strong></span></div>
                                                                                    <div class="detail-row"><span>Industry</span><span>${escapeHtml(d.company.industry || '–')}</span></div>
                                                                                    <div class="detail-row"><span>Status</span><span class="status-indicator ${d.company.status.toLowerCase()}">${escapeHtml(d.company.status)}</span></div>
                                                                                    <div class="detail-row"><span>Joined</span><span>${formatDate(d.company.createdAt)}</span></div>
                                                                                    <div class="detail-row"><span>Total Users</span><span>${d.userCount}</span></div>
                                                                                    <div class="detail-row"><span>Total Projects</span><span>${d.projectCount}</span></div>
                                                                                </div>
                                                                                <div class="detail-section">
                                                                                    <h4>Admin Contact</h4>
                                                                                    ${d.admin ? `
                                                                                        <div class="detail-row"><span>Name</span><span>${escapeHtml(d.admin.name)}</span></div>
                                                                                        <div class="detail-row"><span>Email</span><span>${escapeHtml(d.admin.email)}</span></div>
                                                                                        <div class="detail-row"><span>Phone</span><span>${escapeHtml(d.admin.phone || '–')}</span></div>
                                                                                    ` : '<p style="color: var(--text-secondary); font-size: 0.85rem;">No admin assigned</p>'}
                                                                                    <h4 style="margin-top: var(--spacing-lg);">Subscription</h4>
                                                                                    ${d.subscription ? `
                                                                                        <div class="detail-row"><span>Plan</span><span class="plan-text ${planClass}">${escapeHtml(d.subscription.planName)}</span></div>
                                                                                        <div class="detail-row"><span>Status</span><span>${escapeHtml(d.subscription.status)}</span></div>
                                                                                        <div class="detail-row"><span>Started</span><span>${formatDate(d.subscription.startDate)}</span></div>
                                                                                        <div class="detail-row"><span>Expires</span><span>${d.subscription.endDate ? formatDate(d.subscription.endDate) : '–'}</span></div>
                                                                                        <div style="margin-top: var(--spacing-sm);">
                                                                                            <a href="/superadmin/subscriptions" class="btn-link" style="font-size: 0.85rem; color: var(--primary-blue); text-decoration: none; display: inline-flex; align-items: center; gap: 4px;">
                                                                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                                                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                                                                                                    <polyline points="15 3 21 3 21 9"></polyline>
                                                                                                    <line x1="10" y1="14" x2="21" y2="3"></line>
                                                                                                </svg>
                                                                                                Manage Subscription
                                                                                            </a>
                                                                                        </div>
                                                                                    ` : '<p style="color: var(--text-secondary); font-size: 0.85rem;">No active subscription</p>'}
                                                                                </div>
                                                                            </div>`;
                                                                    } else {
                                                                        body.innerHTML = '<div class="loading-cell">Failed to load company details.</div>';
                                                                    }
                                                                } catch (e) {
                                                                    body.innerHTML = '<div class="loading-cell">An error occurred.</div>';
                                                                }
                                                            };

                                                            window.closeViewCompanyModal = function () {
                                                                document.getElementById('view-company-modal').classList.remove('active');
                                                            };

                                                            // ========== EDIT COMPANY ==========
                                                            window.editCompany = async function (companyId) {
                                                                const overlay = document.getElementById('edit-company-modal');
                                                                try {
                                                                    const res = await fetch(`/api/superadmin/companies/${companyId}`, { credentials: 'same-origin' });
                                                                    const result = await res.json();
                                                                    if (result.success) {
                                                                        const d = result.data;
                                                                        document.getElementById('edit-company-id').value = d.company.companyID;
                                                                        document.getElementById('edit-company-name').value = d.company.companyName;
                                                                        document.getElementById('edit-company-industry').value = d.company.industry || '';
                                                                        document.getElementById('edit-company-status').value = d.company.status;
                                                                        document.getElementById('edit-company-email').value = d.admin?.email || '';
                                                                        document.getElementById('edit-company-phone').value = d.admin?.phone || '';
                                                                        overlay.classList.add('active');
                                                                    }
                                                                } catch (e) { console.error('Error loading company for edit:', e); }
                                                            };

                                                            window.closeEditCompanyModal = function () {
                                                                document.getElementById('edit-company-modal').classList.remove('active');
                                                            };

                                                            document.getElementById('save-edit-company-btn').addEventListener('click', async function () {
                                                                const companyId = document.getElementById('edit-company-id').value;
                                                                const body = {
                                                                    companyName: document.getElementById('edit-company-name').value.trim(),
                                                                    industry: document.getElementById('edit-company-industry').value,
                                                                    status: document.getElementById('edit-company-status').value,
                                                                    adminEmail: document.getElementById('edit-company-email').value.trim(),
                                                                    adminPhone: document.getElementById('edit-company-phone').value.trim()
                                                                };

                                                                if (!body.companyName) { alert('Company name is required.'); return; }

                                                                try {
                                                                    const res = await fetch(`/api/superadmin/companies/${companyId}`, {
                                                                        method: 'PUT',
                                                                        headers: { 'Content-Type': 'application/json' },
                                                                        credentials: 'same-origin',
                                                                        body: JSON.stringify(body)
                                                                    });
                                                                    const result = await res.json();
                                                                    if (result.success) {
                                                                        closeEditCompanyModal();
                                                                        showToast('Company updated successfully.', 'success');
                                                                        loadCompanies();
                                                                    } else {
                                                                        showToast(result.message || 'Failed to update company.', 'error');
                                                                    }
                                                                } catch (e) { alert('An error occurred while updating the company.'); }
                                                            });

                                                            // ========== TOGGLE STATUS (styled confirm) ==========
                                                            window.toggleCompanyStatus = function (companyId, newStatus) {
                                                                const action = newStatus.toLowerCase() === 'active' ? 'activate' : 'deactivate';
                                                                showConfirmModal(
                                                                    `Are you sure you want to <strong>${action}</strong> this company? ${action === 'deactivate' ? 'All users will lose access.' : 'Users will regain access.'}`,
                                                                    `${action.charAt(0).toUpperCase() + action.slice(1)} Company`,
                                                                    action.charAt(0).toUpperCase() + action.slice(1),
                                                                    async function () {
                                                                        try {
                                                                            const response = await fetch(`/api/superadmin/companies/${companyId}/status`, {
                                                                                method: 'PATCH',
                                                                                headers: { 'Content-Type': 'application/json' },
                                                                                credentials: 'same-origin',
                                                                                body: JSON.stringify({ status: newStatus })
                                                                            });
                                                                            const result = await response.json();
                                                                            if (result.success) {
                                                                                showToast(`Company ${action}d successfully.`, 'success');
                                                                                loadCompanies();
                                                                            } else {
                                                                                showToast(result.message || 'Failed to update status.', 'error');
                                                                            }
                                                                        } catch (error) {
                                                                            console.error('Error updating status:', error);
                                                                            alert('An error occurred.');
                                                                        }
                                                                    }
                                                                );
                                                            };

                                                            // ========== CONFIRM MODAL ==========
                                                            function showConfirmModal(message, title, actionLabel, onConfirm) {
                                                                const overlay = document.getElementById('confirm-modal');
                                                                document.getElementById('confirm-modal-title').textContent = title || 'Confirm';
                                                                document.getElementById('confirm-modal-message').innerHTML = message;
                                                                document.getElementById('confirm-modal-action').textContent = actionLabel || 'Confirm';
                                                                confirmCallback = onConfirm;
                                                                overlay.classList.add('active');
                                                            }

                                                            function closeConfirmModal() {
                                                                document.getElementById('confirm-modal').classList.remove('active');
                                                                confirmCallback = null;
                                                            }

                                                            document.getElementById('confirm-modal-cancel').addEventListener('click', closeConfirmModal);
                                                            document.getElementById('confirm-modal-close').addEventListener('click', closeConfirmModal);
                                                            document.getElementById('confirm-modal').addEventListener('click', function (e) {
                                                                if (e.target === this) closeConfirmModal();
                                                            });
                                                            document.getElementById('confirm-modal-action').addEventListener('click', function () {
                                                                if (confirmCallback) confirmCallback();
                                                                closeConfirmModal();
                                                            });

                                                            // ========== ADD COMPANY MODAL ==========
                                                            addCompanyBtn.addEventListener('click', function () {
                                                                modal.classList.add('active');
                                                            });

                                                            function closeAddModal() {
                                                                modal.classList.remove('active');
                                                                form.reset();
                                                            }

                                                            modalClose.addEventListener('click', closeAddModal);
                                                            modalCancel.addEventListener('click', closeAddModal);
                                                            modal.addEventListener('click', function (e) {
                                                                if (e.target === modal) closeAddModal();
                                                            });

                                                            modalSubmit.addEventListener('click', async function () {
                                                                if (form.checkValidity()) {
                                                                    const companyData = {
                                                                        companyName: document.getElementById('company-name').value,
                                                                        industry: document.getElementById('company-industry').value,
                                                                        planId: document.getElementById('company-plan').value,
                                                                        status: 'active',
                                                                        admin: {
                                                                            firstName: document.getElementById('admin-fname').value,
                                                                            lastName: document.getElementById('admin-lname').value,
                                                                            email: document.getElementById('admin-email').value,
                                                                            phone: document.getElementById('admin-phone').value
                                                                        }
                                                                    };

                                                                    modalSubmit.disabled = true;
                                                                    modalSubmit.innerHTML = '<span class="spinner"></span> Creating...';

                                                                    try {
                                                                        const response = await fetch('/api/superadmin/companies', {
                                                                            method: 'POST',
                                                                            headers: { 'Content-Type': 'application/json' },
                                                                            credentials: 'same-origin',
                                                                            body: JSON.stringify(companyData)
                                                                        });
                                                                        const result = await response.json();
                                                                        if (result.success) {
                                                                            closeAddModal();
                                                                            showToast('Company created successfully.', 'success');
                                                                            showPasswordModal(result.data.temporaryPassword);
                                                                            loadCompanies();
                                                                        } else {
                                                                            showToast(result.message || 'Failed to create company.', 'error');
                                                                        }
                                                                    } catch (error) {
                                                                        console.error('Error creating company:', error);
                                                                        alert('An error occurred while creating the company.');
                                                                    } finally {
                                                                        modalSubmit.disabled = false;
                                                                        modalSubmit.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg> Create Company';
                                                                    }
                                                                } else {
                                                                    form.reportValidity();
                                                                }
                                                            });

                                                            // ========== PASSWORD MODAL ==========
                                                            function showPasswordModal(password) {
                                                                generatedPassword.value = password;
                                                                passwordModal.classList.add('active');
                                                            }

                                                            function closePasswordModal() {
                                                                passwordModal.classList.remove('active');
                                                            }

                                                            passwordModalClose.addEventListener('click', closePasswordModal);
                                                            passwordModalDone.addEventListener('click', closePasswordModal);
                                                            passwordModal.addEventListener('click', function (e) {
                                                                if (e.target === passwordModal) closePasswordModal();
                                                            });

                                                            copyPasswordBtn.addEventListener('click', function () {
                                                                generatedPassword.select();
                                                                document.execCommand('copy');
                                                                copyPasswordBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>';
                                                                setTimeout(() => {
                                                                    copyPasswordBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
                                                                }, 2000);
                                                            });

                                                            // ========== SEARCH & FILTER ==========
                                                            const searchInput = document.querySelector('.search-input');
                                                            if (searchInput) {
                                                                let searchTimeout;
                                                                searchInput.addEventListener('input', function () {
                                                                    clearTimeout(searchTimeout);
                                                                    searchTimeout = setTimeout(() => { currentPage = 1; loadCompanies(); }, 300);
                                                                });
                                                            }

                                                            document.getElementById('status-filter').addEventListener('change', () => { currentPage = 1; loadCompanies(); });
                                                            document.getElementById('plan-filter').addEventListener('change', () => { currentPage = 1; loadCompanies(); });

                                                            // ========== CLOSE ON ESCAPE ==========
                                                            document.addEventListener('keydown', function (e) {
                                                                if (e.key === 'Escape') {
                                                                    if (document.getElementById('confirm-modal').classList.contains('active')) closeConfirmModal();
                                                                    else if (document.getElementById('view-company-modal').classList.contains('active')) closeViewCompanyModal();
                                                                    else if (document.getElementById('edit-company-modal').classList.contains('active')) closeEditCompanyModal();
                                                                    else if (modal.classList.contains('active')) closeAddModal();
                                                                    else if (passwordModal.classList.contains('active')) closePasswordModal();
                                                                }
                                                            });

                                                            // Close modals on overlay click
                                                            document.querySelectorAll('.modal-overlay').forEach(overlay => {
                                                                overlay.addEventListener('click', function (e) {
                                                                    if (e.target === overlay) overlay.classList.remove('active');
                                                                });
                                                            });

                                                            // ========== HELPERS ==========
                                                            window.loadCompanies = loadCompanies;

                                                            function escapeHtml(text) {
                                                                if (!text) return '';
                                                                const div = document.createElement('div');
                                                                div.textContent = text;
                                                                return div.innerHTML;
                                                            }

                                                            function formatDate(dateString) {
                                                                if (!dateString) return '–';
                                                                return new Date(dateString).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                                                            }

                                                            function formatNumber(n) {
                                                                if (n == null) return '0';
                                                                return Number(n).toLocaleString();
                                                            }
                                                        });
            </script>
        }